@model E_ShoppingManagement.ViewModels.CartViewModel

@{
    ViewData["Title"] = "Cart Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Cart Details</h2>
    <a asp-action="Index" class="theme-back-btn mb-0">Back to Carts</a>
</div>

<div class="page-card p-4" style="background: #f2efe9; border-radius: 12px; border: 1px solid #ddd;">

    <div class="mb-4 d-flex justify-content-between">
        <h4 style="color: #333;">Customer Cart: <span style="color: #007bff;">@Model.CustomerName</span></h4>
        <span class="badge bg-secondary">Status: Active</span>
    </div>

    @if (Model.Items == null || !Model.Items.Any())
    {
        <div class="alert alert-light">This cart is empty.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm" style="background: #f2efe9;">
                <thead style="background:#532374; color:#fff;">
                    <tr>
                        <th style="width: 70px;">SL No</th>
                        <th style="width: 100px;">Image</th>
                        <th>Product</th>
                        <th style="width: 120px;">Unit Price</th>
                        <th style="width: 100px;">Qty</th>
                        <th style="width: 120px;">Total</th>
                        <th style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var sl = 1; }
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@(sl++)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@(item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/images/products/" + item.ImageUrl)"
                                         style="width:60px;height:60px;object-fit:cover;border-radius:4px; border: 1px solid #eee;" />
                                }
                                else
                                {
                                    <div style="width:60px;height:60px;background:#f2efe9;border-radius:4px;"></div>
                                }
                            </td>
                            <td>
                                <div style="font-weight: 600; color: #333;">@item.ProductName</div>
                            </td>
                            <td style="color: #d9534f; font-weight: bold;">৳@item.UnitPrice.ToString("#,##0")</td>
                            <td><span class="badge bg-secondary">@item.Quantity.ToString("#,##0")</span></td>
                            <td style="font-weight: bold; color: #2c3e50;">৳@item.LineTotal.ToString("#,##0")</td>
                            <td>
                                <form asp-action="RemoveItem" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to remove this item from the cart?');">
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <input type="hidden" name="cartId" value="@Model.CartId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                        }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 p-3" style="background: #f2efe9; border-radius: 8px;">
            <div>
                <form asp-action="ClearCart" method="post" onsubmit="return confirm('Are you sure you want to clear the entire cart? This action cannot be undone.');">
                    <input type="hidden" name="cartId" value="@Model.CartId" />
                    <button type="submit" class="btn btn-danger btn-sm">Clear Entire Cart</button>
                </form>
            </div>
            <div style="font-size: 1.3rem; color: #333;">
                <strong>Grand Total:</strong> <span style="color: #d9534f; font-weight: bold;">৳@Model.Total.ToString("#,##0")</span>
            </div>
        </div>
    }


</div>



