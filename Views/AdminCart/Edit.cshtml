@model E_ShoppingManagement.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Edit Cart";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Edit Cart for @Model.CustomerName</h2>
    <a asp-action="Index" class="theme-back-btn mb-0">Back to List</a>
</div>

<div class="page-card p-3">
    <table class="table table-hover table-bordered align-middle">
        <thead style="background:#532374; color:#fff;">
            <tr>
                <th style="width: 70px;">SL No</th>
                <th>Product</th>
                <th style="width:100px;">Price</th>
                <th style="width:150px;">Quantity</th>
                <th style="width:120px;">Total</th>
                <th style="width:100px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{ var sl = 1; }
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@sl</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@(item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/images/products/" + item.ImageUrl)" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" />
                            }
                            <span>@item.ProductName</span>
                        </div>
                    </td>
                    <td>৳@item.UnitPrice.ToString("#,##0")</td>
                    <td>
                        <form asp-action="UpdateItemQuantity" method="post" class="d-flex gap-1">
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm" />
                            <button type="submit" class="btn btn-sm btn-primary">Update</button>
                        </form>
                    </td>
                    <td>৳@((item.UnitPrice * item.Quantity).ToString("#,##0"))</td>
                    <td>
                        <form asp-action="RemoveItem" method="post">
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <input type="hidden" name="cartId" value="@Model.CartId" />
                            <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                        </form>
                    </td>
                </tr>
                sl++;
            }
        </tbody>
    </table>
</div>
