@model IEnumerable<E_ShoppingManagement.ViewModels.CartViewModel>

@{
    ViewData["Title"] = "Carts";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Customer Carts</h2>
    <a href="javascript:history.back()" class="theme-back-btn mb-0">Back</a>
</div>

<div class="page-card p-3">
    <table class="table table-hover table-bordered align-middle">
        <thead style="background:#532374 !important; color:#fff !important;">
            <tr>
                <th style="width:70px;">SL No</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Total</th>
                <th>Status</th>
                <th style="width:140px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{ var sl = 1; }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No carts found.</td>
                </tr>
            }
            else
            {
                foreach (var cart in Model)
                {
                    <tr>
                        <td>@(sl++)</td>
                        <td>@cart.CustomerName</td>
                        <td>@cart.Items.Count.ToString("#,##0")</td>
                        <td>৳@cart.Total.ToString("#,##0")</td>
                        <td>Active</td>
                       
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@cart.CartId" class="btn btn-sm btn-secondary">View</a>
                                <a asp-action="Edit" asp-route-id="@cart.CartId" class="btn btn-sm btn-success">Edit</a>
                                <form asp-action="Delete" asp-route-id="@cart.CartId" method="post" onsubmit="return confirm('Delete this cart?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>



