@model E_ShoppingManagement.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml"; // Employee layout
}

<h2 class="mb-3">Edit Product</h2>

@if (ViewBag.Message != null)
{
    <div class="alert @(ViewBag.IsSuccess ? "alert-success" : "alert-danger")">
        @ViewBag.Message
    </div>
}

<style>
    .page-card {
        background: #f8f9fa;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        color: #333;
    }
    .form-control, .form-select {
        background-color: #fff !important;
        color: #333 !important;
        border: 1px solid #ced4da !important;
    }
    .form-control:focus, .form-select:focus {
        border-color: #80bdff !important;
        outline: 0;
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25) !important;
    }
</style>

<div class="page-card">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label">Product Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="form-label">Category</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="Model.CategoryList"></select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group mb-3">
                    <label asp-for="ProductTypeId" class="form-label">Product Type</label>
                    <select asp-for="ProductTypeId" class="form-select" asp-items="Model.ProductTypeList"></select>
                    <span asp-validation-for="ProductTypeId" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label>Regular Price</label>
                    <input asp-for="RegularPrice" id="regPrice" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="RegularPrice" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label>Offer %</label>
                    <input asp-for="OfferPercentage" id="offPercent" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="OfferPercentage" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label>Offer Price (Auto)</label>
                    <input asp-for="Price" id="offPrice" class="form-control" readonly style="background-color: #e9ecef;" />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label asp-for="StockQty" class="form-label">Stock Quantity</label>
                    <input asp-for="StockQty" class="form-control" type="number" />
                    <span asp-validation-for="StockQty" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label asp-for="VatPercentage" class="form-label">VAT %</label>
                    <input asp-for="VatPercentage" class="form-control" type="number" step="0.01" />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="AvailableSizes" class="form-label font-weight-bold">Available Sizes</label>
                    <div class="input-group mb-2">
                        <input asp-for="AvailableSizes" id="availableSizes" class="form-control" placeholder="e.g. S, M, L" />
                        <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('availableSizes').value=''; updateSizeFields();">Clear</button>
                    </div>
                    <div class="mb-3 d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-sm btn-outline-primary size-preset" data-size="S">S</button>
                        <button type="button" class="btn btn-sm btn-outline-primary size-preset" data-size="M">M</button>
                        <button type="button" class="btn btn-sm btn-outline-primary size-preset" data-size="L">L</button>
                        <button type="button" class="btn btn-sm btn-outline-primary size-preset" data-size="XL">XL</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary size-preset" data-size="36">36</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary size-preset" data-size="38">38</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary size-preset" data-size="40">40</button>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div id="sizeStockContainer" class="mt-2 mb-3 shadow-sm" style="display:none; background: #ffffff; padding: 20px; border-radius: 12px; border: 2px solid #28a745;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-box-seam me-2 fs-5 text-success"></i>
                        <h6 class="fw-bold mb-0">Inventory by Size</h6>
                    </div>
                    
                    @if (Model.SizeStocks != null && Model.SizeStocks.Any())
                    {
                        <div id="initialSizeStocks" style="display:none;">
                            @foreach (var ss in Model.SizeStocks)
                            {
                                <div class="initial-stock" data-size="@ss.Size" data-qty="@ss.StockQty"></div>
                            }
                        </div>
                    }

                    <div class="row g-2" id="sizeStockInputs"></div>
                    <div class="mt-2 text-center">
                        <span class="text-muted extra-small">Total Stock: <span id="totalStockDisplay" class="fw-bold text-dark">@Model.StockQty</span></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" rows="3" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="ImageFile" class="form-label">Update Product Image</label>
            <input asp-for="ImageFile" type="file" class="form-control" />
        </div>

        <div class="mt-4 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            function calculateOffer() {
                var regPrice = parseFloat($('#regPrice').val()) || 0;
                var offPercent = parseFloat($('#offPercent').val()) || 0;
                var offerPrice = regPrice - (regPrice * (offPercent / 100));
                $('#offPrice').val(offerPrice.toFixed(2));
            }
            $('#regPrice, #offPercent').on('input', function() {
                calculateOffer();
            });

            // Size-wise stock logic
            $('.size-preset').off('click').on('click', function() {
                var size = $(this).data('size');
                var current = $('#availableSizes').val();
                if (current.includes(size)) return;
                
                if (current && !current.endsWith(',')) current += ', ';
                $('#availableSizes').val(current + size);
                updateSizeFields();
            });

            $('#availableSizes').on('input', function() {
                updateSizeFields();
            });

            function updateSizeFields() {
                var sizesStr = $('#availableSizes').val();
                var container = $('#sizeStockContainer');
                var inputsDiv = $('#sizeStockInputs');
                
                if (!sizesStr || sizesStr.trim() === '') {
                    container.hide();
                    inputsDiv.empty();
                    calculateTotalStock();
                    return;
                }

                var sizes = sizesStr.split(',').map(s => s.trim()).filter(s => s !== '');
                if (sizes.length === 0) {
                    container.hide();
                    inputsDiv.empty();
                    calculateTotalStock();
                    return;
                }

                container.show();
                var existingValues = {};
                
                // First check current inputs
                inputsDiv.find('input.size-stock-input').each(function() {
                    existingValues[$(this).attr('data-size')] = $(this).val();
                });

                // Then check initial values from DB (if current inputs are empty)
                $('.initial-stock').each(function() {
                    var s = $(this).attr('data-size');
                    var q = $(this).attr('data-qty');
                    if (existingValues[s] === undefined) {
                        existingValues[s] = q;
                    }
                });

                inputsDiv.empty();
                sizes.forEach((size, index) => {
                    var val = existingValues[size] || 0;
                    var html = `
                        <div class="col-6 mb-3">
                            <div class="p-2 border rounded text-center bg-light">
                                <label class="small fw-bold d-block mb-1 text-uppercase">${size}</label>
                                <input type="number" name="SizeStocks[${index}].StockQty" 
                                       data-size="${size}" value="${val}" class="form-control form-control-sm size-stock-input text-center" min="0" />
                                <input type="hidden" name="SizeStocks[${index}].Size" value="${size}" />
                            </div>
                        </div>`;
                    inputsDiv.append(html);
                });

                $('.size-stock-input').off('input').on('input', calculateTotalStock);
                calculateTotalStock();
            }

            function calculateTotalStock() {
                var total = 0;
                var inputs = $('.size-stock-input');
                inputs.each(function() {
                    total += parseInt($(this).val()) || 0;
                });
                
                var stockInput = $('input[name="StockQty"]');
                stockInput.val(total);
                $('#totalStockDisplay').text(total);
                
                if (inputs.length > 0) {
                    stockInput.prop('readonly', true).css('background-color', '#e9ecef');
                } else {
                    stockInput.prop('readonly', false).css('background-color', '#fff');
                }
            }

            calculateOffer();
            updateSizeFields();
        });
    </script>
}
