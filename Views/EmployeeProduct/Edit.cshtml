@model E_ShoppingManagement.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml"; // Employee layout
}

<h2 class="mb-3">Edit Product</h2>

<style>
    .size-toggle-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 14px;
        border: 1.5px solid #ced4da;
        border-radius: 20px;
        background: #fff;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        color: #555;
        transition: all 0.18s ease;
    }
    .size-toggle-btn .size-check-icon {
        display: none;
        color: #28a745;
        font-weight: 700;
    }
    .size-toggle-btn.active {
        background: #e6f4ea;
        border-color: #28a745;
        color: #1a7c35;
    }
    .size-toggle-btn.active .size-check-icon {
        display: inline;
    }
    .size-stock-input::-webkit-outer-spin-button,
    .size-stock-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .size-stock-input { -moz-appearance: textfield; }
</style>

@if (ViewBag.Message != null)
{
    <div class="alert @(ViewBag.IsSuccess ? "alert-success" : "alert-danger")">
        @ViewBag.Message
    </div>
}

<style>
    .page-card {
        background: #f8f9fa;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        color: #333;
    }
    .form-control, .form-select {
        background-color: #fff !important;
        color: #333 !important;
        border: 1px solid #ced4da !important;
    }
    .form-control:focus, .form-select:focus {
        border-color: #80bdff !important;
        outline: 0;
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25) !important;
    }
</style>

<div class="page-card">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label">Product Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="form-label">Category</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="Model.CategoryList"></select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group mb-3">
                    <label asp-for="ProductTypeId" class="form-label">Product Type</label>
                    <select asp-for="ProductTypeId" class="form-select" asp-items="Model.ProductTypeList"></select>
                    <span asp-validation-for="ProductTypeId" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label>Regular Price</label>
                    <input asp-for="RegularPrice" id="regPrice" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="RegularPrice" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label>Offer %</label>
                    <input asp-for="OfferPercentage" id="offPercent" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="OfferPercentage" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label>Offer Price (Auto)</label>
                    <input asp-for="Price" id="offPrice" class="form-control" readonly style="background-color: #e9ecef;" />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label asp-for="VatPercentage" class="form-label">VAT %</label>
                    <input asp-for="VatPercentage" class="form-control" type="number" step="0.01" />
                </div>
            </div>
        </div>

        <input type="hidden" asp-for="AvailableSizes" id="availableSizesHidden" />

        <div class="form-group mb-3">
            <label>Available Sizes</label>
            <div class="d-flex flex-wrap gap-2 mt-1">
                @{
                    var sizesList = new[] { "S", "M", "L", "XL", "XXL", "3XL" };
                    var savedSizes = (Model?.AvailableSizes ?? "").Split(',').Select(s => s.Trim()).ToList();
                }
                @foreach (var sz in sizesList)
                {
                    var isActive = savedSizes.Contains(sz);
                    <button type="button" class="size-toggle-btn @(isActive ? "active" : "")" data-size="@sz">
                        <span class="size-check-icon">&#10003;</span> @sz
                    </button>
                }
            </div>
        </div>

        <div class="form-group mb-3">
            <label>Size Wise Quantity</label>
            <div class="d-flex flex-wrap gap-3 mt-1">
                @{
                    int idx = 0;
                }
                @foreach (var size in sizesList)
                {
                    var stockVal = Model?.SizeStocks?.FirstOrDefault(s => s.Size == size)?.StockQty ?? 0;
                    var isActive2 = savedSizes.Contains(size);
                    <div class="size-stock-row" data-size="@size" style="display:@(isActive2 ? "flex" : "none");">
                        <div class="d-flex flex-column align-items-center">
                            <small class="text-muted mb-1 fw-semibold">@size</small>
                            <div class="input-group" style="width:110px;">
                                <button type="button" class="btn btn-outline-secondary btn-sm size-dec" data-target="sizeQty_@size">&#8722;</button>
                                <input type="number" id="sizeQty_@size" name="SizeStocks[@idx].StockQty" value="@stockVal" class="form-control form-control-sm size-stock-input text-center" min="0" />
                                <button type="button" class="btn btn-outline-secondary btn-sm size-inc" data-target="sizeQty_@size">&#43;</button>
                            </div>
                            <input type="hidden" name="SizeStocks[@idx].Size" value="@size" />
                        </div>
                    </div>
                    idx++;
                }
            </div>
            <small class="text-muted mt-2 d-block">Total stock quantity will be automatically calculated.</small>
        </div>

        <div class="form-group mb-3">
            <label asp-for="StockQty">Stock Quantity (Auto-calculated)</label>
            <input asp-for="StockQty" id="stockQtyInput" class="form-control" readonly style="background-color: #e9ecef;" />
            <small class="text-muted">Automatically summed from size-wise quantities above.</small>
            <span asp-validation-for="StockQty" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" rows="3" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="ImageFile" class="form-label">Update Product Image</label>
            <input asp-for="ImageFile" type="file" class="form-control" id="imageInput" accept="image/*" />
            @if (!string.IsNullOrEmpty(Model?.ExistingImageUrl))
            {
                <div id="imagePreviewWrapper" style="margin-top:10px;">
                    <img id="imagePreview" src="@Model.ExistingImageUrl" alt="Current Product Image" style="height: 120px; width: auto; border-radius: 6px; border: 1px solid #ddd; box-shadow: 0 2px 6px rgba(0,0,0,0.1);" />
                    <p class="text-muted mt-1" style="font-size:0.82rem;" id="imagePreviewLabel">Current image (select a new file to change)</p>
                </div>
            }
            else
            {
                <div id="imagePreviewWrapper" style="display:none; margin-top:10px;">
                    <img id="imagePreview" src="#" alt="Selected Image Preview" style="height: 120px; width: auto; border-radius: 6px; border: 1px solid #ddd; box-shadow: 0 2px 6px rgba(0,0,0,0.1);" />
                    <p class="text-muted mt-1" style="font-size:0.82rem;" id="imagePreviewLabel">Selected image preview</p>
                </div>
            }
        </div>

        <div class="mt-4 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            function calculateOffer() {
                var regPrice = parseFloat($('#regPrice').val()) || 0;
                var offPercent = parseFloat($('#offPercent').val()) || 0;
                var offerPrice = regPrice - (regPrice * (offPercent / 100));
                $('#offPrice').val(offerPrice.toFixed(2));
            }
            $('#regPrice, #offPercent').on('input', function() {
                calculateOffer();
            });

            // Size toggle button click
            $(document).on('click', '.size-toggle-btn', function() {
                $(this).toggleClass('active');
                var size = $(this).data('size');
                var row = $('.size-stock-row[data-size="' + size + '"]');
                if ($(this).hasClass('active')) {
                    row.css('display', 'flex');
                } else {
                    row.hide();
                    row.find('.size-stock-input').val(0);
                }
                calculateTotalStock();
            });

            // +/- buttons
            $(document).on('click', '.size-inc', function() {
                var inp = $('#' + $(this).data('target'));
                inp.val((parseInt(inp.val()) || 0) + 1);
                calculateTotalStock();
            });
            $(document).on('click', '.size-dec', function() {
                var inp = $('#' + $(this).data('target'));
                var v = (parseInt(inp.val()) || 0) - 1;
                inp.val(v < 0 ? 0 : v);
                calculateTotalStock();
            });

            // Image preview on new file select
            $('#imageInput').on('change', function() {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imagePreview').attr('src', e.target.result);
                        $('#imagePreviewWrapper').show();
                        $('#imagePreviewLabel').text('New image preview');
                    };
                    reader.readAsDataURL(file);
                }
            });

            function calculateTotalStock() {
                var total = 0;
                var availSizes = [];
                $('.size-toggle-btn.active').each(function() {
                    availSizes.push($(this).data('size'));
                });
                $('.size-stock-row:visible .size-stock-input').each(function() {
                    total += parseInt($(this).val()) || 0;
                });

                $('#stockQtyInput').val(total);
                $('#availableSizesHidden').val(availSizes.join(', '));
            }

            $(document).on('input', '.size-stock-input', calculateTotalStock);

            calculateOffer();
            calculateTotalStock();
        });
    </script>
}
