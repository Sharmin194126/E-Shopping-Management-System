@model E_ShoppingManagement.Models.Product

@{
    ViewData["Title"] = "Product Details";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<h2 class="mb-3">Product Details</h2>

<div class="page-card">
    <div class="row">
        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@(Model.ImageUrl.StartsWith("/") ? Model.ImageUrl : "/images/products/" + Model.ImageUrl)" class="img-fluid rounded border shadow-sm" style="max-height: 400px; width: 100%; object-fit: contain; background: #f2efe9;" />
            }
            else
            {
                <img src="/images/no-image.png" class="img-fluid rounded border" />
            }
        </div>
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">Product Name</dt>
                <dd class="col-sm-8 fw-bold">@Model.Name</dd>

                <dt class="col-sm-4">Category</dt>
                <dd class="col-sm-8">@Model.Category?.Name</dd>

                <dt class="col-sm-4">Product Type</dt>
                <dd class="col-sm-8">@(Model.ProductType?.Name ?? Model.ProductTypeId.ToString())</dd>

                <dt class="col-sm-4">Regular Price</dt>
                <dd class="col-sm-8 text-muted text-decoration-line-through">৳ @Model.RegularPrice</dd>

                <dt class="col-sm-4">Price</dt>
                <dd class="col-sm-8 fw-bold text-danger">৳ @Model.Price</dd>

                <dt class="col-sm-4">Total Stock</dt>
                <dd class="col-sm-8 text-primary fw-bold">@Model.StockQty units</dd>
            </dl>

            <div class="mt-4">
                <h5 class="fw-bold"><i class="bi bi-box-seam me-2"></i>Stock Inventory by Size</h5>
                @{
                    var sizeStocks = ViewBag.SizeStocks as List<E_ShoppingManagement.Models.ProductSizeStock>;
                }
                @if (sizeStocks != null && sizeStocks.Any())
                {
                    <div class="table-responsive">
                    <table class="table table-sm table-bordered mt-2">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 30%">Size</th>
                                <th style="width: 40%">Stock Qty</th>
                                <th style="width: 30%">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ss in sizeStocks)
                            {
                                <tr>
                                    <td><span class="badge bg-primary px-3">@ss.Size</span></td>
                                    <td>@ss.StockQty</td>
                                    <td>
                                        @if (ss.StockQty > 0)
                                        {
                                            <span class="text-success small fw-bold"><i class="bi bi-check-circle-fill"></i> In Stock</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger small fw-bold"><i class="bi bi-x-circle-fill"></i> Out of Stock</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-light border small py-2"><i class="bi bi-info-circle me-2"></i>No size-specific stock defined.</div>
                }
            </div>

            <dl class="row mt-4">
                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8">
                    <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-danger")">@Model.Status</span>
                </dd>

                <dt class="col-sm-4">Approved</dt>
                <dd class="col-sm-8">
                    @if(Model.IsApproved) {
                        <span class="text-success fw-bold"><i class="bi bi-patch-check-fill"></i> Approved</span>
                    } else {
                        <span class="text-warning fw-bold"><i class="bi bi-clock-history"></i> Pending</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-4 d-flex justify-content-between border-top pt-3">
        <a asp-action="Index" class="theme-back-btn">Back to List</a>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning fw-bold">Edit Product</a>
        </div>
    </div>
</div>


