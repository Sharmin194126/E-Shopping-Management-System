@model E_ShoppingManagement.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Create Product";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml"; // Employee layout
}

<h2 class="mb-3">Create Product</h2>

<style>
    /* Square checkbox style */
    .size-chk-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 500;
        color: #333;
        user-select: none;
    }
    .size-chk-label input[type="checkbox"] {
        display: none;
    }
    .size-chk-box {
        width: 20px;
        height: 20px;
        border: 2px solid #6c757d;
        border-radius: 3px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f2efe9;
        flex-shrink: 0;
        transition: border-color 0.15s;
    }
    .size-chk-label input[type="checkbox"]:checked + .size-chk-box {
        border-color: #333;
    }
    .size-chk-label input[type="checkbox"]:checked + .size-chk-box::after {
        content: '\2713';
        font-size: 13px;
        font-weight: 700;
        color: #333;
    }
    /* Size quantity input group */
    .size-qty-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 8px;
    }
    .size-qty-item {
        display: flex;
        align-items: stretch;
        border: 1px solid #ced4da;
        border-radius: 4px;
        overflow: hidden;
    }
    .size-qty-item .size-label {
        display: flex;
        align-items: center;
        padding: 4px 10px;
        background: #f2efe9;
        border-right: 1px solid #ced4da;
        font-weight: 700;
        font-size: 0.9rem;
        color: #333;
        min-width: 38px;
        justify-content: center;
    }
    .size-qty-item input[type=number] {
        width: 70px;
        border: none;
        text-align: center;
        padding: 4px 6px;
        font-size: 0.9rem;
        outline: none;
    }
    .size-qty-item input[type=number]:focus {
        background: #f0f4ff;
    }
    .page-card {
        background: #f2efe9;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        color: #333;
    }
    .form-control, .form-select {
        background-color: #f2efe9 !important;
        color: #333 !important;
        border: 1px solid #ced4da !important;
    }
    .form-control:focus, .form-select:focus {
        border-color: #80bdff !important;
        outline: 0;
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25) !important;
    }
</style>

<div class="page-card">
    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label">Product Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="form-label">Category</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="Model.CategoryList">
                        <option value="">Category</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group mb-3">
                    <label asp-for="ProductTypeId" class="form-label">Product Type</label>
                    <select asp-for="ProductTypeId" class="form-select" asp-items="Model.ProductTypeList">
                        <option value=""> Type </option>
                    </select>
                    <span asp-validation-for="ProductTypeId" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label>Regular Price</label>
                    <input asp-for="RegularPrice" id="regPrice" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="RegularPrice" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label>Offer %</label>
                    <input asp-for="OfferPercentage" id="offPercent" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="OfferPercentage" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label>Offer Price (Auto)</label>
                    <input asp-for="Price" id="offPrice" class="form-control" readonly style="background-color: #e9ecef;" />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label asp-for="VatPercentage" class="form-label">VAT %</label>
                    <input asp-for="VatPercentage" class="form-control" type="number" step="0.01" />
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label asp-for="DisplayCategory" class="form-label">Home Display Section</label>
                    <select asp-for="DisplayCategory" class="form-select" asp-items="Model.DisplayCategoryList">
                        <option value=""> None </option>
                    </select>
                </div>
            </div>
        </div>

        <input type="hidden" asp-for="AvailableSizes" id="availableSizesHidden" />

        <div class="form-group mb-3">
            <label>Available Sizes</label>
            <div class="d-flex flex-wrap gap-4 mt-2">
                @{
                    var sizesList = new[] { "S", "M", "L", "XL", "XXL", "3XL" };
                }
                @foreach (var sz in sizesList)
                {
                    <label class="size-chk-label">
                        <input type="checkbox" class="size-checkbox" value="@sz" id="sizeChk_@sz" />
                        <span class="size-chk-box"></span>
                        @sz
                    </label>
                }
            </div>
        </div>

        <div class="form-group mb-3">
            <label>Size Wise Quantity</label>
            <div class="size-qty-row">
                @{
                    int idx = 0;
                }
                @foreach (var size in sizesList)
                {
                    <div class="size-qty-item">
                        <span class="size-label">@size</span>
                        <input type="number" id="sizeQty_@size"
                               name="SizeStocks[@idx].StockQty"
                               value="0"
                               class="size-stock-input"
                               min="0" />
                    </div>
                    <input type="hidden" name="SizeStocks[@idx].Size" value="@size" />
                    idx++;
                }
            </div>
            <small class="text-muted mt-2 d-block">Total stock quantity will be automatically calculated.</small>
        </div>

        <div class="form-group mb-3">
            <label asp-for="StockQty">Stock Quantity (Auto-calculated)</label>
            <input asp-for="StockQty" id="stockQtyInput" class="form-control" readonly style="background-color: #e9ecef;" />
            <small class="text-muted">Automatically summed from size-wise quantities above.</small>
            <span asp-validation-for="StockQty" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" rows="3" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="ImageFile" class="form-label">Product Image</label>
            <input asp-for="ImageFile" type="file" class="form-control" id="imageInput" accept="image/*" />
            <div id="imagePreviewWrapper" style="display:none; margin-top:10px;">
                <img id="imagePreview" src="#" alt="Selected Image Preview" style="height: 120px; width: auto; border-radius: 6px; border: 1px solid #ddd; box-shadow: 0 2px 6px rgba(0,0,0,0.1);" />
                <p class="text-muted mt-1" style="font-size:0.82rem;">Selected image preview</p>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-between">
            <a asp-action="Index" class="theme-back-btn">Back to List</a>
            <button type="submit" class="btn btn-primary">Save</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            function calculateOffer() {
                var regPrice = parseFloat($('#regPrice').val()) || 0;
                var offPercent = parseFloat($('#offPercent').val()) || 0;
                var offerPrice = regPrice - (regPrice * (offPercent / 100));
                $('#offPrice').val(offerPrice.toFixed(2));
            }

            $('#regPrice, #offPercent').on('input', function() {
                calculateOffer();
            });

            // Image preview using native JS for robustness
            const imageInput = document.getElementById('imageInput');
            if (imageInput) {
                imageInput.addEventListener('change', function() {
                    const file = this.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            const preview = document.getElementById('imagePreview');
                            const wrapper = document.getElementById('imagePreviewWrapper');
                            if (preview && wrapper) {
                                preview.src = e.target.result;
                                wrapper.style.display = 'block';
                            }
                        };
                        reader.readAsDataURL(file);
                    } else {
                        const wrapper = document.getElementById('imagePreviewWrapper');
                        if (wrapper) wrapper.style.display = 'none';
                    }
                });
            }

            function calculateTotalStock() {
                var total = 0;
                var availSizes = [];
                $('.size-checkbox:checked').each(function() {
                    availSizes.push($(this).val());
                });
                $('.size-stock-input').each(function() {
                    total += parseInt($(this).val()) || 0;
                });

                $('#stockQtyInput').val(total);
                $('#availableSizesHidden').val(availSizes.join(', '));
            }

            $(document).on('input', '.size-stock-input', calculateTotalStock);
            $(document).on('change', '.size-checkbox', calculateTotalStock);

            calculateOffer();
            calculateTotalStock();
        });
    </script>
}



