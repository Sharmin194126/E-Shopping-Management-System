@model E_ShoppingManagement.Models.Product

@{
    ViewData["Title"] = "Delete Product";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Product</h2>
    <a asp-action="Index" class="theme-back-btn">Back to List</a>
</div>

<div class="alert alert-warning border-warning border-start border-4">
    <h5 class="fw-bold mb-1">Are you sure you want to delete this product?</h5>
    <p class="mb-0">This action cannot be undone. All associated data and stock history will be removed.</p>
</div>

<div class="page-card">
    <div class="row">
        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@(Model.ImageUrl.StartsWith("/") ? Model.ImageUrl : "/images/products/" + Model.ImageUrl)" class="img-fluid rounded border shadow-sm" style="max-height: 400px; width: 100%; object-fit: contain; background: #f2efe9;" />
            }
            else
            {
                <img src="/images/no-image.png" class="img-fluid rounded border" />
            }
        </div>
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">Product Name</dt>
                <dd class="col-sm-8 fw-bold">@Model.Name</dd>

                <dt class="col-sm-4">Category</dt>
                <dd class="col-sm-8">@Model.Category?.Name</dd>

                <dt class="col-sm-4">Regular Price</dt>
                <dd class="col-sm-8 text-muted text-decoration-line-through">৳ @Model.RegularPrice</dd>

                <dt class="col-sm-4">Current Price</dt>
                <dd class="col-sm-8 fw-bold">৳ @Model.Price</dd>

                <dt class="col-sm-4">Total Stock</dt>
                <dd class="col-sm-8">@Model.StockQty units</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8">
                    <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-danger")">@Model.Status</span>
                </dd>
            </dl>

            <div class="mt-4">
                <h5 class="fw-bold"><i class="bi bi-box-seam me-2"></i>Stock Inventory</h5>
                @{
                    var sizeStocks = ViewBag.SizeStocks as List<E_ShoppingManagement.Models.ProductSizeStock>;
                }
                @if (sizeStocks != null && sizeStocks.Any())
                {
                    <div class="table-responsive">
                    <table class="table table-sm table-bordered mt-2">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 50%">Size</th>
                                <th style="width: 50%">Stock Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ss in sizeStocks)
                            {
                                <tr>
                                    <td>@ss.Size</td>
                                    <td>@ss.StockQty</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                }
            </div>

            <form asp-action="Delete" method="post" class="mt-5 pt-3 border-top">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-danger px-5 py-2 fw-bold">
                        <i class="bi bi-trash-fill me-2"></i>Confirm Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4 py-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
