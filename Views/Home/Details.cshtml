@model E_ShoppingManagement.ViewModels.ProductDetailsViewModel
@{
    ViewData["Title"] = Model.Product.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var sizes = !string.IsNullOrEmpty(Model.Product.AvailableSizes)
        ? Model.Product.AvailableSizes.Split(',').Select(s => s.Trim()).Where(s => !string.IsNullOrEmpty(s)).ToArray()
        : null;

    string RenderStars(double rating) {
        int fullStars = (int)Math.Round(rating);
        string stars = "";
        for(int i=0; i<fullStars; i++) stars += "★";
        for(int i=fullStars; i<5; i++) stars += "☆";
        return stars;
    }
}

<style>
    .live-chat-btn {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
        background: linear-gradient(135deg, #532374, #8b1a6b);
        color: white;
        padding: 10px 20px;
        border-radius: 30px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 16px;
        font-weight: bold;
        box-shadow: 0 4px 15px rgba(83, 35, 116, 0.35);
        cursor: pointer;
        transition: transform 0.3s;
        border: none;
    }
    .live-chat-btn:hover {
        transform: scale(1.05);
        color: white;
        background: linear-gradient(135deg, #3d1a55, #532374);
    }
    .chat-box {
        position: fixed;
        bottom: 90px;
        right: 20px;
        width: 350px;
        height: 500px;
        background: #f8f6f0;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        z-index: 9998;
        display: none;
        flex-direction: column;
    }
    .chat-box.active {
        display: flex;
    }
    .chat-header {
        background: linear-gradient(135deg, #532374, #8b1a6b);
        color: white;
        padding: 15px;
        border-radius: 15px 15px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .chat-body {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        background: #f5f5f5;
    }
    .chat-footer {
        padding: 15px;
        border-top: 1px solid #ddd;
        display: flex;
        gap: 10px;
    }
    .chat-message {
        margin-bottom: 10px;
        padding: 10px;
        border-radius: 8px;
        max-width: 80%;
    }
    .chat-message.user {
        background: #dcf8c6;
        margin-left: auto;
    }
    .chat-message.support {
        background: #f8f6f0;
    }
    .rating-bar {
        height: 8px;
        background: #eee;
        border-radius: 4px;
        overflow: hidden;
    }
    .rating-fill {
        height: 100%;
        background: #ffc107;
    }
    .live-chat-banner {
        background: linear-gradient(135deg, #532374 0%, #8b1a6b 100%);
        color: white;
        padding: 20px 0;
        margin-bottom: 30px;
        box-shadow: 0 4px 15px rgba(83, 35, 116, 0.2);
    }
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    /* Daraz Style Zoom */
    .img-zoom-container {
        position: relative;
        width: 100%;
        cursor: zoom-in !important;
    }
    .img-zoom-lens {
        position: absolute;
        border: 1px solid #d4d4d4;
        width: 150px;
        height: 150px;
        background-color: rgba(255, 255, 255, 0.4);
        display: none;
        z-index: 10;
        pointer-events: none; /* Allows cursor to interact with image below */
        cursor: zoom-in !important; /* Strict cursor requirement */
    }
    .img-zoom-result {
        position: absolute;
        top: 0;
        left: 105%;
        border: 1px solid #e0e0e0;
        width: 450px;
        height: 450px;
        background-color: #f8f6f0;
        display: none; /* hidden until hover */
        z-index: 999;
        box-shadow: 0 5px 20px rgba(0,0,0,0.15);
        background-repeat: no-repeat;
    }
    input[type="number"].no-spin::-webkit-inner-spin-button,
    input[type="number"].no-spin::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    input[type="number"].no-spin {
        -moz-appearance: textfield;
    }
    .size-label {
        border-color: #532374 !important;
        color: #532374 !important;
    }
    .size-label:hover, .size-select:checked + .size-label {
        background-color: #532374 !important;
        color: white !important;
        border-color: #532374 !important;
    }
</style>

<div class="live-chat-banner">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h4 class="mb-1" style="color: #FFD700 !important; font-weight: 800;"><i class="bi bi-chat-text-fill me-2"></i>Live Chat Support Available!</h4>
            <p class="mb-0 small" style="color: #ffffff !important; font-weight: 600;">Connect with our product experts instantly via our Live Chat button for real-time assistance.</p>
        </div>
        <button onclick="toggleChat()" class="btn btn-warning fw-bold px-4 text-dark shadow-sm">Start Chat Now</button>
    </div>
</div>

<div class="container mt-2">
    <a href="javascript:history.back()" class="theme-back-btn"><i class="bi bi-arrow-left"></i> Back to Exploration</a>
    <div class="row">
        <!-- Image Section -->
        <div class="col-md-5 position-relative">
            <div class="img-zoom-container" id="zoomContainer" onmouseenter="showZoom()" onmousemove="moveZoom(event)" onmouseleave="hideZoom()">
                <img id="myimage" src="@(string.IsNullOrEmpty(Model.Product.ImageUrl) ? "/images/no-image.png" : (Model.Product.ImageUrl.StartsWith("/") ? Model.Product.ImageUrl : "/images/products/" + Model.Product.ImageUrl))" 
                     class="img-fluid rounded border" alt="@Model.Product.Name" style="height: 500px; width: 100%; object-fit: contain; background: #f8f6f0; cursor: zoom-in !important;" />
                <div id="mylens" class="img-zoom-lens"></div>
            </div>
            <!-- Daraz zoomed result pops out to the right here -->
            <div id="myresult" class="img-zoom-result"></div>
            
            <script>
                function showZoom() {
                    const img = document.getElementById('myimage');
                    const lens = document.getElementById('mylens');
                    const result = document.getElementById('myresult');
                    
                    if(!img.src || img.src.includes('no-image.png')) return;
                    
                    lens.style.display = 'block';
                    result.style.display = 'block';
                    
                    result.style.backgroundImage = "url('" + img.src + "')";
                    updateZoom(img, lens, result, null);
                }
                
                function moveZoom(event) {
                    const img = document.getElementById('myimage');
                    const lens = document.getElementById('mylens');
                    const result = document.getElementById('myresult');
                    if (lens.style.display === 'block') {
                        updateZoom(img, lens, result, event);
                    }
                }
                
                function hideZoom() {
                    document.getElementById('mylens').style.display = 'none';
                    document.getElementById('myresult').style.display = 'none';
                }
                
                function updateZoom(img, lens, result, e) {
                    const cx = result.offsetWidth / lens.offsetWidth;
                    const cy = result.offsetHeight / lens.offsetHeight;
                    result.style.backgroundSize = (img.width * cx) + "px " + (img.height * cy) + "px";
                    
                    if(!e) return;
                    
                    const rect = img.getBoundingClientRect();
                    let x = e.clientX - rect.left;
                    let y = e.clientY - rect.top;
                    
                    let xPos = x - (lens.offsetWidth / 2);
                    let yPos = y - (lens.offsetHeight / 2);
                    
                    if (xPos > img.width - lens.offsetWidth) { xPos = img.width - lens.offsetWidth; }
                    if (xPos < 0) { xPos = 0; }
                    if (yPos > img.height - lens.offsetHeight) { yPos = img.height - lens.offsetHeight; }
                    if (yPos < 0) { yPos = 0; }
                    
                    lens.style.left = xPos + "px";
                    lens.style.top = yPos + "px";
                    
                    result.style.backgroundPosition = "-" + (xPos * cx) + "px -" + (yPos * cy) + "px";
                }
            </script>
        </div>
        
        <!-- Details Section -->
        <div class="col-md-7">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">@TempData["Message"]</div>
            }
            <h2>@Model.Product.Name</h2>
            <div class="mb-2">
                <span class="text-warning fs-5">@Html.Raw(RenderStars(Model.Product.AverageRating))</span>
                <span class="text-muted">(@Model.Product.AverageRating.ToString("0.0")) | @Model.TotalReviews.ToString("#,##0") Reviews</span>
            </div>
            <div class="price-area mb-3 p-3 rounded" style="background: rgba(83,35,116,0.05); border-left: 4px solid #532374;">
                @if (Model.Product.OfferPercentage > 0)
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-danger">@Model.Product.OfferPercentage% OFF</span>
                        <span class="text-danger fw-bold small text-uppercase" style="letter-spacing: 1px;">Limited Time Offer!</span>
                    </div>
                }
                
                <div class="d-flex flex-column gap-1">
                    @if (Model.Product.RegularPrice > Model.Product.Price)
                    {
                        <div>
                            <span class="text-muted small">Regular Price: </span>
                            <span class="text-muted text-decoration-line-through">৳ @Model.Product.RegularPrice.ToString("#,##0")</span>
                        </div>
                    }
                    <div class="d-flex align-items-baseline gap-2">
                        <h3 class="text-danger fw-bold mb-0" style="font-size: 2rem;">৳ @Model.Product.Price.ToString("#,##0")</h3>
                        @if (Model.Product.OfferPercentage > 0)
                        {
                            <span class="text-muted small">(Offer Price)</span>
                        }
                    </div>
                </div>

                @if (Model.Product.VatPercentage > 0)
                {
                    decimal vAmt = (Model.Product.Price * Model.Product.VatPercentage) / 100;
                    decimal totalWVat = Model.Product.Price + vAmt;
                    
                    <div class="mt-2 border-top pt-2">
                        <div class="text-muted small d-flex justify-content-between" style="max-width: 250px;">
                            <span>Price:</span>
                            <span class="fw-bold">৳ @Model.Product.Price.ToString("#,##0")</span>
                        </div>
                        <div class="text-muted small d-flex justify-content-between" style="max-width: 250px;">
                            <span>VAT (@Model.Product.VatPercentage%):</span>
                            <span class="fw-bold text-success">+ ৳ @vAmt.ToString("#,##0")</span>
                        </div>
                        <div class="text-dark fw-bold d-flex justify-content-between" style="max-width: 250px; font-size: 1.1rem;">
                            <span>Grand Total:</span>
                            <span class="text-danger">৳ @totalWVat.ToString("#,##0")</span>
                        </div>
                    </div>
                }
            </div>
            
            <p class="mt-3">@Model.Product.Description</p>
            
            <hr />
            
            <form method="get" id="addToCartForm">
                <input type="hidden" name="productId" value="@Model.Product.Id" />
                <input type="hidden" id="selectedSizeStock" value="@Model.Product.StockQty" /> @* Default to total stock, but will update on size select *@
                
                @if (sizes != null && sizes.Any())
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark fs-5">Select Size:</label>
                        <div class="d-flex gap-2 mb-2">
                            @foreach (var size in sizes)
                            {
                                <input type="radio" class="btn-check size-select" name="size" id="size-@size" value="@size" required autocomplete="off">
                                <label class="btn size-label px-3 py-2 fw-bold" for="size-@size">@size</label>
                            }
                        </div>
                        <div id="sizeStockDisplay" class="mt-2 p-2 rounded" style="display:none; background-color: #f8f9fa; border: 1px solid #dee2e6;">
                            <i class="bi bi-info-circle-fill me-1"></i>
                            <span id="sizeStockText" class="fw-bold"></span>
                        </div>
                        
                        <div id="sizeStockData" style="display:none;">
                            @if (Model.SizeStocks != null)
                            {
                                foreach (var ss in Model.SizeStocks)
                                {
                                    <div class="size-data" data-size="@ss.Size" data-stock="@ss.StockQty"></div>
                                }
                            }
                        </div>
                    </div>
                }
                
                <div class="mb-3">
                    <label class="form-label fw-bold text-dark fs-5">Quantity:</label>
                    <div class="d-flex align-items-center gap-3">
                        <div class="input-group" style="width: 180px; border: 1px solid #ccc; border-radius: 4px; overflow: hidden; background: #f8f6f0; height: 38px;">
                            <button class="btn btn-light px-2 fw-bold border-end" type="button" onclick="changeQty(-1)" style="font-size: 16px; color: #333; padding-bottom: 2px; width: 40px;">-</button>
                            <input type="number" id="quantityInput" name="qty" value="1" min="1"
                                    class="form-control text-center fw-bold border-0 p-0 no-spin" 
                                    style="color: #000 !important; background-color: #f8f6f0 !important; font-size: 1.1rem; width: 100px;"
                                    onchange="validateQty()" oninput="validateQty()" />
                            <button class="btn btn-light px-2 fw-bold border-start" type="button" onclick="changeQty(1)" style="font-size: 16px; color: #333; padding-bottom: 2px; width: 40px;">+</button>
                        </div>
                        <span id="stockLimitMsg" class="text-muted small">
                            (Stock: @Model.Product.StockQty.ToString("#,##0") units | Max: @(Model.Product.MaxOrderQty > 0 ? (Model.Product.MaxOrderQty ?? 0).ToString("#,##0") : "No Limit"))
                        </span>
                    </div>
                    <div id="qtyMessage" class="text-danger small fw-bold mt-2" style="display: none;"></div>
                </div>

                <script>
                    function showMessage(msg) {
                        const msgBox = document.getElementById('qtyMessage');
                        msgBox.innerHTML = msg;
                        msgBox.style.display = 'block';
                        
                        // Clear message after 4 seconds
                        setTimeout(() => {
                            msgBox.style.display = 'none';
                        }, 4000);
                    }

                    function changeQty(amt) {
                        const input = document.getElementById('quantityInput');
                        let val = parseInt(input.value);
                        if(isNaN(val)) val = 0;
                        val += amt;
                        applyValidation(val, input);
                    }

                    function validateQty() {
                        const input = document.getElementById('quantityInput');
                        if (input.value === "") return; // Allow empty while typing
                        let val = parseInt(input.value);
                        if(isNaN(val)) val = 1;
                        applyValidation(val, input);
                    }

                    function applyValidation(val, input) {
                        // Use the selected size's stock if available (from hidden field)
                        let maxStock = parseInt(document.getElementById('selectedSizeStock').value) || 0;
                        let maxOrder = parseInt('@(Model.Product.MaxOrderQty ?? 0)') || 0;
                        
                        // If it's pure zero or lower, restrict to 1 unless there is zero stock
                        if (val < 1) val = 1;

                        if (maxStock <= 0) {
                            val = 0;
                            showMessage("Sorry, this product/size is currently out of stock.");
                        } else if (maxOrder > 0 && maxOrder < maxStock && val > maxOrder) {
                            val = maxOrder;
                            showMessage("Maximum purchase order limit is " + maxOrder + ". If you need more products, please <a href='/Home/Contact' class='text-primary text-decoration-underline fw-bold'>Contact Us</a>.");
                        } else if (val > maxStock) {
                            val = maxStock;
                            showMessage("Requested quantity exceeds available stock of " + maxStock + " units for this selection.");
                        }
                        
                        input.value = val;
                    }

                    document.getElementById('addToCartForm').addEventListener('submit', function(e) {
                        const input = document.getElementById('quantityInput');
                        if (input.value === "" || parseInt(input.value) < 1) {
                            input.value = 1;
                        }

                        @if (sizes != null && sizes.Any())
                        {
                            <text>
                            if (!document.querySelector('input[name="size"]:checked')) {
                                e.preventDefault();
                                showMessage("Please select a size first!");
                                return false;
                            }
                            </text>
                        }
                    });

                    // Add Listener for size select to update stock
                    document.addEventListener('DOMContentLoaded', function() {
                        document.querySelectorAll('.size-select').forEach(radio => {
                            radio.addEventListener('change', function() {
                                const size = this.value;
                                const sizeData = document.querySelector(`.size-data[data-size="${size}"]`);
                                const displayContainer = document.getElementById('sizeStockDisplay');
                                const textDisplay = document.getElementById('sizeStockText');
                                const quantityInput = document.getElementById('quantityInput');
                                const selectedStockInput = document.getElementById('selectedSizeStock');
                                const stockLimitMsg = document.getElementById('stockLimitMsg');
                                
                                if (sizeData) {
                                    const stock = parseInt(sizeData.getAttribute('data-stock')) || 0;
                                    selectedStockInput.value = stock;
                                    
                                    displayContainer.style.display = 'block';
                                    if (stock > 0) {
                                        textDisplay.innerText = "Available Stock for Size " + size + ": " + stock + " units";
                                        textDisplay.className = "fw-bold text-success";
                                        displayContainer.style.borderColor = "#198754";
                                    } else {
                                        textDisplay.innerText = "Size " + size + " is Out of Stock!";
                                        textDisplay.className = "fw-bold text-danger";
                                        displayContainer.style.borderColor = "#dc3545";
                                    }
                                    
                                    stockLimitMsg.innerText = `(Stock for ${size}: ${stock} units | Max: @(Model.Product.MaxOrderQty > 0 ? Model.Product.MaxOrderQty.ToString() : "No Limit"))`;
                                    
                                    // Trigger validation to ensure quantity is capped to new stock
                                    applyValidation(parseInt(quantityInput.value) || 1, quantityInput);
                                }
                            });
                        });
                    });
                </script>
                
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button type="submit" formaction="/Cart/AddToCart" class="btn btn-warning text-white btn-lg px-4 fw-bold">Add to Cart</button>
                    <button type="submit" formaction="/Cart/BuyNow" class="btn btn-danger btn-lg px-4 fw-bold">Buy Now</button>
                    <a href="/Home/CategoryProducts?typeId=@Model.Product.ProductTypeId" class="btn btn-outline-secondary btn-lg px-4">View More @Model.Product.ProductType?.Name</a>
                </div>
            </form>
        </div>
    </div>
    
    <hr class="mt-5 mb-5" />

    <!-- Ratings Summary and Review List -->
    <div class="row">
        <div class="col-md-4">
            <h4>Ratings & Reviews</h4>
            <div class="text-center p-4 bg-light rounded">
                <h1 class="display-3 fw-bold text-dark">@Model.Product.AverageRating.ToString("0.0")</h1>
                <div class="text-warning fs-3">@Html.Raw(RenderStars(Model.Product.AverageRating))</div>
                <div class="text-muted">Based on @Model.TotalReviews reviews</div>
            </div>
            
            <div class="mt-4">
                @for (int i = 5; i >= 1; i--)
                {
                    int count = Model.RatingSummary.ContainsKey(i) ? Model.RatingSummary[i] : 0;
                    double percent = Model.TotalReviews > 0 ? (double)count / Model.TotalReviews * 100 : 0;
                    <div class="d-flex align-items-center mb-1">
                        <span class="me-2" style="width: 20px;">@i</span>
                        <div class="flex-grow-1 rating-bar">
                            <div class="rating-fill" style="width: @percent%;"></div>
                        </div>
                        <span class="ms-2 text-muted" style="width: 30px;">@count</span>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-8 ps-md-5">
            <h4 class="mb-4">Customer Experience</h4>
            
            <!-- Submit Review Section -->
            <div class="card mb-4 border-primary">
                <div class="card-body">
                    <h5>Give a Review</h5>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        if (User.IsInRole("Customer"))
                        {
                            <form asp-action="SubmitReview" method="post" enctype="multipart/form-data">
                                <input type="hidden" name="productId" value="@Model.Product.Id" />
                                <div class="row">
                                    <div class="col-md-3 mb-3">
                                        <label class="form-label fw-bold" style="color: #532374;">Select Stars</label>
                                        <select name="rating" class="form-select border-primary" required>
                                            <option value="5">★★★★★ (5 Stars)</option>
                                            <option value="4">★★★★☆ (4 Stars)</option>
                                            <option value="3">★★★☆☆ (3 Stars)</option>
                                            <option value="2">★★☆☆☆ (2 Stars)</option>
                                            <option value="1">★☆☆☆☆ (1 Star)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-8 mb-3">
                                        <label class="form-label fw-bold" style="color: #532374;">Comments</label>
                                        <textarea name="comment" class="form-control border-primary" rows="2" placeholder="Write your experience..." required></textarea>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold" style="color: #532374;">Add Photos (Optional)</label>
                                    <input type="file" name="images" class="form-control" accept="image/*" multiple onchange="previewImages(this)" />
                                    <small class="text-muted">You can upload up to 5 images</small>
                                    <div id="imagePreview" class="mt-2 d-flex gap-2 flex-wrap"></div>
                                </div>
                                <button type="submit" class="btn btn-primary px-4 fw-bold">Submit Review</button>
                            </form>
                        }
                        else
                        {
                            <p class="text-muted mb-0">Only customers can leave reviews.</p>
                        }
                    }
                    else
                    {
                        <p class="mb-2">Please login to share your feedback.</p>
                        <a asp-controller="Account" asp-action="Login" class="theme-back-btn" style="padding: 5px 20px !important; display: inline-block;">Login Now</a>
                    }
                </div>
            </div>

            <!-- Review List -->
            <div class="review-list">
                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    foreach (var review in Model.Reviews)
                    {
                        <div class="border-bottom mb-4 pb-3">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <span class="text-warning">@Html.Raw(RenderStars(review.Rating))</span>
                                    <span class="ms-2 fw-bold" style="color: #FF6B35;">@review.CustomerName</span>
                                    <span class="badge bg-light text-success ms-2 small" style="font-size: 0.7rem;">Verified Purchase</span>
                                </div>
                                <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy | hh:mm tt")</small>
                            </div>
                            
                            <p class="mt-2 mb-2 text-dark">@review.Comment</p>

                            @if (!string.IsNullOrEmpty(review.ImageUrls))
                            {
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    @foreach (var url in review.ImageUrls.Split(','))
                                    {
                                        <img src="@url" class="rounded review-image" style="width: 100px; height: 100px; object-fit: cover; cursor: pointer;" onclick="window.open('@url', '_blank')" />
                                    }
                                </div>
                            }

                            <!-- Reactions -->
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <button class="btn btn-sm btn-success text-white fw-bold" onclick="reactToReview(@review.Id, 'Like')">
                                    <i class="bi bi-hand-thumbs-up"></i> <span id="like-count-@review.Id">@review.LikeCount</span>
                                </button>
                                <button class="btn btn-sm @(review.IsDislikedByCurrentUser ? "btn-danger" : "btn-outline-danger")" onclick="reactToReview(@review.Id, 'Dislike')">
                                    <i class="bi bi-hand-thumbs-down"></i> <span id="dislike-count-@review.Id">@review.DislikeCount</span>
                                </button>
                                @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Employee")))
                                {
                                    <button class="btn btn-link btn-sm text-decoration-none" onclick="toggleReplyBox(@review.Id)">Reply</button>
                                }
                            </div>

                            <!-- Replies -->
                            @if (review.Replies != null && review.Replies.Any())
                            {
                                <div class="ms-5 mt-3 border-start ps-3 py-1 bg-light rounded">
                                    @foreach (var reply in review.Replies)
                                    {
                                        <div class="mb-2">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="fw-bold small @(reply.IsSeller ? "text-danger" : "text-primary")">
                                                    @(reply.IsSeller ? "Seller Response" : reply.ReplierName)
                                                </span>
                                                <small class="text-muted" style="font-size: 0.7rem;">@reply.CreatedAt.ToString("MMM dd, HH:mm")</small>
                                            </div>
                                            <p class="small mb-0">@reply.ReplyText</p>
                                        </div>
                                    }
                                </div>
                            }

                            <!-- Reply Box -->
                            <div id="reply-box-@review.Id" class="ms-5 mt-2" style="display: none;">
                                <div class="card p-2 border-primary shadow-sm">
                                    <div class="d-flex gap-2 mb-2 p-1 bg-light rounded">
                                        <button type="button" class="btn btn-sm btn-outline-secondary border-0" onclick="insertTool(@review.Id, 'gallery')" title="Add from Gallery"><i class="bi bi-images"></i></button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary border-0" onclick="insertTool(@review.Id, 'attach')" title="Attach File"><i class="bi bi-paperclip"></i></button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary border-0" onclick="insertTool(@review.Id, 'emoji')" title="Insert Emoji"><i class="bi bi-emoji-smile"></i></button>
                                    </div>
                                    <textarea id="reply-text-@review.Id" class="form-control mb-2" rows="2" placeholder="Write your reply..."></textarea>
                                    <div class="d-flex justify-content-end gap-2">
                                        <button type="button" class="btn btn-sm btn-secondary" onclick="toggleReplyBox(@review.Id)">Cancel</button>
                                        <button type="button" class="btn btn-sm btn-primary" onclick="submitReply(@review.Id)">Post Reply</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No reviews yet. Be the first to review this product!</p>
                }
            </div>
        </div>
    </div>

    <!-- Related Products Section -->
    <div class="mt-5 mb-5">
        <h4 class="mb-4">Related Products</h4>
        <div class="row">
            @if (Model.RelatedProducts != null && Model.RelatedProducts.Any())
            {
                foreach (var product in Model.RelatedProducts)
                {
                    <div class="col-md-2 col-6 mb-4">
                        <div class="card h-100 border-0 text-center">
                            <a asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                                <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/no-image.png" : (product.ImageUrl.StartsWith("/") ? product.ImageUrl : "/images/products/" + product.ImageUrl))" 
                                     class="card-img-top rounded" style="height: 150px; object-fit: cover;" />
                                <div class="card-body p-2">
                                    <h6 class="text-dark text-truncate mb-1">@product.Name</h6>
                                    <div class="text-danger fw-bold">৳ @product.Price.ToString("#,##0")</div>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted col-12">No related products found.</p>
            }
        </div>
    </div>
</div>


<!-- Chat Box -->
<div id="chatBox" class="chat-box">
    <div class="chat-header">
        <div>
            <h6 class="mb-0">Live Chat Support</h6>
            <small>We're here to help!</small>
        </div>
        <button onclick="toggleChat()" class="btn btn-sm text-white" style="font-size: 20px; padding: 0; border: none; background: transparent;">×</button>
    </div>
    <div class="chat-body" id="chatMessages" style="color: #333 !important;">
        <div class="chat-message support">
            <strong style="color: #532374;">Support Team</strong>
            <p class="mb-0 small" style="color: #444 !important;">Hello! How can we help you today?</p>
        </div>
    </div>
    <div class="chat-footer">
        <input type="text" id="chatInput" class="form-control" style="color: #000 !important; font-weight: 500;" placeholder="Type your message..." onkeypress="if(event.key==='Enter') sendMessage()">
        <button onclick="sendMessage()" class="btn btn-success"><i class="bi bi-send-fill"></i></button>
    </div>
</div>

<script>
    function toggleChat() {
        const chatBox = document.getElementById('chatBox');
        chatBox.classList.toggle('active');
    }

    function sendMessage() {
        const input = document.getElementById('chatInput');
        const message = input.value.trim();
        if (!message) return;

        const chatMessages = document.getElementById('chatMessages');
        const userMsg = document.createElement('div');
        userMsg.className = 'chat-message user';
        userMsg.innerHTML = `<strong style="color: #198754;">You</strong><p class="mb-0 small" style="color: #222 !important;">${message}</p>`;
        chatMessages.appendChild(userMsg);
        
        input.value = '';
        chatMessages.scrollTop = chatMessages.scrollHeight;
 
        // Actual post to server
        $.post('/Home/SendLiveChatMessage', { message: message });

        // Auto-reply after 1 second
        setTimeout(() => {
            const supportMsg = document.createElement('div');
            supportMsg.className = 'chat-message support';
            supportMsg.innerHTML = `<strong style="color: #532374;">Support Team</strong><p class="mb-0 small" style="color: #444 !important;">Thank you for your message. An agent will respond shortly. For immediate assistance, please call us or visit our <a href="/Home/Contact" style="color: #532374; font-weight: 600;">Contact Page</a>.</p>`;
            chatMessages.appendChild(supportMsg);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }, 1000);
    }

    function reactToReview(reviewId, reactionType) {
        @if (!(User.Identity?.IsAuthenticated ?? false))
        {
            <text>window.location.href = '/Account/Login'; return;</text>
        }
        
        $.post('/Review/React', { reviewId: reviewId, reactionType: reactionType }, function(data) {
            if (data.success) {
                location.reload(); 
            }
        });
    }

    function toggleReplyBox(reviewId) {
        const box = document.getElementById(`reply-box-${reviewId}`);
        box.style.display = box.style.display === 'none' ? 'block' : 'none';
    }

    function submitReply(reviewId) {
        const textArea = document.getElementById(`reply-text-${reviewId}`);
        const text = textArea.value;
        if (!text.trim()) return;

        $.post('/Review/Reply', { reviewId: reviewId, replyText: text }, function(data) {
            if (data.success) {
                location.reload();
            }
        });
    }

    function insertTool(reviewId, type) {
        const area = document.getElementById(`reply-text-${reviewId}`);
        let content = "";
        if(type === 'emoji') content = "😊";
        if(type === 'attach') content = "[Attachment]";
        if(type === 'gallery') content = "[Image]";
        
        const start = area.selectionStart;
        const end = area.selectionEnd;
        area.value = area.value.substring(0, start) + content + area.value.substring(end);
        area.focus();
    }

    document.querySelectorAll('.size-select').forEach(radio => {
        radio.addEventListener('change', function() {
            const size = this.value;
            const sizeStockData = document.querySelector(`.size-data[data-size="${size}"]`);
            const display = document.getElementById('sizeStockDisplay');
            const qtyInput = document.getElementById('quantityInput');
            const limitMsg = document.getElementById('stockLimitMsg');
            
            if (sizeStockData) {
                const stock = parseInt(sizeStockData.getAttribute('data-stock'));
                display.innerText = stock > 0 ? `${stock} units currently in stock` : 'Out of Stock';
                display.style.color = stock > 0 ? '#198754' : '#dc3545';
                
                qtyInput.setAttribute('max', stock);
                limitMsg.innerText = `(Stock: ${stock} units | Max: @(Model.Product.MaxOrderQty > 0 ? Model.Product.MaxOrderQty.ToString() : "No Limit"))`;
                
                if (parseInt(qtyInput.value) > stock) {
                    qtyInput.value = stock > 0 ? 1 : 0;
                }
            } else {
                display.innerText = 'Stock information not available';
                display.style.color = '#6c757d';
            }
            checkStock(qtyInput);
        });
    });

    let selectedFiles = [];

    function previewImages(input) {
        const preview = document.getElementById('imagePreview');
        const dt = new DataTransfer();
        
        if (input.files) {
            selectedFiles = Array.from(input.files).slice(0, 5);
            renderPreviews();
        }
    }

    function renderPreviews() {
        const preview = document.getElementById('imagePreview');
        const input = document.querySelector('input[name="images"]');
        preview.innerHTML = '';
        
        const dt = new DataTransfer();
        selectedFiles.forEach((file, index) => {
            dt.items.add(file);
            const reader = new FileReader();
            reader.onload = function(e) {
                const container = document.createElement('div');
                container.className = 'position-relative';
                container.style.width = '80px';
                container.style.height = '80px';

                const img = document.createElement('img');
                img.src = e.target.result;
                img.style.width = '100%';
                img.style.height = '100%';
                img.style.objectFit = 'cover';
                img.style.borderRadius = '8px';
                img.style.border = '2px solid #ddd';
                
                const delBtn = document.createElement('button');
                delBtn.innerHTML = '×';
                delBtn.className = 'btn btn-danger btn-sm position-absolute top-0 end-0 p-0';
                delBtn.style.width = '20px';
                delBtn.style.height = '20px';
                delBtn.style.fontSize = '14px';
                delBtn.style.lineHeight = '1';
                delBtn.onclick = (e) => {
                    e.preventDefault();
                    selectedFiles.splice(index, 1);
                    renderPreviews();
                };

                container.appendChild(img);
                container.appendChild(delBtn);
                preview.appendChild(container);
            };
            reader.readAsDataURL(file);
        });
        input.files = dt.files;
    }
</script>

