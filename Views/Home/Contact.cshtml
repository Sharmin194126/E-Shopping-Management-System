@{
    ViewData["Title"] = "Contact Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .image-preview-container {
        margin-top: 10px;
    }
    #imagePreview {
        display: none;
        max-width: 150px;
        max-height: 150px;
        object-fit: cover;
        border-radius: 10px;
        border: 2px solid #532374;
    }
</style>

<div class="container mt-5 mb-5">
<div class="d-flex justify-content-end align-items-center mb-3">
    <a asp-action="Index" class="theme-back-btn mb-0">Back</a>
</div>
    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card h-100 border-0 shadow-lg" style="border-radius: 20px; background: linear-gradient(135deg, #532374, #8b1a6b) !important;">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-4" style="color: #FFD700;">Get in Touch</h2>
                    <p class="lead mb-5" style="color:rgba(255,255,255,0.9);">We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>
                    
                    <div class="mb-4 d-flex align-items-start">
                        <div class="me-3 fs-4" style="color: #FFD700;"><i class="bi bi-geo-alt"></i></div>
                        <div>
                            <h5 class="mb-1" style="color: #ffffff; font-weight: 700;">Address</h5>
                            <p style="color: rgba(255,255,255,0.8);">123 E-Shop Street, Dhaka, Bangladesh</p>
                        </div>
                    </div>
                    
                    <div class="mb-4 d-flex align-items-start">
                        <div class="me-3 fs-4" style="color: #FFD700;"><i class="bi bi-telephone"></i></div>
                        <div>
                            <h5 class="mb-1" style="color: #ffffff; font-weight: 700;">Phone</h5>
                            <p style="color: rgba(255,255,255,0.8);">+880 1234-567890</p>
                        </div>
                    </div>
                    
                    <div class="mb-4 d-flex align-items-start">
                        <div class="me-3 fs-4" style="color: #FFD700;"><i class="bi bi-envelope"></i></div>
                        <div>
                            <h5 class="mb-1" style="color: #ffffff; font-weight: 700;">Email</h5>
                            <p style="color: rgba(255,255,255,0.8);">E-Shop@gmail.com</p>
                        </div>
                    </div>

                    <div class="mb-4 d-flex align-items-start">
                        <div class="me-3 fs-4" style="color: #FFD700;"><i class="bi bi-envelope-check"></i></div>
                        <div>
                            <h5 class="mb-1" style="color: #ffffff; font-weight: 700;">Support</h5>
                            <p class="mt-2">
                                <a asp-action="Email" class="btn btn-sm px-4 fw-bold" style="background: #FFD700; color: #532374; border-radius: 50rem;">Send Direct Email</a>
                            </p>
                        </div>
                    </div>
                    
                    <div class="mt-5 pt-3">
                        <a href="#" class="btn border-0 rounded-circle me-3 fs-4" style="color: #ffffff; background: transparent;"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn border-0 rounded-circle me-3 fs-4" style="color: #ffffff; background: transparent;"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="btn border-0 rounded-circle fs-4" style="color: #ffffff; background: transparent;"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-7">
            <div class="card h-100 border-0 shadow" style="border-radius: 20px; background-color: #ffffff !important;">
                <div class="card-body p-5">
                    <h3 class="mb-4 fw-bold" style="color: #532374;">Send us a Message</h3>
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success border-0 shadow-sm rounded-3">@TempData["Message"]</div>
                    }
                    <form asp-action="SendMessage" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="messageType" value="General" />
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold" style="color: #000 !important;">Name</label>
                                <input type="text" name="name" class="form-control rounded-3" placeholder="John Doe" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold" style="color: #000 !important;">Email Address</label>
                                <input type="email" name="email" class="form-control rounded-3" placeholder="john@example.com" required />
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold" style="color: #000 !important;">Subject</label>
                            <input type="text" name="subject" class="form-control rounded-3" placeholder="How can we help?" required />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold" style="color: #000 !important;">Message</label>
                            <textarea name="message" class="form-control rounded-3" rows="5" placeholder="Write your message here..." required></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold" style="color: #000 !important;">Attachment</label>
                            <input type="file" name="attachment" id="attachmentInput" class="form-control rounded-3" onchange="previewImage(event)" />
                            <small class="text-muted">Upload an image or screenshot for reference.</small>
                            <div class="image-preview-container">
                                <img id="imagePreview" src="#" alt="Preview" />
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary px-5 py-3 fw-bold rounded-pill" style="background: #532374; border: none;">
                            Send Message <i class="bi bi-send ms-2"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(event) {
            const input = event.target;
            const preview = document.getElementById('imagePreview');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                }
                
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.style.display = 'none';
            }
        }
    </script>
}
