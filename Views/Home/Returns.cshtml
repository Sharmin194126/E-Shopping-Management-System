@{
    ViewData["Title"] = "Returns & Refunds";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="fw-bold mb-4 text-center">Returns & Refunds Policy</h1>
            <div class="card border-0 shadow-sm p-5">
                <section class="mb-5">
                    <h4 class="fw-bold border-bottom pb-2">1. Return Eligibility</h4>
                    <p>We want you to be completely satisfied with your purchase. You can return most items within 7 days of delivery if they are:</p>
                    <ul>
                        <li>In original packaging with all tags attached.</li>
                        <li>Unused, unwashed, and in original condition.</li>
                        <li>Accompanied by the original invoice or receipt.</li>
                    </ul>
                </section>

                <section class="mb-5">
                    <h4 class="fw-bold border-bottom pb-2">2. Items Not Eligible for Return</h4>
                    <p>For health and safety reasons, some items cannot be returned, including:</p>
                    <ul>
                        <li>Personal care items (skin care, makeup, etc.).</li>
                        <li>Undergarments and swimwear.</li>
                        <li>Perishable goods.</li>
                        <li>Customized or personalized products.</li>
                    </ul>
                </section>

                <section class="mb-5">
                    <h4 class="fw-bold border-bottom pb-2">3. Refund Process</h4>
                    <p>Once we receive and inspect your return, we will process your refund. Total processing time is typically 5-10 business days.</p>
                    <p>Refunds will be issued to your original payment method (Online Payment, Bkash, etc.) or as store credit, depending on your preference.</p>
                </section>

                <div class="bg-light p-3 rounded text-center mt-4">
                    <p class="mb-2">Need to start a return?</p>
                    <a href="/Home/Contact" class="btn btn-primary px-4 fw-bold">Contact Support Team</a>
                </div>
            </div>
        </div>
    </div>
</div>
