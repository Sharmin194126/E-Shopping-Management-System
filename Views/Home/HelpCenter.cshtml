@{
    ViewData["Title"] = "Help Center";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">How can we help you today?</h1>
        <p class="lead text-muted">Find answers to common questions and learn how to make the most of your shopping experience.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="fs-1 text-primary mb-3"><i class="bi bi-box-seam"></i></div>
                <h5 class="fw-bold">Orders & Shipping</h5>
                <ul class="list-unstyled mt-3">
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark">Track your order</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark">Shipping costs & methods</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark">International shipping</a></li>
                </ul>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="fs-1 text-success mb-3"><i class="bi bi-wallet2"></i></div>
                <h5 class="fw-bold">Payment & Pricing</h5>
                <ul class="list-unstyled mt-3">
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark">Payment methods</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark">Coupons & discounts</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark">Price matching</a></li>
                </ul>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="fs-1 text-danger mb-3"><i class="bi bi-arrow-counterclockwise"></i></div>
                <h5 class="fw-bold">Returns & Refunds</h5>
                <ul class="list-unstyled mt-3">
                    <li class="mb-2"><a href="/Home/Returns" class="text-decoration-none text-dark">Return policy</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark">Refund process</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark">Exchanges</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="mt-5 p-5 bg-light rounded shadow-sm">
        <h3 class="fw-bold mb-4">Frequently Asked Questions</h3>
        <div class="accordion" id="faqAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                        How do I track my order?
                    </button>
                </h2>
                <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        You can track your order by clicking on the "Track Your Order" link in the footer or by visiting your dashboard if you are a registered customer.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                        Can I cancel my order?
                    </button>
                </h2>
                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        Orders can be cancelled before they are shipped. Please contact our support team immediately if you wish to cancel.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
