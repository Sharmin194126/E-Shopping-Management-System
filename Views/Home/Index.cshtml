@model E_ShoppingManagement.ViewModels.HomeIndexViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isLoggedIn = User.Identity?.IsAuthenticated ?? false;

    var banners = Model.Banners;

    // Distribute products based on DisplayCategory
    var allProducts = Model.Products.ToList();

    var validSections = new List<E_ShoppingManagement.Models.DisplaySection>();
    var validSectionProducts = new Dictionary<string, List<E_ShoppingManagement.Models.Product>>();

    E_ShoppingManagement.Models.DisplaySection categorySection = null;

    foreach (var dispSection in Model.DisplaySections)
    {
        if (dispSection.Name.Contains("Categories", StringComparison.OrdinalIgnoreCase) || dispSection.Name.Contains("Category", StringComparison.OrdinalIgnoreCase))
        {
            categorySection = dispSection;
            continue;
        }

        var sectionProducts = allProducts.Where(p => p.DisplayCategory == dispSection.Name || (dispSection.Name == "Featured Items" && p.DisplayCategory == "Featured")).ToList();
        if (sectionProducts.Any())
        {
            validSections.Add(dispSection);
            validSectionProducts[dispSection.Name] = sectionProducts;
        }
    }

    var allSectionsToRender = new List<E_ShoppingManagement.Models.DisplaySection>();
    if (categorySection != null && Model.Categories != null && Model.Categories.Any())
    {
        allSectionsToRender.Add(categorySection);
    }
    allSectionsToRender.AddRange(validSections);
    allSectionsToRender = allSectionsToRender.OrderBy(s => s.DisplayOrder).ToList();

    // Helper to render stars
    string RenderStars(double rating) {
        int fullStars = (int)rating;
        string stars = "";
        for(int i=0; i<fullStars; i++) stars += "★";
        for(int i=fullStars; i<5; i++) stars += "☆";
        return stars;
    }
}

<style>
    .product-actions {
        display: flex;
        gap: 5px;
        margin-top: 10px;
        justify-content: center;
    }
    .btn-action {
        padding: 5px 10px;
        font-size: 12px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        transition: 0.3s;
        text-decoration: none;
        display: inline-block;
    }
    .btn-cart {
        background-color: #ff9900;
        color: white;
    }
    .btn-cart:hover {
        background-color: #e68a00;
    }
    .btn-buy {
        background-color: #ff4d4d;
        color: white;
    }
    .btn-buy:hover {
        background-color: #cc0000;
    }
    .product-card {
        padding-bottom: 15px; 
        text-align: center;
    }
    .product-card img {
        width: 100%;
        height: 220px;
        object-fit: contain;
        background: #fff;
        border-radius: 8px;
        padding: 5px;
    }
    .price-old {
        text-decoration: line-through;
        color: #888;
        font-size: 14px;
        margin-right: 5px;
    }
    .price-new {
        color: #d9534f;
        font-weight: bold;
        font-size: 18px;
    }
    .review-user-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 5px;
    }
    .payment-method-img {
        height: 30px;
        margin-right: 10px;
    }
</style>

<div class="page-wrapper">

    <!-- SIDE NAV (fixed) -->
    <div class="side-nav">
        @foreach (var dispSection in allSectionsToRender)
        {
            var sectionId = dispSection.Name.Replace(" ", "").ToLower();
            <a href="#@sectionId">
                @if (dispSection.Name.Contains("Categor", StringComparison.OrdinalIgnoreCase)) { <text>🗂️</text> }
                else if (dispSection.Name.Contains("Featured")) { <text>⭐</text> }
                else if (dispSection.Name.Contains("Exclusive")) { <text>💎</text> }
                else if (dispSection.Name.Contains("Offer")) { <text>🔥</text> }
                else if (dispSection.Name.Contains("You")) { <text>❤️</text> }
                else if (dispSection.Name.Contains("Restock")) { <text>🔁</text> }
                else { <text>📦</text> }
                <span>@dispSection.Name</span>
            </a>
        }
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <!-- ===== BANNER ===== -->
        <div class="banner" style="position: relative;">
            <button class="banner-btn left" onclick="prevBanner()" style="z-index: 5;">‹</button>
            <button class="banner-btn right" onclick="nextBanner()" style="z-index: 5;">›</button>

            @if (banners != null && banners.Any())
            {
                for (int i = 0; i < banners.Count; i++)
                {
                    <img src="@banners[i]" class="@(i == 0 ? "active" : "")" style="filter: brightness(0.85);">
                }
            }
            else
            {
                <img src="~/images/banners/banner1.jpg" class="active" style="filter: brightness(0.85);">
            }

            <!-- WELCOME TEXT OVERLAY -->
            <div class="welcome-overlay" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: white; width: 100%; z-index: 2;">
                <h2 style="font-family: 'Playfair Display', serif; font-size: 58px; font-weight: 500; margin-bottom: 15px; color: #fff; text-shadow: 0 4px 12px rgba(0,0,0,0.3);">Discover Your Style</h2>
                <p style="font-size: 16px; font-weight: 500; letter-spacing: 0.5px; opacity: 0.95; color: #fff; text-shadow: 0 2px 8px rgba(0,0,0,0.3); margin-bottom: 25px;">Your ultimate destination for fashion, beauty and pure luxury.</p>
                <a href="#featureditems" class="btn" style="background: #f8f6f0; color: #33312e; padding: 12px 35px; border-radius: 30px; font-weight: 600; font-size: 14px; text-decoration: none;">Shop Now</a>
            </div>
        </div>

        <div class="welcome" style="margin-top: 50px;">
            <h2 style="font-family: 'Playfair Display', serif; text-align: center; color: #532374; margin-bottom: 40px; font-weight: 700;">Welcome To E-Shop</h2>
            <p style="text-align: center; color: #55534e; font-size: 16px; font-family: 'Inter', sans-serif;">Your trusted online shopping destination for fashion, beauty and electronics. Enjoy premium products, exclusive deals and fast delivery.</p>
        </div>

        @foreach (var dispSection in allSectionsToRender)
        {
            var sectionId = dispSection.Name.Replace(" ", "").ToLower();
            
            if (dispSection.Name.Contains("Category", StringComparison.OrdinalIgnoreCase) || dispSection.Name.Contains("Categories", StringComparison.OrdinalIgnoreCase))
            {
                <section class="section" id="@sectionId" style="margin-bottom: 40px; margin-top: 30px;">
                    <h2 style="text-align: center; margin-bottom: 20px; font-size: 32px;">@dispSection.Name</h2>
                    
                    <div style="display: flex; gap: 20px; overflow-x: auto; padding: 10px 15px; justify-content: center; flex-wrap: wrap;">
                        @foreach (var cat in Model.Categories)
                        {
                            <div style="width: 140px; text-align: center; position: relative; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.15); transition: transform 0.2s ease;">
                                <a href="/Home/CategoryProducts?categoryId=@cat.Id" style="display: block; position: relative;" onmouseover="this.parentElement.style.transform='translateY(-5px)'" onmouseout="this.parentElement.style.transform='translateY(0)'">
                                    <img src="@(string.IsNullOrEmpty(cat.ImageUrl) ? "/images/no-image.png" : (cat.ImageUrl.StartsWith("/") ? cat.ImageUrl : "/images/categories/" + cat.ImageUrl))" alt="@cat.Name" style="width: 140px; height: 140px; object-fit: cover; filter: brightness(0.6); display: block; border-radius: 12px;" />
                                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #fff; font-weight: 700; font-size: 16px; text-shadow: 0px 2px 6px rgba(0,0,0,0.8); z-index: 2; width: 90%; text-align: center; letter-spacing: 0.5px; text-transform: uppercase;">
                                        @cat.Name
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </section>
            }
            else
            {
                var sectionProducts = validSectionProducts[dispSection.Name];
                
                <section class="section" id="@sectionId" style="margin-bottom: 30px;">
                    <h2 style="text-align: center; margin-bottom: 15px; font-size: 32px;">@dispSection.Name</h2>
                    
                    <div class="@(dispSection.Name.Contains("Featured") ? "featured-grid" : "product-grid")">
                        @foreach (var item in sectionProducts)
                        {
                            <div class="product-card">
                                <a href="/Home/Details/@item.Id" style="position: relative; display: block;">
                                    @if (item.OfferPercentage > 0)
                                    {
                                        <div style="position: absolute; top: 12px; left: 12px; font-size: 11px; background: #3c3935; color: white; padding: 3px 8px; border-radius: 4px; font-weight: 600;">-@item.OfferPercentage% OFF</div>
                                    }
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : (item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/images/products/" + item.ImageUrl))" alt="@item.Name">
                                </a>
                                <div class="card-bottom-row">
                                    <div class="card-text-col">
                                        <div class="desc">
                                            <a href="/Home/Details/@item.Id" style="text-decoration:none;">
                                                <h6>@item.Name</h6>
                                            </a>
                                        </div>
                                        <div class="rating" style="font-size: 11px; margin-bottom: 3px; color: #bca05b;">
                                            @Html.Raw(RenderStars(item.AverageRating)) <span style="color:#8b7d6b">(@item.AverageRating)</span>
                                        </div>
                                        <div class="price-new">
                                            @if (item.RegularPrice > item.Price) {
                                                <span class="price-old" style="font-size: 12px; font-weight: 500; color: #8b7d6b; margin-right: 4px; text-decoration: line-through;">৳@item.RegularPrice.ToString("#,##0")</span>
                                            }
                                            ৳@item.Price.ToString("#,##0")
                                        </div>
                                    </div>
                                    <form asp-controller="Cart" asp-action="AddToCart" method="get" class="m-0 p-0">
                                        <input type="hidden" name="productId" value="@item.Id" />
                                        <input type="hidden" name="qty" value="1" />
                                        <button type="submit" class="border-0 add-btn-pill">Add to Cart</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        }

        <!-- Rest of content will be followed by layout footer -->
    </div>
</div>

    </div>
</div>

    </div>
</div>

@*  FOR BANNER PAGE *@
<script>
    let currentBanner = 0;
    let banners = [];
    let bannerInterval = null;

    function showBanner(index) {
        banners.forEach((img, i) => {
            img.classList.remove("active");
            if (i === index) img.classList.add("active");
        });
    }

    function nextBanner(manual = false) {
        currentBanner = (currentBanner + 1) % banners.length;
        showBanner(currentBanner);

        if (manual) restartAutoSlide();
    }

    function prevBanner() {
        currentBanner = (currentBanner - 1 + banners.length) % banners.length;
        showBanner(currentBanner);
        restartAutoSlide();
    }

    function startAutoSlide() {
        bannerInterval = setInterval(() => {
            nextBanner(false);
        }, 3000);
    }

    function restartAutoSlide() {
        clearInterval(bannerInterval);
        startAutoSlide();
    }

    document.addEventListener("DOMContentLoaded", function () {
        banners = document.querySelectorAll(".banner img");

        currentBanner = 0;
        showBanner(currentBanner);

        setTimeout(() => {
            nextBanner(false);
            startAutoSlide();
        }, 3000);
    });
</script>




