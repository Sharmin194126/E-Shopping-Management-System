@{
    ViewData["Title"] = "Track Your Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="text-center mb-5">
                <div class="fs-1 text-primary mb-2"><i class="bi bi-geo-alt"></i></div>
                <h1 class="fw-bold">Track Your Order</h1>
                <p class="text-muted">Enter your order ID and phone number to see current status.</p>
            </div>

            <div class="card border-0 shadow-sm p-4">
                <form action="#" method="get">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Order ID</label>
                        <input type="text" class="form-control py-3" placeholder="e.g. #123456" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Registerd Phone Number</label>
                        <input type="tel" class="form-control py-3" placeholder="01XXXXXXXXX" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold fs-5">Track My Package</button>
                </form>
            </div>

            <div class="mt-4 text-center">
                <p class="small text-muted">Usually takes 2-5 business days for delivery after shipment. <br />
                Need help? <a href="/Home/Contact" class="text-primary text-decoration-none fw-bold">Contact Support</a></p>
            </div>
        </div>
    </div>
</div>
