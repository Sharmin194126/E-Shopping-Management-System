@model E_ShoppingManagement.ViewModels.ProductTypeViewModel

@{
    ViewData["Title"] = "Edit Product Type";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-3">Edit Product Type</h2>

<div class="page-card">

    @if (ViewBag.Message != null)
    {
        <div class="alert @(ViewBag.IsSuccess == true ? "alert-success" : "alert-danger")">
            @ViewBag.Message
        </div>
    }

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="Name" class="control-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description" class="control-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Status" class="control-label"></label>
            <select asp-for="Status" class="form-control">
                <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>

        <div class="form-group mb-4">
            <div class="custom-chk-container">
                <input asp-for="IsApproved" type="checkbox" id="chkApproved" class="custom-chk-input" />
                <label for="chkApproved" class="custom-chk-label">
                    <span class="custom-chk-box">
                        <i class="bi bi-check-lg"></i>
                    </span>
                    <span class="ms-2 fw-bold" style="color: #532374;">Is Approved</span>
                </label>
            </div>
        </div>

        <style>
            .custom-chk-container {
                display: flex;
                align-items: center;
                cursor: pointer;
            }
            .custom-chk-input {
                display: none;
            }
            .custom-chk-box {
                width: 28px;
                height: 28px;
                border: 2px solid #532374;
                border-radius: 6px;
                display: flex;
                align-items: center;
                justify-content: center;
                background-color: #fff;
                transition: all 0.2s ease;
                color: transparent;
                font-size: 1.2rem;
            }
            .custom-chk-input:checked + .custom-chk-label .custom-chk-box {
                background-color: #532374;
                color: white;
            }
            .custom-chk-label {
                display: flex;
                align-items: center;
                cursor: pointer;
                user-select: none;
            }
        </style>

        <div class="mt-3 d-flex justify-content-between">
            <a asp-action="Index" class="theme-back-btn">Back to List</a>
            <button type="submit" class="btn btn-success">Update</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
