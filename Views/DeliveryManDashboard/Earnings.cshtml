@model IEnumerable<E_ShoppingManagement.Models.DeliveryManPayment>
@{
    ViewData["Title"] = "My Earnings";
    ViewData["ActivePage"] = "Earnings";
    Layout = "~/Views/Shared/_DeliveryManLayout.cshtml";
    var dm = ViewBag.DeliveryMan as E_ShoppingManagement.Models.DeliveryMan;

    var nowLocal = DateTime.UtcNow.ToLocalTime();
    var today = Model.Where(p => p.CreatedAt.ToLocalTime().Date == nowLocal.Date).Sum(p => p.CommissionAmount);
    var weekly = Model.Where(p => p.CreatedAt.ToLocalTime() >= nowLocal.AddDays(-7)).Sum(p => p.CommissionAmount);
    var monthly = Model.Where(p => p.CreatedAt.ToLocalTime() >= nowLocal.AddDays(-30)).Sum(p => p.CommissionAmount);
    var total = dm?.TotalEarnings ?? 0;
    var pending = dm?.PendingAmount ?? 0;
    var paid = dm?.PaidAmount ?? 0;
}

<!-- Earnings Summary Cards -->

<a href="javascript:history.back()" class="theme-back-btn mb-1">Back</a>
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="dm-stat-card dm-card-teal">
            <div class="dm-card-content">
                <div class="dm-card-label">Today's Earnings</div>
                <div class="dm-card-value">৳@today.ToString("0.##")</div>
            </div>
            <div class="dm-card-icon"><i class="bi bi-sun-fill"></i></div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="dm-stat-card dm-card-blue">
            <div class="dm-card-content">
                <div class="dm-card-label">Weekly Earnings</div>
                <div class="dm-card-value">৳@weekly.ToString("0.##")</div>
            </div>
            <div class="dm-card-icon"><i class="bi bi-calendar-week-fill"></i></div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="dm-stat-card dm-card-orange">
            <div class="dm-card-content">
                <div class="dm-card-label">Monthly Earnings</div>
                <div class="dm-card-value">৳@monthly.ToString("0.##")</div>
            </div>
            <div class="dm-card-icon"><i class="bi bi-calendar-month-fill"></i></div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="dm-stat-card dm-card-purple">
            <div class="dm-card-content">
                <div class="dm-card-label">Total Earnings</div>
                <div class="dm-card-value">৳@total.ToString("0.##")</div>
            </div>
            <div class="dm-card-icon"><i class="bi bi-cash-stack"></i></div>
        </div>
    </div>
</div>

<!-- Pending / Paid Summary -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="page-card d-flex align-items-center gap-4">
            <div style="width:54px;height:54px;background:linear-gradient(135deg,#f59e0b,#d97706);border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-hourglass-split text-white fs-4"></i>
            </div>
            <div>
                <div style="font-size:12px;font-weight:600;letter-spacing:0.5px;color:#64748b;text-transform:uppercase;">Pending Payout</div>
                <div style="font-size:28px;font-weight:800;color:#d97706;">৳@pending.ToString("0.##")</div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="page-card d-flex align-items-center gap-4">
            <div style="width:54px;height:54px;background:linear-gradient(135deg,#22c55e,#16a34a);border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-check-circle-fill text-white fs-4"></i>
            </div>
            <div>
                <div style="font-size:12px;font-weight:600;letter-spacing:0.5px;color:#64748b;text-transform:uppercase;">Total Paid Out</div>
                <div style="font-size:28px;font-weight:800;color:#16a34a;">৳@paid.ToString("0.##")</div>
            </div>
        </div>
    </div>
</div>

<!-- Chart + Table Row -->
<div class="row g-4">

    <!-- Earnings Chart -->
    <div class="col-lg-5">
        <div class="page-card">
            <h5 class="fw-bold mb-3"><i class="bi bi-bar-chart-fill me-2 text-primary"></i>Last 7 Days Trend</h5>
            <canvas id="earningsChart" height="220"></canvas>
        </div>
    </div>

    <!-- Transaction Table -->
    <div class="col-lg-7">
        <div class="page-card">
            <h5 class="fw-bold mb-3"><i class="bi bi-receipt me-2 text-success"></i>Transaction History</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-primary">
                        <tr>
                            <th>Date</th>
                            <th>Order ID</th>
                            <th>Order Total</th>
                            <th>Commission</th>
                            <th>Payment Type</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var p in Model.OrderByDescending(x => x.CreatedAt))
                            {
                                <tr>
                                    <td>@p.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                    <td><strong>#@p.OrderId</strong></td>
                                    <td>৳@p.OrderTotal</td>
                                    <td class="text-success fw-bold">৳@p.CommissionAmount.ToString("0.##")</td>
                                    <td><span class="badge bg-secondary">Cash on Delivery</span></td>
                                    <td>
                                        <span class="badge @(p.Status == "Paid" ? "bg-success" : "bg-warning text-dark")">@p.Status</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4">
                                    <i class="bi bi-wallet2 fs-2 text-muted"></i>
                                    <p class="text-muted mt-2">No transactions yet.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
    // Build last-7-days chart data from server
    const chartLabels = @Html.Raw(ViewBag.ChartLabels ?? "[]");
    const chartData   = @Html.Raw(ViewBag.ChartData   ?? "[]");

    const ctx = document.getElementById('earningsChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: chartLabels,
            datasets: [{
                label: 'Earnings (৳)',
                data: chartData,
                backgroundColor: 'rgba(99, 102, 241, 0.75)',
                borderColor: '#4f46e5',
                borderWidth: 2,
                borderRadius: 8,
                hoverBackgroundColor: 'rgba(99, 102, 241, 0.95)'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: ctx => '৳' + ctx.parsed.y } }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { callback: v => '৳' + v },
                    grid: { color: '#f1f5f9' }
                },
                x: { grid: { display: false } }
            }
        }
    });
</script>
}



