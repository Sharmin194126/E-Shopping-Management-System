@model IEnumerable<E_ShoppingManagement.Models.Order>
@{
    ViewData["Title"] = "Assigned Orders";
    ViewData["ActivePage"] = "AssignedOrders";
    Layout = "~/Views/Shared/_DeliveryManLayout.cshtml";
    var dm = ViewBag.DeliveryMan as E_ShoppingManagement.Models.DeliveryMan;
}

<style>
    /* ===== CALL CUSTOMER BUTTON ===== */
    .btn-call-customer {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: linear-gradient(135deg, #16a34a, #15803d);
        color: #ffffff !important;
        border: none;
        border-radius: 8px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.3px;
        text-decoration: none !important;
        box-shadow: 0 3px 10px rgba(22, 163, 74, 0.35);
        transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
        cursor: pointer;
        position: relative;
    }

    .btn-call-customer:hover {
        background: linear-gradient(135deg, #15803d, #166534);
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(22, 163, 74, 0.45);
        color: #ffffff !important;
    }
    
    /* ===== COPY PHONE CHIP ===== */
    .copy-phone-chip {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        background: #f2efe9;
        border: 1px solid #e6e2db;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        color: #33312e;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .copy-phone-chip:hover {
        background: #e6e2db;
        color: #33312e;
        border-color: #8b7d6b;
    }
</style>

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0 fw-bold"><i class="bi bi-list-check me-2 text-primary"></i>All Assigned Orders</h5>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to Dashboard</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead style="background: linear-gradient(135deg, #4b1d68 0%, #301144 100%); color:#fff;">
                <tr>
                    <th style="width: 70px;">SL No</th>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Address</th>
                    <th>Contact</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Payment</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @{ var sl = 1; }
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@(sl++)</td>
                        <td><strong>@order.Id</strong></td>
                        <td><span class="fw-bold">@order.Customer?.Name</span></td>
                        <td><small>@order.ShippingAddress, @order.City</small></td>
                        <td>
                            @if (!string.IsNullOrEmpty(order.PhoneNumber))
                            {
                                <span class="copy-phone-chip" onclick="copyPhone(this, '@order.PhoneNumber')" title="Click to copy number" data-bs-toggle="tooltip" data-bs-placement="top">
                                    <i class="bi bi-telephone-fill me-1"></i>@order.PhoneNumber
                                    <i class="bi bi-clipboard ms-1 copy-icon"></i>
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>৳@order.TotalAmount</td>
                        <td>
                            @switch(order.OrderStatus)
                            {
                                case "Delivered": <span class="badge bg-success">Delivered</span> break;
                                case "Returned": <span class="badge bg-danger">Returned</span> break;
                                case "Shipped": <span class="badge bg-info">Shipped</span> break;
                                case "Waiting": <span class="badge bg-secondary">Waiting</span> break;
                                default: <span class="badge bg-warning text-dark">@order.OrderStatus</span> break;
                            }
                        </td>
                        <td>
                            <span class="badge @(order.PaymentStatus == "Paid" ? "bg-success" : "bg-warning")">@order.PaymentStatus</span>
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-info text-white" title="View Order Details" data-bs-toggle="tooltip" data-bs-placement="top">
                                    <i class="bi bi-eye-fill"></i> View
                                </a>
                                @if (!string.IsNullOrEmpty(order.PhoneNumber))
                                {
                                    <a href="tel:@order.PhoneNumber" class="btn btn-sm btn-call-customer" title="Call Customer" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="bi bi-telephone-fill"></i> Call
                                    </a>
                                }
                                @if (User.IsInRole("DeliveryMan") && order.OrderStatus != "Delivered" && order.OrderStatus != "Returned")
                                {
                                    <button class="btn btn-sm btn-warning text-dark fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#update-@order.Id" title="Update Order Status">
                                        <i class="bi bi-pencil-fill"></i> Update
                                    </button>
                                }
                            </div>
                            <div class="collapse mt-2" id="update-@order.Id">
                                <form asp-action="UpdateStatus" method="post" class="p-2 border rounded" style="background:#f2efe9;">
                                    <input type="hidden" name="orderId" value="@order.Id" />
                                    <div class="mb-2">
                                        <label class="small fw-bold">Change Status:</label>
                                        <select name="status" class="form-select form-select-sm" onchange="toggleReason(this, @order.Id)">
                                            <option value="Shipped">Shipped</option>
                                            <option value="Delivered">Delivered</option>
                                            <option value="Waiting">Waiting (Not received)</option>
                                            <option value="Returned">Return Parcel</option>
                                        </select>
                                    </div>
                                    <div class="mb-2 d-none" id="reason-div-@order.Id">
                                        <label class="small fw-bold text-danger">Return Reason:</label>
                                        <input type="text" name="reason" class="form-control form-control-sm" placeholder="Why returned?" />
                                    </div>
                                    @if (order.PaymentStatus != "Paid")
                                    {
                                        <div class="form-check mb-2 bg-light border border-2 border-primary text-dark p-2 rounded d-flex align-items-center justify-content-between">
                                            <div>
                                                <input class="form-check-input ms-1" type="checkbox" name="paymentStatus" value="Paid" id="pay-@order.Id" onchange="togglePaymentReceived(this, @order.Id)">
                                                <label class="form-check-label small fw-bold ms-1 mt-1" style="cursor:pointer;" for="pay-@order.Id">Mark Payment as Received</label>
                                            </div>
                                            <i class="bi bi-check-lg fs-4 d-none text-success fw-bold" id="pay-check-icon-@order.Id"></i>
                                        </div>
                                    }
                                    <button type="submit" class="btn btn-sm btn-success w-100 mt-1">Submit Update</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center py-5">
                            <i class="bi bi-box-seam fs-1 text-muted"></i>
                            <p class="mt-2 text-muted">No orders assigned to you yet.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function toggleReason(select, orderId) {
            const div = document.getElementById('reason-div-' + orderId);
            if (select.value === 'Returned') {
                div.classList.remove('d-none');
            } else {
                div.classList.add('d-none');
            }
        }
        
        function togglePaymentReceived(checkbox, orderId) {
            const icon = document.getElementById('pay-check-icon-' + orderId);
            if (checkbox.checked) {
                icon.classList.remove('d-none');
            } else {
                icon.classList.add('none');
            }
        }

        function copyPhone(element, phone) {
            navigator.clipboard.writeText(phone).then(function() {
                var icon = element.querySelector('.copy-icon');
                if(icon) {
                    icon.classList.remove('bi-clipboard');
                    icon.classList.add('bi-check2', 'text-success');
                }
                setTimeout(function() {
                    if(icon) {
                        icon.classList.remove('bi-check2', 'text-success');
                        icon.classList.add('bi-clipboard');
                    }
                }, 2000);
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            var tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
            tooltipEls.forEach(function (el) {
                new bootstrap.Tooltip(el, { trigger: 'hover' });
            });
        });
    </script>
}
