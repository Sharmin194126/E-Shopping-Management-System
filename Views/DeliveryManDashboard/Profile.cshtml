@model E_ShoppingManagement.Models.DeliveryMan
@{
    ViewData["Title"] = "My Profile";
    ViewData["ActivePage"] = "Profile";
    Layout = "~/Views/Shared/_DeliveryManLayout.cshtml";
}

<div class="row g-4 justify-content-center">

    <!-- Profile Card -->
    <div class="col-lg-4">
        <div class="page-card text-center">

            <!-- Avatar -->
            <div class="profile-avatar mx-auto mb-3">
                <i class="bi bi-person-fill"></i>
            </div>

            <h4 class="fw-bold mb-1" style="color:#1e293b;">@Model.Name</h4>
            <p class="text-muted mb-2" style="font-size:13px;">Delivery Partner</p>

            @if (Model.Status == "Active")
            {
                <span class="badge bg-success px-3 py-1">● Active</span>
            }
            else
            {
                <span class="badge bg-secondary px-3 py-1">@Model.Status</span>
            }

            <hr class="my-4" />

            <!-- Info Grid -->
            <div class="profile-info-grid">
                <div class="profile-info-item">
                    <div class="pinfo-icon bg-blue-soft"><i class="bi bi-telephone-fill text-primary"></i></div>
                    <div>
                        <div class="pinfo-label">Phone</div>
                        <div class="pinfo-value">@Model.ContactNumber</div>
                    </div>
                </div>
                <div class="profile-info-item">
                    <div class="pinfo-icon bg-purple-soft"><i class="bi bi-envelope-fill" style="color:#8b5cf6;"></i></div>
                    <div>
                        <div class="pinfo-label">Email</div>
                        <div class="pinfo-value">@(Model.Email ?? "N/A")</div>
                    </div>
                </div>
                <div class="profile-info-item">
                    <div class="pinfo-icon bg-green-soft"><i class="bi bi-truck-fill text-success"></i></div>
                    <div>
                        <div class="pinfo-label">Vehicle</div>
                        <div class="pinfo-value">@(Model.VehicleInfo ?? "N/A")</div>
                    </div>
                </div>
                <div class="profile-info-item">
                    <div class="pinfo-icon bg-orange-soft"><i class="bi bi-percent" style="color:#f59e0b;"></i></div>
                    <div>
                        <div class="pinfo-label">Commission Rate</div>
                        <div class="pinfo-value">@Model.CommissionRate%</div>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <!-- Earnings Summary -->
            <div class="row g-2 text-center">
                <div class="col-4">
                    <div class="p-2 rounded" style="background:#f0fdf4;">
                        <div style="font-size:18px;font-weight:800;color:#16a34a;">৳@Model.TotalEarnings.ToString("0.##")</div>
                        <div style="font-size:10px;color:#64748b;font-weight:600;text-transform:uppercase;">Total</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-2 rounded" style="background:#fefce8;">
                        <div style="font-size:18px;font-weight:800;color:#d97706;">৳@Model.PendingAmount.ToString("0.##")</div>
                        <div style="font-size:10px;color:#64748b;font-weight:600;text-transform:uppercase;">Pending</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-2 rounded" style="background:#eff6ff;">
                        <div style="font-size:18px;font-weight:800;color:#2563eb;">৳@Model.PaidAmount.ToString("0.##")</div>
                        <div style="font-size:10px;color:#64748b;font-weight:600;text-transform:uppercase;">Paid</div>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="d-grid gap-2">
                <a asp-action="Index" class="theme-back-btn text-center justify-content-center mb-0">
                    <i class="bi bi-grid-1x2 me-2"></i>Back to Dashboard
                </a>
            </div>

        </div>
    </div>

    <!-- Edit Forms Column -->
    <div class="col-lg-7">
        @if (User.IsInRole("DeliveryMan"))
        {

        <!-- Update Profile Form -->
        <div class="page-card mb-4">
            <h5 class="fw-bold mb-4">
                <i class="bi bi-pencil-square me-2 text-primary"></i>Update Profile
            </h5>
            <form asp-action="UpdateProfile" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" name="name" value="@Model.Name" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone Number</label>
                        <input type="text" class="form-control" name="contactNumber" value="@Model.ContactNumber" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-control" name="email" value="@(Model.Email ?? "")" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Vehicle Info</label>
                        <input type="text" class="form-control" name="vehicleInfo" value="@(Model.VehicleInfo ?? "")" />
                    </div>
                    <div class="col-12 mt-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save me-2"></i>Update Profile
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Change Password Form -->
        <div class="page-card">
            <h5 class="fw-bold mb-4">
                <i class="bi bi-shield-lock-fill me-2 text-warning"></i>Change Password
            </h5>

            @if (TempData["PwdSuccess"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["PwdSuccess"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["PwdError"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["PwdError"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="ChangePassword" method="post">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label">Current Password</label>
                        <div class="position-relative">
                            <input type="password" class="form-control" name="currentPassword"
                                   placeholder="Enter current password" id="curPwd" />
                            <span class="pwd-eye" onclick="togglePwd('curPwd', this)">
                                <i class="bi bi-eye-slash"></i>
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">New Password</label>
                        <div class="position-relative">
                            <input type="password" class="form-control" name="newPassword"
                                   placeholder="New password" id="newPwd" />
                            <span class="pwd-eye" onclick="togglePwd('newPwd', this)">
                                <i class="bi bi-eye-slash"></i>
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Confirm Password</label>
                        <div class="position-relative">
                            <input type="password" class="form-control" name="confirmPassword"
                                   placeholder="Confirm password" id="confPwd" />
                            <span class="pwd-eye" onclick="togglePwd('confPwd', this)">
                                <i class="bi bi-eye-slash"></i>
                            </span>
                        </div>
                    </div>
                    <div class="col-12 mt-2">
                        <button type="submit" class="btn btn-warning text-white px-4">
                            <i class="bi bi-key-fill me-2"></i>Change Password
                        </button>
                    </div>
                </div>
            </form>
        </div>

        }
        else
        {
            <div class="page-card text-center p-5">
                <i class="bi bi-shield-lock text-muted" style="font-size: 3rem;"></i>
                <h5 class="mt-3 text-muted">View Only Mode</h5>
                <p class="small text-muted">You are viewing this profile as an Administrator or Employee. Only the Delivery Partner can modify their own details.</p>
            </div>
        }
    </div>
</div>

<style>
    .profile-avatar {
        width: 90px; height: 90px;
        border-radius: 50%;
        background: linear-gradient(135deg, #532374, #8b3fb8);
        display: flex; align-items: center; justify-content: center;
        font-size: 36px; color: #fff;
        box-shadow: 0 6px 20px rgba(83,35,116,0.35);
    }

    .profile-info-grid { display: flex; flex-direction: column; gap: 10px; text-align: left; }
    .profile-info-item {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 14px; border-radius: 10px;
        background: #f2efe9; border: 1px solid #e6e2db;
    }
    .pinfo-icon {
        width: 36px; height: 36px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 16px; flex-shrink: 0;
    }
    .bg-blue-soft   { background: #eff6ff; }
    .bg-purple-soft { background: #f5f3ff; }
    .bg-green-soft  { background: #f0fdf4; }
    .bg-orange-soft { background: #fff7ed; }
    .pinfo-label { font-size: 11px; color: #94a3b8; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .pinfo-value { font-size: 14px; font-weight: 700; color: #33312e; }

    .pwd-eye {
        position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
        cursor: pointer; color: #64748b; font-size: 16px;
    }
    .pwd-eye:hover { color: #3b82f6; }
</style>

@section Scripts {
    <script>
        function togglePwd(inputId, icon) {
            const input = document.getElementById(inputId);
            const i = icon.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                i.className = 'bi bi-eye';
            } else {
                input.type = 'password';
                i.className = 'bi bi-eye-slash';
            }
        }
    </script>
}
