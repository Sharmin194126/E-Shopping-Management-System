@model IEnumerable<E_ShoppingManagement.Models.Order>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Dashboard";
}

<div class="container mt-5">
    
<div class="d-flex justify-content-end align-items-center mb-3">
    <a href="javascript:history.back()" class="theme-back-btn mb-0">Back</a>
</div>
<div class="row">
        <!-- Sidebar / Menu -->
        <div class="col-md-3">
            <div class="card shadow-sm mb-4 border-0" style="border-radius: 12px;">
                <div class="card-body text-center position-relative" style="border-radius: 12px 12px 0 0; overflow: hidden; padding-top: 40px; background: #fff; border-bottom: 1px solid #f1f5f9;">
                    <!-- Background Cover -->
                    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 80px; background: linear-gradient(135deg, #532374, #8b5cf6);"></div>
                    <img src="@(string.IsNullOrEmpty(ViewBag.ProfilePictureUrl) ? "/images/user-avatar.png" : ViewBag.ProfilePictureUrl)" class="rounded-circle mb-2 shadow position-relative" style="width: 100px; height: 100px; object-fit: cover; border: 4px solid #fff; background: #fff; z-index: 2;" onerror="this.src='/images/user-avatar.png'" />
                    <h5 class="fw-bold mb-1" style="color: #33312e; position: relative; z-index: 2;">@ViewBag.CustomerName</h5>
                    <p class="text-muted small mb-0 position-relative" style="z-index: 2;"><i class="bi bi-patch-check-fill text-success me-1"></i>Verified Customer</p>
                </div>
                <div class="list-group list-group-flush customer-sidebar">
                    <style>
                        .customer-sidebar .list-group-item.active {
                            background-color: #f8f6f0 !important;
                            border-color: #532374 !important;
                            border-left: 4px solid #532374 !important;
                            color: #532374 !important;
                            font-weight: 700;
                        }
                        .customer-sidebar .list-group-item {
                            padding: 14px 20px;
                            transition: 0.2s ease;
                            color: #475569;
                            border: none;
                            border-bottom: 1px solid #f1f5f9;
                            border-left: 4px solid transparent;
                        }
                        .customer-sidebar .list-group-item:last-child {
                            border-bottom: none;
                        }
                        .customer-sidebar .list-group-item:hover:not(.active) {
                            background-color: #f8f6f0;
                            color: #532374;
                            border-left-color: #e6e2db;
                        }
                    </style>
                    <a href="/CustomerDashboard" class="list-group-item list-group-item-action active"><i class="bi bi-grid-1x2 me-2"></i>Dashboard</a>
                    <a href="/CustomerDashboard/Profile" class="list-group-item list-group-item-action"><i class="bi bi-person me-2"></i>My Profile</a>
                    <a href="/CustomerDashboard/Orders" class="list-group-item list-group-item-action"><i class="bi bi-cart3 me-2"></i>My Orders</a>
                    <a href="/Cart" class="list-group-item list-group-item-action"><i class="bi bi-bag me-2"></i>My Cart</a>
                    <a href="/Home/Tracking" class="list-group-item list-group-item-action text-primary"><i class="bi bi-geo-alt me-2"></i>Track Order</a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <h3 class="mb-4 fw-bold" style="color:#532374;"><i class="bi bi-grid-1x2 me-2"></i>My Dashboard</h3>
            
            <style>
                .stat-card-hover { transition: transform 0.3s ease, box-shadow 0.3s ease; }
                .stat-card-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.12) !important; z-index: 10; }
            </style>

            <div class="row mb-4 g-3">
                <div class="col-md-4">
                    <div class="card text-white shadow-sm h-100 stat-card-hover" style="background: linear-gradient(135deg, #1aa385, #117d65); border: none; border-radius: 12px;">
                        <div class="card-body d-flex justify-content-between align-items-center p-4">
                            <div>
                                <h6 class="card-title mb-1 text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 11px; opacity: 0.9;">Total Spent</h6>
                                <p class="card-text fw-bold mb-0" style="font-size: 28px;"><span style="font-size: 18px;">৳</span>@Model.Where(o => o.OrderStatus == "Delivered").Sum(o => o.TotalAmount).ToString("#,##0")</p>
                            </div>
                            <div style="font-size: 40px; opacity: 0.3;">
                                <i class="bi bi-wallet2"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-white shadow-sm h-100 stat-card-hover" style="background: linear-gradient(135deg, #532374, #733c9a); border: none; border-radius: 12px;">
                        <div class="card-body d-flex justify-content-between align-items-center p-4">
                            <div>
                                <h6 class="card-title mb-1 text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 11px; opacity: 0.9;">My Orders</h6>
                                <p class="card-text fw-bold mb-0" style="font-size: 28px;">@Model.Count()</p>
                            </div>
                            <div style="font-size: 40px; opacity: 0.3;">
                                <i class="bi bi-bag-check-fill"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-white shadow-sm h-100 stat-card-hover" style="background: linear-gradient(135deg, #f59e0b, #d97706); border: none; border-radius: 12px;">
                        <div class="card-body d-flex justify-content-between align-items-center p-4">
                            <div>
                                <h6 class="card-title mb-1 text-uppercase fw-bold" style="letter-spacing: 0.5px; font-size: 11px; opacity: 0.9;">Pending / Process</h6>
                                <p class="card-text fw-bold mb-0" style="font-size: 28px;">@Model.Count(o => o.OrderStatus == "Pending" || o.OrderStatus == "Processing")</p>
                            </div>
                            <div style="font-size: 40px; opacity: 0.3;">
                                <i class="bi bi-hourglass-split"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0" style="border-radius: 12px; overflow:hidden;">
                <div class="card-header border-bottom-0 p-4" style="background: linear-gradient(135deg, #532374, #3d1a55); color: #fff;">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2" style="opacity: 0.8;"></i>Recent Orders</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-bag-x" style="font-size:4rem; color:#cbd5e1;"></i>
                            <p class="text-muted mt-3 fs-5">You haven't placed any orders yet.</p>
                            <a href="/Home/CategoryProducts" class="btn fw-bold px-4 pt-2 pb-2 text-white" style="background:#532374; border-radius:25px;">Start Shopping</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead style="background:#f2efe9; color:#532374;">
                                    <tr>
                                        <th class="ps-4" style="width: 70px;">SL</th>
                                        <th>Order ID</th>
                                        <th>Date</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                        <th class="text-center pe-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var sl = 1; }
                                    @foreach (var order in Model.OrderByDescending(o=>o.CreatedAt).Take(5))
                                    {
                                        <tr>
                                            <td class="ps-4">@(sl++)</td>
                                            <td class="fw-bold">#@order.Id</td>
                                            <td><small class="text-muted">@order.CreatedAt.ToString("MMM dd, yyyy")</small></td>
                                            <td class="fw-bold text-success">৳@order.TotalAmount</td>
                                            <td>
                                                <span class="badge rounded-pill @(order.OrderStatus == "Delivered" ? "bg-success" : (order.OrderStatus == "Cancelled" ? "bg-danger" : "bg-warning text-dark"))">
                                                    @order.OrderStatus
                                                </span>
                                            </td>
                                            <td class="text-center pe-4">
                                                <a href="/CustomerDashboard/OrderDetails/@order.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3">View</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if(Model.Count() > 5)
                        {
                            <div class="text-center p-3 border-top" style="background:#fafafa;">
                                <a href="/CustomerDashboard/Orders" class="text-decoration-none fw-bold" style="color:#532374;">View All Orders <i class="bi bi-arrow-right"></i></a>
                            </div>
                        }
                    }
                </div>
            </div>

        </div>
    </div>
</div>



