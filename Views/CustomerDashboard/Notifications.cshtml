@model IEnumerable<E_ShoppingManagement.Models.Order>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Notifications";
    var lastCheck = ViewBag.LastNotificationCheck as DateTime? ?? DateTime.MinValue;
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0" style="color:#532374;"><i class="bi bi-bell-fill me-2"></i>My Notifications</h3>
    </div>

    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            @{ ViewData["ActivePage"] = "Notifications"; }
            @await Html.PartialAsync("_CustomerSidebar")
        </div>

        <!-- Content -->
        <div class="col-md-9">
            <div class="card shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-body p-0">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-bell-slash text-muted" style="font-size: 4rem;"></i>
                            <p class="mt-3 fs-5 text-muted">No notifications yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var order in Model)
                            {
                                bool isNew = order.CreatedAt > lastCheck;
                                <a href="/CustomerDashboard/OrderDetails/@order.Id" class="list-group-item list-group-item-action p-4 @(isNew ? "bg-light border-start border-4 border-primary" : "")">
                                    <div class="d-flex w-100 justify-content-between align-items-center">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle bg-primary bg-opacity-10 p-3 text-primary">
                                                <i class="bi @(order.OrderStatus == "Delivered" ? "bi-check-circle" : (order.OrderStatus == "Cancelled" ? "bi-x-circle" : "bi-box-seam")) fs-4"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-1 fw-bold">Order #@order.Id Update</h6>
                                                <p class="mb-1 text-muted">Your order is currently <strong>@order.OrderStatus</strong>.</p>
                                                <small class="text-secondary"><i class="bi bi-clock me-1"></i>@order.CreatedAt.ToString("MMM dd, yyyy | hh:mm tt")</small>
                                            </div>
                                        </div>
                                        @if (isNew)
                                        {
                                            <span class="badge rounded-pill bg-danger">NEW</span>
                                        }
                                    </div>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
