@model IEnumerable<E_ShoppingManagement.Models.ContactMessage>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Messages";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0" style="color:#532374;"><i class="bi bi-chat-dots-fill me-2"></i>My Messages</h3>
        <a href="/CustomerDashboard" class="theme-back-btn mb-0 shadow">Back to Dashboard</a>
    </div>

    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="card shadow-sm mb-4 border-0" style="border-radius: 12px;">
                <div class="list-group list-group-flush customer-sidebar">
                    <style>
                        .customer-sidebar .list-group-item.active { background-color: #f8f6f0 !important; border-color: #532374 !important; border-left: 4px solid #532374 !important; color: #532374 !important; font-weight: 700; }
                        .customer-sidebar .list-group-item { padding: 14px 20px; transition: 0.2s ease; color: #475569; border: none; border-bottom: 1px solid #f1f5f9; border-left: 4px solid transparent; }
                        .customer-sidebar .list-group-item:last-child { border-bottom: none; }
                        .customer-sidebar .list-group-item:hover:not(.active) { background-color: #f8f6f0; color: #532374; border-left-color: #e6e2db; }
                    </style>
                    <a href="/CustomerDashboard" class="list-group-item list-group-item-action"><i class="bi bi-grid-1x2 me-2"></i>Dashboard</a>
                    <a href="/CustomerDashboard/Profile" class="list-group-item list-group-item-action"><i class="bi bi-person me-2"></i>My Profile</a>
                    <a href="/CustomerDashboard/Orders" class="list-group-item list-group-item-action"><i class="bi bi-cart3 me-2"></i>My Orders</a>
                    <a href="/CustomerDashboard/Notifications" class="list-group-item list-group-item-action"><i class="bi bi-bell me-2"></i>Notifications</a>
                    <a href="/CustomerDashboard/Messages" class="list-group-item list-group-item-action active"><i class="bi bi-chat-dots me-2"></i>Messages</a>
                    <a href="/Cart" class="list-group-item list-group-item-action"><i class="bi bi-bag me-2"></i>My Cart</a>
                    <a href="/Home/Tracking" class="list-group-item list-group-item-action text-primary"><i class="bi bi-geo-alt me-2"></i>Track Order</a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="mt-3 px-3 pb-3">
                        <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center gap-2" style="background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.30); color: #ef4444; font-weight: 600; padding: 10px 16px; border-radius: 8px; transition: all 0.2s;">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Content -->
        <div class="col-md-9">
            <div class="card shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-body p-4">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-chat-left-dots text-muted" style="font-size: 4rem;"></i>
                            <p class="mt-3 fs-5 text-muted">You haven't sent any messages yet.</p>
                            <a href="/Home/Contact" class="btn btn-primary px-4 rounded-pill">Contact Us</a>
                        </div>
                    }
                    else
                    {
                        @foreach (var msg in Model)
                        {
                            <div class="message-card mb-4 p-4 rounded border-start border-4 @(string.IsNullOrEmpty(msg.Reply) ? "border-warning" : "border-success")" style="background: #f8f6f0;">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="fw-bold mb-0">Subject: @msg.Subject</h5>
                                    <span class="badge @(string.IsNullOrEmpty(msg.Reply) ? "bg-warning text-dark" : "bg-success")">
                                        @(string.IsNullOrEmpty(msg.Reply) ? "Pending Reply" : "Replied")
                                    </span>
                                </div>
                                <p class="mb-3 text-muted" style="font-size: 0.95rem;">@msg.Message</p>
                                <div class="text-secondary small mb-3">
                                    <i class="bi bi-clock me-1"></i>Sent on: @msg.CreatedAt.ToString("MMM dd, yyyy | hh:mm tt")
                                </div>
                                
                                @if (!string.IsNullOrEmpty(msg.Reply))
                                {
                                    <div class="reply-box mt-3 p-3 bg-white rounded border">
                                        <div class="fw-bold text-success mb-2"><i class="bi bi-reply-fill me-1"></i>Store Reply:</div>
                                        <div class="text-dark">@msg.Reply</div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
