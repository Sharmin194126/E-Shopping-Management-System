@model E_ShoppingManagement.Models.Order
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Order Details";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Order Details SL @Model.Id</h2>
        <div class="d-flex gap-2">
            @if (Model.PaymentStatus == "Paid")
            {
                <a href="/CustomerDashboard/MoneyReceipt/@Model.Id" class="btn btn-success">View Money Receipt</a>
            }
            <a href="/CustomerDashboard/Orders" class="theme-back-btn mb-0">Back</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-theme text-white">
                    <h5 class="mb-0 text-white">Order Items</h5>
                </div>
                <div class="card-body">
                    <table class="table align-middle">
                        <thead style="background:#532374; color:#fff;">
                            <tr>
                                <th style="width: 70px;">SL</th>
                                <th>Product</th>
                                <th>Unit Price</th>
                                <th>Quantity</th>
                                <th>Subtotal (Inc. VAT)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var sl = 1; }
                            @foreach (var item in Model.OrderDetails)
                            {
                                <tr>
                                    <td>@(sl++)</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl) ? "/images/no-image.png" : (item.Product.ImageUrl.StartsWith("/") ? item.Product.ImageUrl : "/images/products/" + item.Product.ImageUrl))" 
                                                 style="width: 50px; height: 50px; object-fit: cover; margin-right: 10px;" />
                                            <div>@(item.Product?.Name ?? "Product")</div>
                                        </div>
                                    </td>
                                    <td>৳@item.PriceWithVat.ToString("N0")</td>
                                    <td>@item.Quantity</td>
                                    <td>৳@((item.PriceWithVat * item.Quantity).ToString("N0"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="text-end fw-bold">Grand Total (Inc. VAT):</td>
                                <td class="fw-bold fs-5 text-danger">৳@Model.TotalAmount.ToString("N0")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-theme text-white">
                    <h5 class="mb-0 text-white">Order Summary</h5>
                </div>
                <div class="card-body">
                    <p><strong>Order Date:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</p>
                    <p><strong>Status:</strong> <span class="badge @(Model.OrderStatus == "Delivered" ? "bg-success text-white" : "bg-warning text-dark")">@Model.OrderStatus</span></p>
                     <p><strong>Payment Method:</strong> 
                        @{
                            var pm = Model.PaymentMethod;
                            if (string.Equals(pm, "bKash", StringComparison.OrdinalIgnoreCase)) pm = "bKash";
                            else if (string.Equals(pm, "Nagad", StringComparison.OrdinalIgnoreCase)) pm = "Nagad";
                            else if (string.IsNullOrEmpty(pm) || pm == "COD") pm = "Cash on Delivery";
                        }
                        @pm
                     </p>
                </div>
            </div>
        </div>
    </div>
</div>
