@model E_ShoppingManagement.Models.Order
@{
    ViewData["Title"] = "Money Receipt";
    Layout = null; // No layout for printable receipt
    var company = ViewBag.CompanyInfo as E_ShoppingManagement.Models.FooterInfo;
}

<!DOCTYPE html>
<html>
<head>
    <title>Money Receipt - @Model.Id</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 30px; background: #f0f2f5; }
        .receipt-container { 
            background: #f2efe9; 
            padding: 40px; 
            border-radius: 15px; 
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            max-width: 800px;
            margin: auto;
        }
        .receipt-header { border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 30px; }
        .company-name { font-family: 'French Script MT', cursive; font-size: 48px; color: #007bff; font-weight: bold; }
        .receipt-title { font-size: 24px; font-weight: bold; color: #333; text-transform: uppercase; letter-spacing: 2px; }
        .info-label { font-weight: bold; color: #666; width: 150px; display: inline-block; }
        .table thead { background: #007bff; color: white; }
        .total-section { border-top: 2px solid #eee; margin-top: 20px; padding-top: 10px; }
        .paid-stamp { 
            border: 3px solid #28a745; 
            color: #28a745; 
            padding: 5px 15px; 
            display: inline-block; 
            font-size: 32px; 
            font-weight: 800; 
            transform: rotate(-15deg); 
            border-radius: 10px;
            opacity: 0.8;
        }
        .theme-back-btn { 
            background: #532374; 
            color: white; 
            padding: 10px 25px; 
            border-radius: 50px; 
            text-decoration: none; 
            font-weight: 600; 
            transition: all 0.3s ease; 
            display: inline-flex; 
            align-items: center; 
            gap: 8px; 
            border: none;
        }
        .theme-back-btn:hover { background: #3d1a55; color: white; transform: translateX(-5px); }
        @@media print {
            .no-print { display: none !important; }
            body { background: white; padding: 0; margin: 0; width: 100%; height: auto; overflow: visible; }
            .receipt-container { 
                box-shadow: none !important; 
                border: none !important; 
                width: 100% !important; 
                max-width: 100% !important; 
                margin: 0 !important; 
                padding: 5px !important;
                background: white !important;
                transform: scale(0.98);
                transform-origin: top center;
            }
            .table { font-size: 9pt; margin-bottom: 5px; }
            .company-name { font-size: 28px; }
            .receipt-title { font-size: 18px; }
            .paid-stamp { font-size: 20px; }
            .mt-5 { margin-top: 2rem !important; }
            .pt-5 { padding-top: 2rem !important; }
            @@page {
                size: A4;
                margin: 1cm;
            }
        }
    </style>
</head>
<body>
    <div class="no-print d-flex justify-content-center align-items-center gap-3 mb-4">
        <a href="javascript:history.back()" class="theme-back-btn mb-0 shadow">
            <i class="bi bi-arrow-left"></i> Back
        </a>
        <button onclick="window.print()" class="btn btn-primary btn-lg px-5 shadow">Print / Download Receipt</button>
    </div>

    <div class="receipt-container">
        <div class="receipt-header d-flex justify-content-between align-items-center">
            <div>
                <div class="company-name" style="color:#532374;">E-Shop</div>
                <div>@company?.Address</div>
                <div>Phone: @company?.ContactNumber</div>
                <div>Email: @company?.Email</div>
            </div>
            <div class="text-end">
                <div class="receipt-title">Money Receipt</div>
                <div class="mt-2 text-muted">Date: @Model.CreatedAt.ToString("dd MMM yyyy")</div>
                <div class="mt-1"><strong>Invoice: #@Model.Id</strong></div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-6">
                <h5 class="mb-3" style="color:#532374;">Customer Details</h5>
                <div><span class="info-label">Name:</span> @(Model.Customer?.Name ?? Model.CreatedBy)</div>
                <div><span class="info-label">Phone:</span> @Model.PhoneNumber</div>
                <div><span class="info-label">Address:</span> @Model.ShippingAddress</div>
            </div>
            <div class="col-6 text-end d-flex align-items-center justify-content-end">
                @if (Model.PaymentStatus == "Paid")
                {
                    <div class="paid-stamp">PAID</div>
                }
                else
                {
                    <div class="paid-stamp" style="border-color:#dc3545; color:#dc3545;">UNPAID</div>
                }
            </div>
        </div>

        <!-- Payment Info Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="p-3 rounded" style="background: rgba(83,35,116,0.05); border: 1px dashed #532374;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <strong>Payment Method:</strong>
                            @if (string.Equals(Model.PaymentMethod, "bKash", StringComparison.OrdinalIgnoreCase)) {
                                <div class="payment-badge-receipt">bKash</div>
                            } else if (string.Equals(Model.PaymentMethod, "Nagad", StringComparison.OrdinalIgnoreCase)) {
                                <div class="payment-badge-receipt">Nagad</div>
                            } else {
                                <span class="badge bg-secondary">@(string.IsNullOrEmpty(Model.PaymentMethod) || Model.PaymentMethod == "COD" ? "Cash on Delivery" : Model.PaymentMethod)</span>
                            }
                        </div>
                        <div>
                            <strong>Payment Status:</strong>
                            <span class="badge @(Model.PaymentStatus == "Paid" ? "bg-success" : "bg-danger")">@Model.PaymentStatus</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <table class="table table-bordered mt-4">
            <thead style="background:#532374; color:#fff;">
                <tr>
                    <th style="width: 70px;">SL No</th>
                    <th>Product Name</th>
                    <th class="text-center">Price</th>
                    <th class="text-center">Quantity</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                @{ var sl = 1; }
                @if (Model.OrderDetails != null)
                {
                    foreach (var item in Model.OrderDetails)
                    {
                        <tr>
                            <td>@(sl++)</td>
                            <td>
                                @(item.Product?.Name ?? "Product") (@(item.Size ?? "N/A"))
                                @if (item.OfferPercentage > 0)
                                {
                                    <br /><small class="text-success fw-bold">(@item.OfferPercentage% Offer applied)</small>
                                }
                            </td>
                            <td class="text-center">
                                ৳@item.Price.ToString("#,##0") <br />
                                <small class="text-muted">+ ৳@item.VatAmount.ToString("#,##0") VAT</small>
                            </td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">৳@((item.PriceWithVat * item.Quantity).ToString("#,##0"))</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="4" class="text-end font-weight-bold">Subtotal (Excl. VAT)</td>
                    <td class="text-end">৳@((Model.OrderDetails?.Sum(i => i.Price * i.Quantity) ?? 0).ToString("#,##0"))</td>
                </tr>
                <tr>
                    <td colspan="4" class="text-end font-weight-bold">Total VAT</td>
                    <td class="text-end">৳@((Model.OrderDetails?.Sum(i => i.VatAmount * i.Quantity) ?? 0).ToString("#,##0"))</td>
                </tr>
                <tr class="table-info">
                    <td colspan="4" class="text-end fw-bold fs-5">Total Paid</td>
                    <td class="text-end fw-bold fs-5">৳@Model.TotalAmount.ToString("#,##0")</td>
                </tr>
            </tfoot>
        </table>

        <div class="mt-5 pt-5 d-flex justify-content-between">
            <div class="text-center" style="border-top: 1px solid #000; width: 150px;">
                Customer Signature
            </div>
            <div class="text-center" style="border-top: 1px solid #000; width: 150px;">
                Authorized Signature
            </div>
        </div>

        <div class="mt-5 text-center text-muted small">
            Thank you for shopping with E-Shop! This is a computer generated receipt.
        </div>
    </div>

    <script>
        // Auto-print if needed can be added here
    </script>
</body>
</html>


