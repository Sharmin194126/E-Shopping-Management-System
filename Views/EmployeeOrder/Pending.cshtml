@model IEnumerable<E_ShoppingManagement.ViewModels.EmployeeOrderListViewModel>

@{
    ViewData["Title"] = "Pending Orders";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Pending Orders</h2>
    <a asp-controller="EmployeeDashboard" asp-action="Index" class="theme-back-btn mb-0">Back</a>
</div>

<div class="page-card p-3">
    <table class="table table-hover table-bordered align-middle">
        <thead style="background:#532374; color:#fff;">
            <tr>
                <th style="width: 70px;">SL No</th>
                <th>Order Id</th>
                <th>Customer</th>
                <th>Total</th>
                <th>Status</th>
                <th>Created</th>
                <th style="width:140px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{ var sl = 1; }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted">No pending orders.</td></tr>
            }
            else
            {
                foreach (var o in Model)
                {
                    <tr>
                        <td>@(sl++)</td>
                        <td>@o.OrderId</td>
                        <td>@o.CustomerName</td>
                        <td>৳@o.TotalAmount</td>
                        <td>
                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@o.OrderId" />
                                <select name="newStatus" onchange="this.form.submit()" class="form-select form-select-sm fw-bold text-primary" style="min-width: 110px;">
                                    <option value="Pending" selected="@(o.OrderStatus == "Pending")">Pending</option>
                                    <option value="Processing" selected="@(o.OrderStatus == "Processing")">Processing</option>
                                    <option value="Shipped" selected="@(o.OrderStatus == "Shipped")">Shipped</option>
                                    <option value="Delivered" selected="@(o.OrderStatus == "Delivered")">Delivered</option>
                                </select>
                            </form>
                        </td>
                        <td>@o.CreatedAt.ToLocalTime().ToString("dd-MM-yyyy, hh:mm tt")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@o.OrderId" class="btn btn-sm btn-outline-info">View</a>
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="this.parentElement.parentElement.previousElementSibling.previousElementSibling.querySelector('select').focus()">Edit</button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
