@model IEnumerable<E_ShoppingManagement.ViewModels.EmployeeOrderListViewModel>

@{
    ViewData["Title"] = "Manage Orders";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Orders</h2>
    <a asp-controller="EmployeeDashboard" asp-action="Index" class="theme-back-btn">Back to Dashboard</a>
</div>

<div class="page-card p-3 mb-3">
    <form asp-action="Index" method="get" class="row g-2">
        <div class="col-md-3">
            <select name="status" class="form-control">
                <option value="">All Status</option>
                <option value="Pending" selected="@(ViewBag.SelectedStatus == "Pending")">Pending</option>
                <option value="Processing" selected="@(ViewBag.SelectedStatus == "Processing")">Processing</option>
                <option value="Shipped" selected="@(ViewBag.SelectedStatus == "Shipped")">Shipped</option>
                <option value="Delivered" selected="@(ViewBag.SelectedStatus == "Delivered")">Delivered</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-secondary w-100">Filter</button>
        </div>
    </form>
</div>

<div class="page-card p-3">
    <table class="table table-hover table-bordered align-middle ">
        <thead style="background:#532374; color:#fff;">
            <tr>
                <th>ID</th>
                <th>Order Id</th>
                <th>Customer</th>
                <th>Total</th>
                <th>Status</th>
                <th>Created</th>
                <th style="width:140px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                var i = 1;
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted">No orders found.</td></tr>
            }
            else
            {
                foreach (var o in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@o.OrderId</td>
                        <td>@o.CustomerName</td>
                        <td><span class="fw-bold">৳@o.TotalAmount</span></td>
                        <td>
                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@o.OrderId" />
                                <select name="newStatus" onchange="this.form.submit()" class="form-select form-select-sm fw-bold @(o.OrderStatus == "Delivered" ? "text-success" : (o.OrderStatus == "Cancelled" ? "text-danger" : "text-primary"))" style="min-width: 110px;">
                                    <option value="Pending" selected="@(o.OrderStatus == "Pending")">Pending</option>
                                    <option value="Processing" selected="@(o.OrderStatus == "Processing")">Processing</option>
                                    <option value="Shipped" selected="@(o.OrderStatus == "Shipped")">Shipped</option>
                                    <option value="Delivered" selected="@(o.OrderStatus == "Delivered")">Delivered</option>
                                    <option value="Cancelled" selected="@(o.OrderStatus == "Cancelled")">Cancelled</option>
                                </select>
                            </form>
                        </td>
                        <td>@o.CreatedAt.ToLocalTime().ToString("dd-MM-yyyy, hh:mm tt")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="/EmployeeOrder/Details/@o.OrderId" class="btn btn-sm btn-outline-info">View</a>
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="this.parentElement.parentElement.previousElementSibling.previousElementSibling.querySelector('select').focus()">Edit</button>
                            </div>
                        </td>
                    </tr>
                    i++;
                }
            }
        </tbody>
    </table>
</div>
