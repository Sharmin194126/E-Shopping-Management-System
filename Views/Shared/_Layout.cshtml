@using Microsoft.AspNetCore.Identity
@inject UserManager<E_ShoppingManagement.Models.Users> UserManager
@{
    int newCount = 0;
    string notificationLink = "/Home/Notifications";
    string userRole = "";
    
    if (User.Identity.IsAuthenticated)
    {
        var db = Context.RequestServices.GetRequiredService<E_ShoppingManagement.Data.AppDbContext>();
        var loggedInUser = await UserManager.GetUserAsync(User);
        var lastCheck = loggedInUser?.LastNotificationCheck ?? DateTime.MinValue;
        userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
        var userId = UserManager.GetUserId(User);

        if (userRole == "Admin") {
            newCount = db.Orders.Count(o => o.OrderStatus == "Pending" && o.CreatedAt > lastCheck) +
                       db.Employees.Count(e => e.Status == "Pending" && e.CreatedAt > lastCheck) +
                       db.ContactMessages.Count(m => m.Status != "Replied" && m.CreatedAt > lastCheck);
            notificationLink = "/AdminDashboard/Notifications";
        } else if (userRole == "Employee") {
            var emp = db.Employees.FirstOrDefault(e => e.UserId == userId);
            var empId = emp?.Id ?? 0;
            newCount = db.Orders.Count(o => o.AssignedEmployeeId == empId && o.OrderStatus == "Pending" && o.CreatedAt > lastCheck) +
                       db.ContactMessages.Count(m => m.Status != "Replied" && m.CreatedAt > lastCheck);
            notificationLink = "/EmployeeDashboard/Notifications";
        } else if (userRole == "Customer") {
            var cust = db.Customers.FirstOrDefault(c => c.UserId == userId);
            var custId = cust?.Id ?? 0;
            newCount = db.Orders.Count(o => o.CustomerId == custId && (o.CreatedAt > lastCheck || o.ModifiedAt > lastCheck) && o.OrderStatus != "Pending");
            notificationLink = "/Home/Notifications";
        } else if (userRole == "DeliveryMan") {
            notificationLink = "/DeliveryManDashboard/Notifications";
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E_ShoppingManagement</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_ShoppingManagement.styles.css" asp-append-version="true" />
    <style>
        /* GLOBAL THEME SYNC */
        body, .admin-main, .dm-main, .main-content, .admin-content, .dm-content {
            background-color: #f8f6f0 !important;
            background: #f8f6f0 !important;
        }
        .page-card, .card, .table-container, .table, .modal-content, .list-group-item, .dropdown-menu {
            background-color: #f2efe9 !important;
            background: #f2efe9 !important;
        }
        /* Ensure no white background in any container */
        .container, .container-fluid {
            background-color: transparent !important;
        }
    </style>
</head>
<body>
    <header class="shoegee-header">
        <div class="shoegee-topbar">
            <div class="container-fluid d-flex justify-content-between align-items-center px-4 py-3">
                
                <div class="topbar-left d-flex align-items-center gap-3" style="width: 280px;">
                    <!-- Digital Clock Widget -->
                    <div id="digital-clock-widget" class="digital-clock-widget">
                        <div id="clock-day" class="clock-day"></div>
                        <div id="clock-date" class="clock-date"></div>
                        <div id="clock-time" class="clock-time"></div>
                    </div>
                    <a href="#" onclick="document.getElementById('searchForm').classList.toggle('d-none'); return false;" class="topbar-link">Search</a>
                    <form id="searchForm" class="d-none position-absolute mt-2" asp-controller="Home" asp-action="Search" method="get" style="z-index: 1000; display:flex;">
                        <input class="form-control form-control-sm me-1 border-0" type="search" name="query" placeholder="Type to search..." style="border-radius:20px; width: 180px; padding-left: 15px;">
                        <button class="btn btn-sm" type="submit" style="background: #e5e2db; color: #3c3935; border-radius:20px; padding: 0 15px;">Go</button>
                    </form>
                </div>
                
                <div class="topbar-center text-center flex-grow-1">
                    <a href="/Home/Index" class="text-decoration-none">
                        <h2 class="shoegee-brand mb-0">E-Shop</h2>
                    </a>
                </div>

                <div class="topbar-right d-flex justify-content-end align-items-center gap-4" style="width: 280px;">
                    <a href="#" onclick="document.getElementById('searchForm').classList.toggle('d-none'); return false;" class="topbar-link"><i class="bi bi-search" style="font-size: 1.1rem;"></i></a>
                    
                    @if (User.Identity.IsAuthenticated)
                    {
                        <!-- Notification Button -->
                        <div class="me-1">
                            <a href="@notificationLink" class="topbar-link position-relative text-decoration-none" title="View Notifications">
                                <i class="bi bi-bell-fill" style="font-size: 1.2rem; color: #532374; transition: color 0.3s ease;"></i>
                                @if (newCount > 0) {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem;">
                                        @newCount
                                    </span>
                                }
                            </a>
                        </div>
                        <div class="cart-wrapper">
                            @await Component.InvokeAsync("CartSummary")
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline m-0 p-0">
                            <button type="submit" class="btn btn-link topbar-link p-0 text-decoration-none border-0" style="font-size: 14px;">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a class="topbar-link" asp-controller="Account" asp-action="Login">Login</a>
                        <span class="text-white mx-2">|</span>
                        <a class="topbar-link fw-bold text-white text-decoration-none" asp-controller="Account" asp-action="Register">Sign Up</a>
                    }
                </div>
                
            </div>
        </div>

        <div class="shoegee-nav-container">
            <nav class="shoegee-pill-nav">
                <ul class="d-flex list-unstyled mb-0 gap-5 justify-content-center w-100">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Home" asp-action="CategoryProducts" asp-route-typeId="">Categories</a></li>
                    <li><a asp-controller="Home" asp-action="Deals">Deals</a></li>
                    <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                    
                    @if (User.IsInRole("Admin")) { <li><a asp-controller="AdminDashboard" asp-action="Index">Dashboard</a></li> }
                    else if (User.IsInRole("Employee")) { <li><a asp-controller="EmployeeDashboard" asp-action="Index">Dashboard</a></li> }
                    else if (User.IsInRole("DeliveryMan")) { <li><a asp-controller="DeliveryManDashboard" asp-action="Index">Dashboard</a></li> }
                    else if (User.Identity.IsAuthenticated) { <li><a asp-controller="CustomerDashboard" asp-action="Index">Dashboard</a></li> }
                </ul>
            </nav>
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @await Component.InvokeAsync("Footer")
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function updateClock() {
            const now = new Date();
            const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
            const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

            const dayEl   = document.getElementById('clock-day');
            const dateEl  = document.getElementById('clock-date');
            const timeEl  = document.getElementById('clock-time');

            if (!dayEl) return;

            // Day
            dayEl.textContent = dayNames[now.getDay()];

            // Date
            const dd  = String(now.getDate()).padStart(2,'0');
            const mon = monthNames[now.getMonth()];
            const yr  = now.getFullYear();
            dateEl.textContent = `${dd} ${mon} ${yr}`;

            // Time
            let h   = now.getHours();
            const m = String(now.getMinutes()).padStart(2,'0');
            const s = String(now.getSeconds()).padStart(2,'0');
            const ampm = h >= 12 ? 'PM' : 'AM';
            h = h % 12 || 12;
            timeEl.textContent = `${String(h).padStart(2,'0')}:${m}:${s} ${ampm}`;
        }
        setInterval(updateClock, 1000);
        updateClock();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
