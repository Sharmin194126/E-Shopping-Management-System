@model E_ShoppingManagement.ViewComponents.FooterViewModel

@{
    string RenderStars(double rating) {
        int fullStars = (int)rating;
        string stars = "";
        for(int i=0; i<fullStars; i++) stars += "★";
        for(int i=fullStars; i<5; i++) stars += "☆";
        return stars;
    }
}

<footer class="home-footer d-print-none">
    <div class="container">
        <div class="footer-top row g-4">
            <!-- Brand & Payments -->
            <div class="col-md-3">
                <h4 class="brand-text" style="font-family: 'French Script MT', cursive; color: #FF6B35; font-size: 2rem;">E-Shop</h4>
                <p class="small" style="color: #FFD700;">Direct Merchant Payments for Secure Shopping.</p>
                
                <div class="mt-4">
                    <h6 class="small fw-bold text-uppercase mb-2" style="color: #FFD700;">Secure Payments</h6>
                    <div class="footer-payments d-flex flex-wrap gap-2">
                        @if (Model.PaymentMethods != null)
                        {
                            foreach (var pm in Model.PaymentMethods)
                            {
                                <div class="payment-icon" title="@pm.Name">
                                    @if(!string.IsNullOrEmpty(pm.LogoUrl)) {
                                        <img src="@pm.LogoUrl" alt="@pm.Name" style="height: 30px; object-fit: contain;">
                                    } else {
                                        <span class="badge border text-dark">@pm.Name</span>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Links -->
            <div class="col-md-3">
                <h5>Help & Services</h5>
                <ul class="list-unstyled mt-3 footer-nav-links">
                    <li><a asp-controller="Home" asp-action="HelpCenter">Help Center</a></li>
                    <li><a asp-controller="Home" asp-action="Returns">Returns & Refunds</a></li>
                    <li><a asp-controller="Home" asp-action="Tracking">Track Your Order</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="col-md-6">
                <h5>Address & Contact</h5>
                <div class="mt-3">
                    <p class="mb-1"><strong>@Model.Info.Address</strong></p>
                    <div class="d-flex flex-column gap-1">
                        <span class="small fw-semibold" style="color: #FFD700;">Email: @Model.Info.Email</span>
                        <span class="small fw-semibold" style="color: #FFD700;">Phone: @Model.Info.ContactNumber</span>
                    </div>
                    <div class="social-links mt-3">
                        @if (!string.IsNullOrEmpty(Model.Info.FacebookUrl)) { <a href="@Model.Info.FacebookUrl" class="btn btn-sm btn-outline-primary rounded-circle">FB</a> }
                        @if (!string.IsNullOrEmpty(Model.Info.InstagramUrl)) { <a href="@Model.Info.InstagramUrl" class="btn btn-sm btn-outline-danger rounded-circle ms-2">IG</a> }
                    </div>
                </div>
            </div>
        </div>

        <!-- Reviews -->
        @if (Model.RecentReviews.Any())
        {
            <hr class="my-5 border-secondary">
            <h5 class="text-center mb-4">What Our Customers Say</h5>
            <div class="reviews row g-3">
                @foreach (var r in Model.RecentReviews)
                {
                    <div class="col-md-3 mb-4">
                        <div class="review-box h-100">
                            <div class="review-head d-flex align-items-center mb-1">
                                <strong class="small" style="color: #000000 !important; font-weight: 700; font-size: 0.85rem;">@r.CustomerName</strong>
                            </div>
                            <div class="rating text-warning mb-1" style="font-size: 0.7rem;">@RenderStars(r.Rating)</div>
                            <p class="small text-muted mb-0" style="font-size: 0.8rem; line-height: 1.4; color: #333 !important;">"@r.Comment"</p>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</footer>

<style>
    .home-footer {
        background-color: #532374;
        color: #e5e2db;
        padding: 60px 0 60px 10%; /* Shifted right by increasing left padding */
    }
    .payment-badge {
        background: rgba(255,255,255,0.1);
        padding: 5px 12px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid rgba(255,255,255,0.2);
        color: #e5e2db;
    }
    .payment-badge img { height: 20px; filter: brightness(0) invert(1); }
    .footer-nav-links a { display: block; margin-bottom: 8px; color: #e5e2db; }
    .footer-nav-links a:hover { color: #ffffff; text-decoration: underline; }
    .review-box {
        background: #fdfdfd;
        padding: 10px 15px;
        border-radius: 12px;
        border: 1px solid #eeeeee;
        box-shadow: 0 1px 4px rgba(0,0,0,0.01);
    }
</style>
