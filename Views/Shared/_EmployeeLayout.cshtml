<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Employee</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Admin CSS (reuse same styles) -->
    <link href="~/css/admin.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        /* GLOBAL THEME SYNC */
        body, .admin-main, .dm-main, .main-content, .admin-content, .dm-content {
            background-color: #f8f6f0 !important;
            background: #f8f6f0 !important;
        }
        .page-card, .card, .table-container, .table, .modal-content, .list-group-item, .dropdown-menu {
            background-color: #f2efe9 !important;
            background: #f2efe9 !important;
        }
        /* Ensure no white background in any container */
        .container, .container-fluid {
            background-color: transparent !important;
        }

        /* Sidebar link text color white */
        .admin-sidebar a {
            color: #ffffff !important;
        }
        .admin-sidebar a:hover {
            background: rgba(255, 255, 255, 0.15) !important;
            color: #ffffff !important;
        }
        .admin-sidebar a.active {
            background: rgba(255, 255, 255, 0.25) !important;
            border-left: 4px solid #fff;
            color: #ffffff !important;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <h4 class="text-center py-3">EMPLOYEE</h4>
            <a asp-controller="Home" asp-action="Index" style="background-color: #532374 !important; border: 1px solid #fff; border-radius: 8px;">
                <i class="bi bi-box-arrow-left me-2"></i>Back to Website
            </a>

            <a asp-controller="EmployeeDashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeDashboard" ? "active" : "")">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
            
            <p class="menu-title">PRODUCTS & TYPES</p>
            <a asp-controller="EmployeeProduct" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeProduct" ? "active" : "")">
                <i class="bi bi-box-seam me-2"></i>Manage Products
            </a>
            <a asp-controller="ProductType" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductType" ? "active" : "")">
                <i class="bi bi-collection me-2"></i>Product Types
            </a>

            <p class="menu-title">ORDERS & LOGISTICS</p>
            <a asp-controller="EmployeeOrder" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeOrder" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-cart-check me-2"></i>Manage Orders
            </a>
            <a asp-controller="EmployeeOrder" asp-action="Pending" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeOrder" && ViewContext.RouteData.Values["Action"]?.ToString() == "Pending" ? "active" : "")">
                <i class="bi bi-hourglass-split me-2"></i>Pending Orders
            </a>
            <a asp-controller="DeliveryMan" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "DeliveryMan" ? "active" : "")">
                <i class="bi bi-truck me-2"></i>Delivery Personnel
            </a>
            <a asp-controller="Customer" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customer" ? "active" : "")">
                <i class="bi bi-people me-2"></i>Manage Customers
            </a>

            <p class="menu-title">PERSONAL</p>
            <a asp-controller="EmployeeOrder" asp-action="MySales" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "MySales" ? "active" : "")">
                <i class="bi bi-graph-up-arrow me-2"></i>My Sales Performance
            </a>

            <p class="menu-title">SYSTEM</p>
            <a asp-controller="AdminDashboard" asp-action="Messages" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Messages" ? "active" : "")">
                <i class="bi bi-envelope me-2"></i>Messages
            </a>
        </aside>

        <!-- MAIN -->
        <main class="admin-main">

            <!-- HEADER -->
            <header class="admin-header">
                <form asp-controller="EmployeeOrder" asp-action="Index" method="get" class="search-box">
                    <input type="text" name="query" placeholder="Search orders..." />
                    <button type="submit">🔍</button>
                </form>
            </header>

            <!-- PAGE CONTENT -->
            <section class="admin-content">
                @RenderBody()
            </section>

            @RenderSection("Scripts", required: false)

        </main>

    </div>

</body>
</html>

