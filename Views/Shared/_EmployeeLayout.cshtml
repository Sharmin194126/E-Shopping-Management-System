@using Microsoft.AspNetCore.Identity
@inject UserManager<E_ShoppingManagement.Models.Users> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Employee</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Admin CSS -->
    <link href="~/css/admin.css" rel="stylesheet" />
    <style>
        /* GLOBAL THEME SYNC */
        body, .admin-main, .dm-main, .main-content, .admin-content, .dm-content {
            background-color: #f8f6f0 !important;
            background: #f8f6f0 !important;
        }
        .page-card, .card, .table-container, .table, .modal-content, .list-group-item, .dropdown-menu {
            background-color: #f2efe9 !important;
            background: #f2efe9 !important;
        }
        /* Ensure no white background in any container */
        .container, .container-fluid {
            background-color: transparent !important;
        }

        /* Sidebar link text color white */
        .admin-sidebar a {
            color: #ffffff !important;
        }
        .admin-sidebar a:hover {
            background: rgba(255, 255, 255, 0.15) !important;
            color: #ffffff !important;
        }
        .admin-sidebar a.active {
            background: rgba(255, 255, 255, 0.25) !important;
            border-left: 4px solid #fff;
            color: #ffffff !important;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <!-- Brand & Profile Section -->
            @{
                var curUserLayout = await UserManager.GetUserAsync(User);
            }
            <div class="px-3 py-4 text-center border-bottom border-white border-opacity-10 mb-3">
                <div class="rounded-circle bg-white bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2" style="width: 64px; height: 64px; border: 2px solid rgba(255,255,255,0.25); box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                    <i class="bi bi-person-workspace text-white" style="font-size: 1.8rem;"></i>
                </div>
                <div class="text-white fw-bold px-2" style="font-size: 0.95rem; letter-spacing: 0.3px;">@(curUserLayout?.FullName ?? "Employee")</div>
                <div class="text-white text-opacity-75 small" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">Store Employee</div>
            </div>
            
            <a asp-controller="Home" asp-action="Index">
                <i class="bi bi-box-arrow-left me-2"></i>Back to Website
            </a>
            
            <a asp-controller="EmployeeDashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeDashboard" ? "active" : "")">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>

            <p class="menu-title">PRODUCTS & TYPES</p>
            <a asp-controller="EmployeeProduct" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeProduct" ? "active" : "")">
                <i class="bi bi-box-seam me-2"></i>Manage Products
            </a>
            <a asp-controller="ProductType" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductType" ? "active" : "")">
                <i class="bi bi-collection me-2"></i>Product Types
            </a>

            <p class="menu-title">ORDERS & LOGISTICS</p>
            <a asp-controller="EmployeeOrder" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeOrder" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-cart-check me-2"></i>Manage Orders
            </a>
            <a asp-controller="EmployeeOrder" asp-action="Pending" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeOrder" && ViewContext.RouteData.Values["Action"]?.ToString() == "Pending" ? "active" : "")">
                <i class="bi bi-hourglass-split me-2"></i>Pending Orders
            </a>
            <a asp-controller="DeliveryMan" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "DeliveryMan" ? "active" : "")">
                <i class="bi bi-truck me-2"></i>Delivery Personnel
            </a>
            <a asp-controller="EmployeeDashboard" asp-action="Messages" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Messages" ? "active" : "")">
                <i class="bi bi-chat-dots me-2"></i>Customer Messages
            </a>
            <a asp-controller="EmployeeDashboard" asp-action="Emails" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Emails" ? "active" : "")">
                <i class="bi bi-envelope me-2"></i>Customer Emails
            </a>
            <a asp-controller="EmployeeDashboard" asp-action="Profile" class="fw-bold text-warning @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                <i class="bi bi-person-circle me-2"></i>My Profile
            </a>

            <p class="menu-title">TRACKING</p>
            <a asp-controller="Home" asp-action="Tracking" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Tracking" ? "active" : "")">
                <i class="bi bi-geo-alt me-2"></i>Track Customer Order
            </a>

            <!-- Logout -->
            <div class="mt-auto px-3 pb-3 pt-4 border-top border-white border-opacity-10" style="margin-top: 20px;">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center gap-2" style="background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.30); color: #fca5a5; font-weight: 600; padding: 10px 16px; border-radius: 8px;">
                        <i class="bi bi-box-arrow-right"></i>
                        Logout
                    </button>
                </form>
            </div>
        </aside>

        <!-- MAIN -->
        <main class="admin-main">

            <header class="admin-header d-flex justify-content-between align-items-center px-4 py-3" style="background:#fff; border-bottom:1px solid #e6e2db;">
                <div class="header-search flex-grow-1 me-4">
                    <form asp-controller="EmployeeProduct" asp-action="Index" method="get" class="position-relative">
                        <input type="text" name="query" placeholder="Search products, orders..." class="form-control" style="border-radius:10px; padding-left:45px; background: #f8f6f0; border: 1px solid #e6e2db; height: 45px;" />
                        <i class="bi bi-search position-absolute" style="left: 15px; top: 50%; transform: translateY(-50%); color: #532374; font-size: 1.1rem;"></i>
                    </form>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <!-- Notification Button -->
                    @{
                        var db = Context.RequestServices.GetRequiredService<E_ShoppingManagement.Data.AppDbContext>();
                        var loggedInUser = await UserManager.GetUserAsync(User);
                        var lastCheck = loggedInUser?.LastNotificationCheck ?? DateTime.MinValue;

                        var employee = db.Employees.FirstOrDefault(e => e.UserId == loggedInUser.Id);
                        var empId = employee?.Id ?? 0;

                        var pendingOrders = db.Orders.Where(o => o.AssignedEmployeeId == empId && o.OrderStatus == "Pending").ToList();
                        var activeMsgs = db.ContactMessages.Where(m => m.Status != "Replied").ToList();

                        var newOrdersCount = pendingOrders.Count(o => o.CreatedAt > lastCheck);
                        var newMsgsCount = activeMsgs.Count(m => m.CreatedAt > lastCheck);
                        
                        var totalNewNotifs = newOrdersCount + newMsgsCount;
                        var totalItems = pendingOrders.Count + activeMsgs.Count;
                    }
                    <div class="dropdown">
                        <a asp-controller="EmployeeDashboard" asp-action="Notifications" class="position-relative text-decoration-none" title="View Notifications">
                            <i class="bi bi-bell-fill" style="font-size: 1.3rem; color: #532374;"></i>
                            @{
                                var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                             }
                            @if (totalNewNotifs > 0 && currentAction != "Notifications") {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.65rem; border: 2px solid #fff;">
                                    @totalNewNotifs
                                </span>
                            }
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="employeeNotificationDropdown" style="width: 300px; border-radius: 12px; background: #fff !important;">
                            <li><h6 class="dropdown-header fw-bold" style="background:#532374; color:#fff; border-radius: 12px 12px 0 0; margin-top:-8px; padding:12px 15px;">Notifications</h6></li>
                            
                            @if (pendingOrders.Any()) {
                                <li>
                                    <a class="dropdown-item py-2 border-bottom" asp-controller="EmployeeOrder" asp-action="Pending">
                                        <div class="d-flex gap-2">
                                            <i class="bi bi-cart-plus text-primary"></i>
                                            <div>
                                                <span class="fw-bold">@pendingOrders.Count Pending Orders</span>
                                                <small class="text-muted d-block">Assigned to you</small>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                            }
                            @if (activeMsgs.Any()) {
                                <li>
                                    <a class="dropdown-item py-2 border-bottom" asp-controller="EmployeeDashboard" asp-action="Messages">
                                        <div class="d-flex gap-2">
                                            <i class="bi bi-envelope text-info"></i>
                                            <div>
                                                <span class="fw-bold">@activeMsgs.Count New Messages</span>
                                                <small class="text-muted d-block">Customer inquiries</small>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                            }

                            @if (totalItems == 0) {
                                <li><div class="dropdown-item py-3 text-center text-muted">No new notifications</div></li>
                            }

                            <li><hr class="dropdown-divider m-0"></li>
                            <li><a class="dropdown-item text-center fw-bold py-2" style="color:#532374; font-size:13px;" asp-controller="EmployeeDashboard" asp-action="Notifications">View All Notifications</a></li>
                        </ul>
                    </div>
                    <!-- Profile Icon -->
                    <a asp-controller="EmployeeDashboard" asp-action="Profile" class="d-flex align-items-center gap-2 text-decoration-none" title="My Profile">
                        <i class="bi bi-person-circle" style="font-size: 1.8rem; color: #532374;"></i>
                    </a>
                </div>
            </header>

            <!-- PAGE CONTENT -->
            <section class="admin-content">
                @RenderBody()
            </section>

            @RenderSection("Scripts", required: false)

        </main>

    </div>

</body>
</html>
