<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Employee</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Admin CSS (reuse same styles) -->
    <link href="~/css/admin.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        /* GLOBAL THEME SYNC */
        body, .admin-main, .dm-main, .main-content, .admin-content, .dm-content {
            background-color: #f8f6f0 !important;
            background: #f8f6f0 !important;
        }
        .page-card, .card, .table-container, .table, .modal-content, .list-group-item, .dropdown-menu {
            background-color: #f2efe9 !important;
            background: #f2efe9 !important;
        }
        /* Ensure no white background in any container */
        .container, .container-fluid {
            background-color: transparent !important;
        }

        /* Sidebar link text color white */
        .admin-sidebar a {
            color: #ffffff !important;
        }
        .admin-sidebar a:hover {
            background: rgba(255, 255, 255, 0.15) !important;
            color: #ffffff !important;
        }
        .admin-sidebar a.active {
            background: rgba(255, 255, 255, 0.25) !important;
            border-left: 4px solid #fff;
            color: #ffffff !important;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <h4 class="text-center py-3">EMPLOYEE</h4>
            <a asp-controller="Home" asp-action="Index" style="background-color: #532374 !important; border: 1px solid #fff; border-radius: 8px;">
                <i class="bi bi-box-arrow-left me-2"></i>Back to Website
            </a>

            <a asp-controller="EmployeeDashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeDashboard" ? "active" : "")">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
            
            <p class="menu-title">PRODUCTS & TYPES</p>
            <a asp-controller="EmployeeProduct" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeProduct" ? "active" : "")">
                <i class="bi bi-box-seam me-2"></i>Manage Products
            </a>
            <a asp-controller="ProductType" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductType" ? "active" : "")">
                <i class="bi bi-collection me-2"></i>Product Types
            </a>

            <p class="menu-title">ORDERS & LOGISTICS</p>
            <a asp-controller="EmployeeOrder" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeOrder" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-cart-check me-2"></i>Manage Orders
            </a>
            <a asp-controller="EmployeeOrder" asp-action="Pending" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EmployeeOrder" && ViewContext.RouteData.Values["Action"]?.ToString() == "Pending" ? "active" : "")">
                <i class="bi bi-hourglass-split me-2"></i>Pending Orders
            </a>
            <a asp-controller="DeliveryMan" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "DeliveryMan" ? "active" : "")">
                <i class="bi bi-truck me-2"></i>Delivery Personnel
            </a>
            <a asp-controller="Customer" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customer" ? "active" : "")">
                <i class="bi bi-people me-2"></i>Manage Customers
            </a>

            <p class="menu-title">PERSONAL</p>
            <a asp-controller="EmployeeOrder" asp-action="MySales" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "MySales" ? "active" : "")">
                <i class="bi bi-graph-up-arrow me-2"></i>My Sales Performance
            </a>

            <p class="menu-title">SYSTEM</p>
            <a asp-controller="AdminDashboard" asp-action="Messages" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Messages" ? "active" : "")">
                <i class="bi bi-envelope me-2"></i>Messages
            </a>
            <p class="menu-title">TRACKING</p>
            <a asp-controller="Home" asp-action="Tracking" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Tracking" ? "active" : "")">
                <i class="bi bi-geo-alt me-2"></i>Track Customer Order
            </a>
        </aside>

        <!-- MAIN -->
        <main class="admin-main">
            <!-- HEADER -->
            <header class="admin-header d-flex justify-content-between align-items-center px-4 py-3" style="background:#fff; border-bottom:1px solid #e6e2db;">
                 <div class="header-search flex-grow-1 me-4">
                    <form asp-controller="EmployeeOrder" asp-action="Index" method="get" class="position-relative">
                        <input type="text" name="query" placeholder="Search orders, customers..." class="form-control" style="border-radius:10px; padding-left:45px; background: #f8f6f0; border: 1px solid #e6e2db; height: 45px;" />
                        <i class="bi bi-search position-absolute" style="left: 15px; top: 50%; transform: translateY(-50%); color: #532374; font-size: 1.1rem;"></i>
                    </form>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <!-- Notification Button -->
                    <div class="dropdown">
                        <a href="#" class="position-relative text-decoration-none" id="employeeNotificationDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-bell-fill" style="font-size: 1.3rem; color: #532374;"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.65rem; border: 2px solid #fff;">
                                2
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="employeeNotificationDropdown" style="width: 300px; border-radius: 12px; background: #fff !important;">
                            <li><h6 class="dropdown-header fw-bold" style="background:#532374; color:#fff; border-radius: 12px 12px 0 0; margin-top:-8px; padding:12px 15px;">Notifications</h6></li>
                            <li><a class="dropdown-item py-3 border-bottom" href="#"><div class="d-flex gap-2"><i class="bi bi-cart-plus text-primary"></i><div><small class="text-muted d-block">Just now</small>New order assigned to you.</div></div></a></li>
                            <li><a class="dropdown-item py-3 border-bottom" href="#"><div class="d-flex gap-2"><i class="bi bi-box-seam text-warning"></i><div><small class="text-muted d-block">2 hrs ago</small>Product stock is low.</div></div></a></li>
                            <li><hr class="dropdown-divider m-0"></li>
                            <li><a class="dropdown-item text-center fw-bold py-2" style="color:#532374; font-size:13px;" asp-controller="EmployeeDashboard" asp-action="Notifications">View All Notifications</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- PAGE CONTENT -->
            <section class="admin-content">
                @RenderBody()
            </section>

            @RenderSection("Scripts", required: false)

        </main>

    </div>

    <!-- Bootstrap JS (Required for Dropdowns, Modals, etc.) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
