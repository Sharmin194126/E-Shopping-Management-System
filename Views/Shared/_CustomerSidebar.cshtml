@using Microsoft.AspNetCore.Identity
@inject UserManager<E_ShoppingManagement.Models.Users> userMgr
@{
    var dbContext = Context.RequestServices.GetRequiredService<E_ShoppingManagement.Data.AppDbContext>();
    var userObj = await userMgr.GetUserAsync(User);
    var lastCheckTime = userObj?.LastNotificationCheck ?? DateTime.MinValue;
    var userIdForCust = userObj?.Id;
    var customerObj = dbContext.Customers.FirstOrDefault(c => c.UserId == userIdForCust);
    var newNotifCount = customerObj != null ? dbContext.Orders.Count(o => o.CustomerId == customerObj.Id && o.CreatedAt > lastCheckTime && o.OrderStatus != "Pending") : 0;
    var activePage = ViewData["ActivePage"]?.ToString() ?? "";
}

<div class="card shadow-sm mb-4 border-0" style="border-radius: 12px;">
    <div class="card-body text-center position-relative" style="border-radius: 12px 12px 0 0; overflow: hidden; padding-top: 40px; background: #fff; border-bottom: 1px solid #f1f5f9;">
        <!-- Background Cover -->
        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 80px; background: linear-gradient(135deg, #532374, #8b5cf6);"></div>
        <img src="@(string.IsNullOrEmpty(customerObj?.ProfilePictureUrl) ? "/images/user-avatar.png" : customerObj.ProfilePictureUrl)" class="rounded-circle mb-2 shadow position-relative" style="width: 100px; height: 100px; object-fit: cover; border: 4px solid #fff; background: #fff; z-index: 2;" onerror="this.src='/images/user-avatar.png'" />
        <h5 class="fw-bold mb-1" style="color: #33312e; position: relative; z-index: 2;">@(customerObj?.Name ?? Localizer["Customer"])</h5>
        <p class="text-muted small mb-0 position-relative" style="z-index: 2;"><i class="bi bi-patch-check-fill text-success me-1"></i>@Localizer["Verified Customer"]</p>
    </div>
    <div class="list-group list-group-flush customer-sidebar">
        <style>
            .customer-sidebar .list-group-item.active {
                background-color: #f8f6f0 !important;
                border-color: #532374 !important;
                border-left: 4px solid #532374 !important;
                color: #532374 !important;
                font-weight: 700;
            }
            .customer-sidebar .list-group-item {
                padding: 14px 20px;
                transition: 0.2s ease;
                color: #475569;
                border: none;
                border-bottom: 1px solid #f1f5f9;
                border-left: 4px solid transparent;
            }
            .customer-sidebar .list-group-item:last-child {
                border-bottom: none;
            }
            .customer-sidebar .list-group-item:hover:not(.active) {
                background-color: #f8f6f0;
                color: #532374;
                border-left-color: #e6e2db;
            }
        </style>
        <a href="/CustomerDashboard" class="list-group-item list-group-item-action @(activePage == "Dashboard" ? "active" : "")"><i class="bi bi-grid-1x2 me-2"></i>@Localizer["Dashboard"]</a>
        <a href="/CustomerDashboard/Profile" class="list-group-item list-group-item-action @(activePage == "Profile" ? "active" : "")"><i class="bi bi-person me-2"></i>@Localizer["My Profile"]</a>
        <a href="/CustomerDashboard/Orders" class="list-group-item list-group-item-action @(activePage == "Orders" ? "active" : "")"><i class="bi bi-cart3 me-2"></i>@Localizer["My Orders"]</a>
        <a href="/CustomerDashboard/Notifications" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(activePage == "Notifications" ? "active" : "")">
            <span><i class="bi bi-bell me-2"></i>@Localizer["Notifications"]</span>
            @if (newNotifCount > 0)
            {
                <span class="badge rounded-pill bg-danger" style="font-size: 0.7rem;">@newNotifCount</span>
            }
        </a>
        <a href="/CustomerDashboard/Messages" class="list-group-item list-group-item-action @(activePage == "Messages" ? "active" : "")"><i class="bi bi-chat-dots me-2"></i>@Localizer["Messages"]</a>
        <a href="/Cart" class="list-group-item list-group-item-action"><i class="bi bi-bag me-2"></i>@Localizer["My Cart"]</a>
        <a href="/Home/Tracking" class="list-group-item list-group-item-action text-primary"><i class="bi bi-geo-alt me-2"></i>@Localizer["Track Order"]</a>
        <form asp-controller="Account" asp-action="Logout" method="post" class="mt-3 px-3 pb-3">
            <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center gap-2" style="background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.30); color: #ef4444; font-weight: 600; padding: 10px 16px; border-radius: 8px; transition: all 0.2s;">
                <i class="bi bi-box-arrow-right"></i> @Localizer["Logout"]
            </button>
        </form>
    </div>
</div>
