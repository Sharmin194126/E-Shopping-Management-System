<style>
    .emoji-item {
        cursor: pointer;
        font-size: 1.5rem;
        padding: 5px;
        display: inline-block;
        transition: transform 0.1s;
        width: 40px;
        text-align: center;
    }
    .emoji-item:hover { transform: scale(1.2); background: #f0f0f0; border-radius: 5px; }
    .emoji-tabs .btn.active { background: #532374; color: #fff; }
</style>

<script>
    function switchEmojiTab(btn, tabId) {
        const picker = btn.closest('.emoji-picker');
        picker.querySelectorAll('.emoji-tab-pane').forEach(p => p.style.display = 'none');
        picker.querySelector('#' + tabId).style.display = 'block';
        picker.querySelectorAll('.emoji-tabs .btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }

    function selectEmoji(span) {
        const emoji = span.innerText;
        const picker = document.getElementById('emojiPickerTemplate');
        const targetId = picker.dataset.targetId;
        if(targetId) {
            const area = document.getElementById(targetId);
            if(area) {
                const start = area.selectionStart || 0;
                const end = area.selectionEnd || 0;
                area.value = area.value.substring(0, start) + emoji + area.value.substring(end);
                area.focus();
                
                // Trigger input event if it exists (for toggling send buttons etc)
                area.dispatchEvent(new Event('input', { bubbles: true }));
            }
            picker.style.display = 'none';
        }
    }

    
