            <button type="button" class="btn btn-sm btn-light flex-grow-1" onclick="switchEmojiTab(this, 'nature')">🌿</button>
            <button type="button" class="btn btn-sm btn-light flex-grow-1" onclick="switchEmojiTab(this, 'food')">🍕</button>
            <button type="button" class="btn btn-sm btn-light flex-grow-1" onclick="switchEmojiTab(this, 'activities')">⚽</button>
            <button type="button" class="btn btn-sm btn-light flex-grow-1" onclick="switchEmojiTab(this, 'objects')">💡</button>
            <button type="button" class="btn btn-sm btn-light flex-grow-1" onclick="switchEmojiTab(this, 'symbols')">❤️</button>
        </div>
