<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Admin CSS -->
    <link href="~/css/admin.css" rel="stylesheet" />
    <style>
        /* GLOBAL THEME SYNC */
        body, .admin-main, .dm-main, .main-content, .admin-content, .dm-content {
            background-color: #f8f6f0 !important;
            background: #f8f6f0 !important;
        }
        .page-card, .card, .table-container, .table, .modal-content, .list-group-item, .dropdown-menu {
            background-color: #f2efe9 !important;
            background: #f2efe9 !important;
        }
        /* Ensure no white background in any container */
        .container, .container-fluid {
            background-color: transparent !important;
        }

        /* Sidebar link text color white */
        .admin-sidebar a {
            color: #ffffff !important;
        }
        .admin-sidebar a:hover {
            background: rgba(255, 255, 255, 0.15) !important;
            color: #ffffff !important;
        }
        .admin-sidebar a.active {
            background: rgba(255, 255, 255, 0.25) !important;
            border-left: 4px solid #fff;
            color: #ffffff !important;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <h4 class="text-center py-3">ADMIN</h4>
            <div class="px-3 mb-3">
                <a asp-controller="Home" asp-action="Index" class="theme-back-btn w-100 justify-content-center" style="margin-bottom:0; color: #532374 !important;">
                    <i class="bi bi-arrow-left"></i> Back to Website
                </a>
            </div>
            
            <a asp-controller="AdminDashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminDashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>

            <p class="menu-title">CATEGORY</p>
            <a asp-controller="Category" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")">
                <i class="bi bi-tags me-2"></i>Categories
            </a>
            <a asp-controller="Product" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")">
                <i class="bi bi-box-seam me-2"></i>Products
            </a>
            <a asp-controller="ProductType" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductType" ? "active" : "")">
                <i class="bi bi-collection me-2"></i>Product Types
            </a>
            <a asp-controller="AdminDashboard" asp-action="ManageDisplaySections" class="text-warning @(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageDisplaySections" ? "active" : "")">
                <i class="bi bi-house-gear me-2"></i>Homepage Sections
            </a>

            <p class="menu-title">SYSTEM</p>
            <a asp-controller="Customer" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customer" ? "active" : "")">
                <i class="bi bi-people me-2"></i>Manage Customer
            </a>
            <a asp-controller="Employee" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Employee" ? "active" : "")">
                <i class="bi bi-person-badge me-2"></i>Manage Employees
            </a>
            <a asp-controller="AdminCart" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminCart" ? "active" : "")">
                <i class="bi bi-cart me-2"></i>Manage Carts
            </a>
            <a asp-controller="DeliveryMan" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "DeliveryMan" ? "active" : "")">
                <i class="bi bi-truck me-2"></i>Delivery Personnel
            </a>
            <a asp-controller="AdminReport" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminReport" ? "active" : "")">
                <i class="bi bi-file-earmark-bar-graph me-2"></i>Reports
            </a>
            <a asp-controller="AdminDashboard" asp-action="ManageReviews" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageReviews" ? "active" : "")">
                <i class="bi bi-star me-2"></i>Manage Reviews
            </a>
            <a asp-controller="AdminDashboard" asp-action="Messages" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Messages" ? "active" : "")">
                <i class="bi bi-envelope me-2"></i>Messages
            </a>
            <a asp-controller="AdminDashboard" asp-action="EmployeeList" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "EmployeeList" ? "active" : "")">
                <i class="bi bi-person-lines-fill me-1"></i>Employee Products-Sales
            </a>
            <a asp-controller="AdminDashboard" asp-action="Profile" class="fw-bold text-warning @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                <i class="bi bi-person-circle me-2"></i>My Profile
            </a>
            <a asp-controller="PaymentGateway" asp-action="AdminPaymentHistory" class="text-info @(ViewContext.RouteData.Values["Action"]?.ToString() == "AdminPaymentHistory" ? "active" : "")">
                <i class="bi bi-credit-card me-2"></i>Payment History
            </a>
            <a asp-controller="Banner" asp-action="Index" class="text-success @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Banner" ? "active" : "")">
                <i class="bi bi-images me-2"></i>Manage Banners
            </a>
        </aside>

        <!-- MAIN -->
        <main class="admin-main">

            <!-- HEADER -->
            <header class="admin-header">
                <form asp-controller="Product" asp-action="Index" method="get" class="search-box">
                    <input type="text" name="query" placeholder="Search products..." />
                    <button type="submit">🔍</button>
                </form>
            </header>

            <!-- PAGE CONTENT -->
            <section class="admin-content">
                @RenderBody()
            </section>

            @RenderSection("Scripts", required: false)

        </main>

    </div>

</body>
</html>
