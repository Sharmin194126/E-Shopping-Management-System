<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Admin CSS -->
    <link href="~/css/admin.css" rel="stylesheet" />
    <style>
        /* GLOBAL THEME SYNC */
        body, .admin-main, .dm-main, .main-content, .admin-content, .dm-content {
            background-color: #f8f6f0 !important;
            background: #f8f6f0 !important;
        }
        .page-card, .card, .table-container, .table, .modal-content, .list-group-item, .dropdown-menu {
            background-color: #f2efe9 !important;
            background: #f2efe9 !important;
        }
        /* Ensure no white background in any container */
        .container, .container-fluid {
            background-color: transparent !important;
        }
    </style>
</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <h4 class="text-center py-3">ADMIN</h4>
            <div class="px-3 mb-3">
                <a asp-controller="Home" asp-action="Index" class="theme-back-btn w-100 justify-content-center" style="margin-bottom:0;">
                    <i class="bi bi-arrow-left"></i> Back to Website
                </a>
            </div>
            <a asp-controller="AdminDashboard" asp-action="Index">Dashboard</a>

            <p class="menu-title">CATEGORY</p>
            <a asp-controller="Category" asp-action="Index">Categories</a>
            <a asp-controller="Product" asp-action="Index">Products</a>
            <a asp-controller="ProductType" asp-action="Index">Product Types</a>
            <a asp-controller="AdminDashboard" asp-action="ManageDisplaySections" class="text-warning">🏠 Homepage Sections</a>

            <p class="menu-title">SYSTEM</p>
            <a asp-controller="Customer" asp-action="Index">Manage Customer</a>
            <a asp-controller="Employee" asp-action="Index">Manage Employees</a>
            <a asp-controller="AdminCart" asp-action="Index">Manage Carts</a>
            <a asp-controller="DeliveryMan" asp-action="Index">Delivery Personnel</a>
            <a asp-controller="AdminReport" asp-action="Index">Reports</a>
            <a asp-controller="AdminDashboard" asp-action="ManageReviews">⭐ Manage Reviews</a>
            <a asp-controller="AdminDashboard" asp-action="Messages">✉ Messages</a>
            <a asp-controller="AdminDashboard" asp-action="EmployeeList">👥 Employee Products & Sales</a>
            <a asp-controller="AdminDashboard" asp-action="Profile" class="fw-bold text-warning">My Profile</a>
            <a asp-controller="PaymentGateway" asp-action="AdminPaymentHistory" class="text-info">💰 Payment History</a>
            <a asp-controller="Banner" asp-action="Index" class="text-success">🖼️ Manage Banners</a>
        </aside>

        <!-- MAIN -->
        <main class="admin-main">

            <!-- HEADER -->
            <header class="admin-header">
                <form asp-controller="Product" asp-action="Index" method="get" class="search-box">
                    <input type="text" name="query" placeholder="Search products..." />
                    <button type="submit">🔍</button>
                </form>
            </header>

            <!-- PAGE CONTENT -->
            <section class="admin-content">
                @RenderBody()
            </section>

            @RenderSection("Scripts", required: false)

        </main>

    </div>

</body>
</html>

