@using Microsoft.AspNetCore.Identity
@inject UserManager<E_ShoppingManagement.Models.Users> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Admin CSS -->
    <link href="~/css/admin.css" rel="stylesheet" />
    <style>
        /* GLOBAL THEME SYNC */
        body, .admin-main, .dm-main, .main-content, .admin-content, .dm-content {
            background-color: #f8f6f0 !important;
            background: #f8f6f0 !important;
        }
        .page-card, .card, .table-container, .table, .modal-content, .list-group-item, .dropdown-menu {
            background-color: #f2efe9 !important;
            background: #f2efe9 !important;
        }
        /* Ensure no white background in any container */
        .container, .container-fluid {
            background-color: transparent !important;
        }

        /* Sidebar link text color white */
        .admin-sidebar a {
            color: #ffffff !important;
        }
        .admin-sidebar a:hover {
            background: rgba(255, 255, 255, 0.15) !important;
            color: #ffffff !important;
        }
        .admin-sidebar a.active {
            background: rgba(255, 255, 255, 0.25) !important;
            border-left: 4px solid #fff;
            color: #ffffff !important;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <h4 class="text-center py-3">ADMIN</h4>
            
            <a asp-controller="Home" asp-action="Index">
                <i class="bi bi-box-arrow-left me-2"></i>Back to Website
            </a>
            
            <a asp-controller="AdminDashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminDashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>

            <p class="menu-title">CATEGORY</p>
            <a asp-controller="Category" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")">
                <i class="bi bi-tags me-2"></i>Categories
            </a>
            <a asp-controller="Product" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")">
                <i class="bi bi-box-seam me-2"></i>Products
            </a>
            <a asp-controller="ProductType" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductType" ? "active" : "")">
                <i class="bi bi-collection me-2"></i>Product Types
            </a>
            <a asp-controller="AdminDashboard" asp-action="ManageDisplaySections" class="text-warning @(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageDisplaySections" ? "active" : "")">
                <i class="bi bi-house-gear me-2"></i>Homepage Sections
            </a>

            <p class="menu-title">SYSTEM</p>
            <a asp-controller="Customer" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customer" ? "active" : "")">
                <i class="bi bi-people me-2"></i>Manage Customer
            </a>
            <a asp-controller="Employee" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Employee" ? "active" : "")">
                <i class="bi bi-person-badge me-2"></i>Manage Employees
            </a>
            <a asp-controller="AdminCart" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminCart" ? "active" : "")">
                <i class="bi bi-cart me-2"></i>Manage Carts
            </a>
            <a asp-controller="DeliveryMan" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "DeliveryMan" ? "active" : "")">
                <i class="bi bi-truck me-2"></i>Delivery Personnel
            </a>
            <a asp-controller="AdminReport" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminReport" ? "active" : "")">
                <i class="bi bi-file-earmark-bar-graph me-2"></i>Reports
            </a>
            <a asp-controller="AdminDashboard" asp-action="ManageReviews" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageReviews" ? "active" : "")">
                <i class="bi bi-star me-2"></i>Manage Reviews
            </a>
            <a asp-controller="AdminDashboard" asp-action="Messages" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Messages" ? "active" : "")">
                <i class="bi bi-envelope me-2"></i>Messages
            </a>
            <a asp-controller="AdminDashboard" asp-action="EmployeeList" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "EmployeeList" ? "active" : "")">
                <i class="bi bi-person-lines-fill me-1"></i>Employee Products-Sales
            </a>
            <a asp-controller="AdminDashboard" asp-action="Profile" class="fw-bold text-warning @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                <i class="bi bi-person-circle me-2"></i>My Profile
            </a>
            <a asp-controller="PaymentGateway" asp-action="AdminPaymentHistory" class="text-info @(ViewContext.RouteData.Values["Action"]?.ToString() == "AdminPaymentHistory" ? "active" : "")">
                <i class="bi bi-credit-card me-2"></i>Payment History
            </a>
            <a asp-controller="Banner" asp-action="Index" class="text-success @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Banner" ? "active" : "")">
                <i class="bi bi-images me-2"></i>Manage Banners
            </a>
            <p class="menu-title">TRACKING</p>
            <a asp-controller="Home" asp-action="Tracking" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Tracking" ? "active" : "")">
                <i class="bi bi-geo-alt me-2"></i>Track Customer Order
            </a>
        </aside>

        <!-- MAIN -->
        <main class="admin-main">

            <header class="admin-header d-flex justify-content-between align-items-center px-4 py-3" style="background:#fff; border-bottom:1px solid #e6e2db;">
                <div class="header-search flex-grow-1 me-4">
                    <form asp-controller="Product" asp-action="Index" method="get" class="position-relative">
                        <input type="text" name="query" placeholder="Search products, orders, customers..." class="form-control" style="border-radius:10px; padding-left:45px; background: #f8f6f0; border: 1px solid #e6e2db; height: 45px;" />
                        <i class="bi bi-search position-absolute" style="left: 15px; top: 50%; transform: translateY(-50%); color: #532374; font-size: 1.1rem;"></i>
                    </form>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <!-- Notification Button -->
                    @{
                        var db = Context.RequestServices.GetRequiredService<E_ShoppingManagement.Data.AppDbContext>();
                        var loggedInUser = await UserManager.GetUserAsync(User);
                        var lastCheck = loggedInUser?.LastNotificationCheck ?? DateTime.MinValue;

                        var pendingOrders = db.Orders.Where(o => o.OrderStatus == "Pending").ToList();
                        var pendingEmps = db.Employees.Where(e => e.Status == "Pending").ToList();
                        var activeMsgs = db.ContactMessages.Where(m => m.Status != "Replied").ToList();

                        var newOrdersCount = pendingOrders.Count(o => o.CreatedAt > lastCheck);
                        var newEmpsCount = pendingEmps.Count(e => e.CreatedAt > lastCheck);
                        var newMsgsCount = activeMsgs.Count(m => m.CreatedAt > lastCheck);
                        
                        var totalNewNotifs = newOrdersCount + newEmpsCount + newMsgsCount;
                        var totalItems = pendingOrders.Count + pendingEmps.Count + activeMsgs.Count;
                    }
                    <div class="dropdown">
                        <a href="#" class="position-relative text-decoration-none" id="adminNotificationDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-bell-fill" style="font-size: 1.4rem; color: #532374;"></i>
                            @{
                                var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                             }
                            @if (totalNewNotifs > 0 && currentAction != "Notifications")
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.65rem; border: 2px solid #fff;">
                                    @totalNewNotifs
                                </span>
                            }
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="adminNotificationDropdown" style="width: 320px; border-radius: 12px; background: #fff !important;">
                            <li><h6 class="dropdown-header fw-bold" style="background:#532374; color:#fff; border-radius: 12px 12px 0 0; margin-top:-8px; padding:12px 15px;">Admin Notifications</h6></li>
                            
                            @if (pendingOrders.Any()) {
                                <li>
                                    <a class="dropdown-item py-2 border-bottom" asp-controller="AdminDashboard" asp-action="OrdersByStatus" asp-route-status="Pending">
                                        <div class="d-flex gap-2">
                                            <i class="bi bi-cart-plus text-primary"></i>
                                            <div>
                                                <span class="fw-bold">@pendingOrders.Count Pending Orders</span>
                                                <small class="text-muted d-block">Needs processing</small>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                            }
                            @if (pendingEmps.Any()) {
                                <li>
                                    <a class="dropdown-item py-2 border-bottom" asp-controller="Employee" asp-action="Index">
                                        <div class="d-flex gap-2">
                                            <i class="bi bi-person-plus text-success"></i>
                                            <div>
                                                <span class="fw-bold">@pendingEmps.Count Pending Approvals</span>
                                                <small class="text-muted d-block">New employee registrations</small>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                            }
                            @if (activeMsgs.Any()) {
                                <li>
                                    <a class="dropdown-item py-2 border-bottom" asp-controller="AdminDashboard" asp-action="Messages">
                                        <div class="d-flex gap-2">
                                            <i class="bi bi-envelope text-info"></i>
                                            <div>
                                                <span class="fw-bold">@activeMsgs.Count New Messages</span>
                                                <small class="text-muted d-block">From contact form</small>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                            }

                            @if (totalItems == 0) {
                                <li><div class="dropdown-item py-3 text-center text-muted">No new notifications</div></li>
                            }

                            <li><hr class="dropdown-divider m-0"></li>
                            <li><a class="dropdown-item text-center fw-bold py-2" style="color:#532374; font-size:13px;" asp-controller="AdminDashboard" asp-action="Notifications">View All Activity</a></li>
                        </ul>
                    </div>
                    <!-- Profile Link -->
                    <a asp-action="Profile" class="d-flex align-items-center gap-2 text-decoration-none">
                        <i class="bi bi-person-circle" style="font-size: 1.8rem; color: #532374;"></i>
                    </a>
                </div>
            </header>

            <!-- PAGE CONTENT -->
            <section class="admin-content">
                @RenderBody()
            </section>

            @RenderSection("Scripts", required: false)

        </main>

    </div>

    <!-- Bootstrap JS (Required for Dropdowns, Modals, etc.) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
