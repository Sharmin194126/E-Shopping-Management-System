@using Microsoft.AspNetCore.Identity
@inject UserManager<E_ShoppingManagement.Models.Users> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Delivery Man</title>

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- jQuery & Chart.js -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <!-- Admin CSS -->
    <link href="~/css/admin.css" rel="stylesheet" asp-append-version="true" />
</head>

<body>

<div class="dm-wrapper">

    <!-- SIDEBAR -->
    <aside class="dm-sidebar">
        <!-- Brand & Profile Section -->
        @{
            var dmUserLayout = await UserManager.GetUserAsync(User);
        }
        <div class="px-3 py-4 text-center border-bottom border-white border-opacity-10 mb-3">
            <div class="rounded-circle bg-white bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2" style="width: 64px; height: 64px; border: 2px solid rgba(255,255,255,0.25); box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                <i class="bi bi-truck text-white" style="font-size: 1.8rem;"></i>
            </div>
            <div class="text-white fw-bold px-2" style="font-size: 0.95rem; letter-spacing: 0.3px;">@(dmUserLayout?.FullName ?? "Delivery Man")</div>
            <div class="text-white text-opacity-75 small" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">Delivery Personnel</div>
        </div>
        
        <a asp-controller="Home" asp-action="Index">
            <i class="bi bi-box-arrow-left me-2"></i>Back to Website
        </a>
        
        <a asp-controller="DeliveryManDashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "DeliveryManDashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
            <i class="bi bi-speedometer2 me-2"></i>My Dashboard
        </a>

        <p class="menu-title">OPERATIONS</p>
        <a asp-controller="DeliveryManDashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "DeliveryManDashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
            <i class="bi bi-list-task me-2"></i>Assigned Orders
        </a>
        <a asp-controller="DeliveryManDashboard" asp-action="Earnings" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Earnings" ? "active" : "")">
            <i class="bi bi-cash-stack me-2"></i>My Earnings
        </a>
        <a asp-controller="DeliveryManDashboard" asp-action="Notifications" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Notifications" ? "active" : "")">
            <i class="bi bi-bell me-2"></i>Notifications
        </a>

        <p class="menu-title">ACCOUNT</p>
        <a asp-controller="DeliveryManDashboard" asp-action="Profile" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
            <i class="bi bi-person-circle me-2"></i>My Profile
        </a>

        <!-- Logout -->
        <div class="mt-auto px-3 pb-3 pt-4 border-top border-white border-opacity-10" style="margin-top: 20px;">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center gap-2" style="background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.30); color: #fca5a5; font-weight: 600; padding: 10px 16px; border-radius: 8px;">
                    <i class="bi bi-box-arrow-right"></i>
                    Logout
                </button>
            </form>
        </div>
    </aside>

    <!-- MAIN -->
    <main class="dm-main">

        <header class="dm-header d-flex justify-content-between align-items-center px-4 py-3" style="background:#fff; border-bottom:1px solid #e6e2db;">
            <div class="header-search flex-grow-1 me-4">
                <h4 class="mb-0 fw-bold" style="color: #532374;">@ViewData["Title"]</h4>
            </div>
            <div class="d-flex align-items-center gap-4">
                <!-- Notification Button -->
                <div class="dropdown">
                    <a asp-controller="DeliveryManDashboard" asp-action="Notifications" class="notif-btn position-relative" title="Notifications">
                        <i class="bi bi-bell-fill text-primary fs-4" style="color:#532374 !important;"></i>
                        @if(ViewBag.UnreadNotifications > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.65rem;">
                                @ViewBag.UnreadNotifications
                            </span>
                        }
                    </a>
                </div>
                <!-- Profile Icon -->
                <a asp-controller="DeliveryManDashboard" asp-action="Profile" class="notif-btn ms-2" title="Profile">
                    <i class="bi bi-person-circle text-primary fs-3" style="color:#532374 !important;"></i>
                </a>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <section class="dm-content">
            @RenderBody()
        </section>

    </main>

</div>

@RenderSection("Scripts", required: false)

</body>
</html>
