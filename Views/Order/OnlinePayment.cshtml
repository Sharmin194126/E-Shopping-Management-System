@model E_ShoppingManagement.Models.Cart
@{
    var paymentMethod = ViewBag.PaymentMethod as string ?? "Online";
    ViewData["Title"] = paymentMethod + " Payment";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    // Dynamic styling based on payment method
    string primaryColor = "#e81828"; // Default (bKash)
    string secondaryColor = "#c41212";
    string logoIcon = "📱";
    
    if (paymentMethod.Contains("Nagad", StringComparison.OrdinalIgnoreCase)) {
        primaryColor = "#EC2B2B";
        secondaryColor = "#AD2020";
        logoIcon = "📱";
    } else if (paymentMethod.Contains("Rocket", StringComparison.OrdinalIgnoreCase)) {
        primaryColor = "#8E2DE2";
        secondaryColor = "#4A00E0";
        logoIcon = "📱";
    } else if (paymentMethod.Contains("Card", StringComparison.OrdinalIgnoreCase) || paymentMethod.Contains("Credit", StringComparison.OrdinalIgnoreCase)) {
        primaryColor = "#007bff";
        secondaryColor = "#0056b3";
        logoIcon = "💳";
    }
}

<style>
    :root {
        --payment-primary: @primaryColor;
        --payment-secondary: @secondaryColor;
    }

    .payment-wrapper {
        background: #f4f7f6;
        min-height: 80vh;
        padding: 40px 0;
    }

    .payment-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 30px;
        background: #f2efe9;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    }

    .payment-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
        margin-bottom: 30px;
    }

    .order-summary {
        background: linear-gradient(135deg, var(--payment-primary) 0%, var(--payment-secondary) 100%);
        color: white;
        padding: 25px;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
    }

    .order-summary h3 {
        color: #ffffff !important;
        margin-bottom: 20px;
        font-weight: 700;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding-bottom: 10px;
    }

    .order-item span, .order-total span {
        color: #ffffff !important;
    }

    .order-item {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .order-item:last-child {
        border-bottom: none;
    }

    .order-total {
        display: flex;
        justify-content: space-between;
        font-size: 20px;
        font-weight: bold;
        margin-top: auto;
        padding-top: 20px;
        border-top: 2px solid rgba(255, 255, 255, 0.3);
    }

    .payment-form-section {
        background: #f2efe9;
        padding: 25px;
        border-radius: 10px;
        border: 1px solid #eee;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #333;
    }

    .form-group input {
        width: 100%;
        padding: 12px;
        border: 2px solid #ddd;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s;
    }

    .form-group input:focus {
        outline: none;
        border-color: var(--payment-primary);
        box-shadow: 0 0 0 0.2rem rgba(232, 24, 40, 0.1);
    }

    .payment-header {
        text-align: center;
        margin-bottom: 25px;
    }

    .payment-logo-icon {
        font-size: 48px;
        margin-bottom: 10px;
    }

    .pay-button {
        background: linear-gradient(135deg, var(--payment-primary) 0%, var(--payment-secondary) 100%);
        color: white;
        padding: 15px 30px;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        width: 100%;
        margin-top: 20px;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .pay-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    }

    .info-box {
        background: #e7f3ff;
        color: #004085;
        padding: 15px;
        border-radius: 8px;
        margin-top: 20px;
        border-left: 4px solid #004085;
        font-size: 0.9rem;
    }

    .button-container {
        display: flex;
        justify-content: center;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #ddd;
    }

    .back-link {
        color: #6c757d;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--payment-primary);
    }

    /* Payment Gateway Modal Styles */
    .payment-modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.6);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        backdrop-filter: blur(5px);
    }

    .payment-modal {
        background: white;
        padding: 40px 30px;
        border-radius: 15px;
        width: 90%;
        max-width: 420px;
        text-align: center;
        box-shadow: 0 25px 50px rgba(0,0,0,0.25);
        animation: modalPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @@keyframes modalPop {
        0% { transform: scale(0.8); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }

    .payment-modal h4 {
        color: var(--payment-primary);
        margin-bottom: 15px;
        font-weight: 700;
        font-size: 24px;
    }

    .payment-modal p {
        color: #555;
        margin-bottom: 25px;
        font-size: 15px;
        line-height: 1.5;
    }

    .payment-modal input.gateway-input {
        width: 100%;
        padding: 15px;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        text-align: center;
        font-size: 24px;
        letter-spacing: 5px;
        margin-bottom: 25px;
        transition: all 0.3s;
        font-weight: bold;
    }

    .payment-modal input.gateway-input:focus {
        border-color: var(--payment-primary);
        outline: none;
        box-shadow: 0 0 0 4px rgba(0,0,0,0.05);
    }

    .payment-modal .btn-gateway-confirm {
        background: linear-gradient(135deg, var(--payment-primary) 0%, var(--payment-secondary) 100%);
        color: white;
        padding: 15px 30px;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        font-size: 16px;
        cursor: pointer;
        width: 100%;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .payment-modal .btn-gateway-confirm:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .payment-modal .btn-gateway-cancel {
        color: #888;
        background: none;
        border: none;
        margin-top: 15px;
        font-size: 14px;
        cursor: pointer;
        text-decoration: underline;
        transition: color 0.2s;
    }

    .payment-modal .btn-gateway-cancel:hover {
        color: #333;
    }

    .gateway-spinner {
        width: 50px;
        height: 50px;
        border: 5px solid #f3f3f3;
        border-top: 5px solid var(--payment-primary);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 20px auto;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    @@media (max-width: 768px) {
        .payment-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="payment-wrapper">
    <div class="payment-container">
        <h2 style="text-align: center; margin-bottom: 30px; color: var(--payment-primary);">
            <span style="font-size: 36px;">@logoIcon</span> @paymentMethod Payment
        </h2>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger text-center">
                @TempData["ErrorMessage"]
            </div>
        }


        <div class="payment-grid">
            <!-- Order Summary -->
            <div class="order-summary">
                <h3>📋 Order Summary</h3>
                @if(Model.Items != null)
                {
                    @foreach (var item in Model.Items)
                    {
                        <div class="order-item">
                            <div>
                                <span>@item.Product?.Name x @item.Quantity</span>
                                <br/><small style="opacity: 0.8;">VAT: @item.Product?.VatPercentage% (৳@((item.Quantity * item.VatAmount).ToString("N2")))</small>
                            </div>
                            <span>৳@((item.Quantity * item.Price).ToString("N2"))</span>
                        </div>
                    }
                }
                <div class="order-total" style="border-top: 2px solid rgba(255, 255, 255, 0.3); margin-top: 20px; padding-top: 10px; font-size: 16px;">
                    <span>Subtotal:</span>
                    <span>৳@Model.Items?.Sum(i => i.Quantity * i.Price).ToString("N2")</span>
                </div>
                <div class="order-total" style="border-top: none; padding-top: 5px; font-size: 16px;">
                    <span>Total VAT:</span>
                    <span>৳@Model.Items?.Sum(i => i.Quantity * i.VatAmount).ToString("N2")</span>
                </div>
                <div class="order-total" style="border-top: 2px solid rgba(255, 255, 255, 0.5); padding-top: 15px; font-size: 22px;">
                    <span>Total Amount:</span>
                    <span>৳@Model.Items?.Sum(i => i.Quantity * i.PriceWithVat).ToString("N2")</span>
                </div>
            </div>

            <!-- Payment Form -->
            <div class="payment-form-section">
                <div class="payment-header">
                    <div class="payment-logo-icon">@logoIcon</div>
                    <h3 style="color: var(--payment-primary); margin-bottom: 5px;">@paymentMethod Details</h3>
                    @if (ViewBag.PaymentMethodObj != null && !string.IsNullOrEmpty(ViewBag.PaymentMethodObj.Details))
                    {
                        <div class="alert alert-info py-2 mb-3">
                            <strong>Receiving Account:</strong> @ViewBag.PaymentMethodObj.Details
                        </div>
                    }
                </div>

                <form id="paymentForm" asp-action="ConfirmOnlinePayment" method="post">
                    <input type="hidden" name="transactionId" id="generatedTransactionId" />
                    
                    @if (paymentMethod.Contains("Card", StringComparison.OrdinalIgnoreCase) || paymentMethod.Contains("Credit", StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="form-group">
                            <label>Card Holder Name</label>
                            <input type="text" name="cardHolder" placeholder="FULL NAME ON CARD" required />
                        </div>
                        <div class="form-group">
                            <label>Card Number</label>
                            <input type="text" id="cardNumberInput" placeholder="XXXX XXXX XXXX XXXX" required pattern="[0-9\s]{13,19}" />
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <div class="form-group">
                                    <label>Expiry Date</label>
                                    <input type="text" placeholder="MM/YY" required />
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-group">
                                    <label>CVV</label>
                                    <input type="password" placeholder="***" required maxlength="4" />
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" name="fullName" placeholder="Enter Full Name" required />
                        </div>
                        
                        <div class="form-group">
                            <label>Email Address</label>
                            <input type="email" name="email" placeholder="Enter Email Address" required />
                        </div>

                        <div class="form-group">
                            <label>@paymentMethod Account Number</label>
                            <input type="tel" name="phoneNumber" placeholder="e.g., 01XXXXXXXXX" pattern="01[0-9]{9}" maxlength="11" required />
                            <small class="text-muted">Enter your 11-digit @paymentMethod account number</small>
                        </div>
                    }

                    <button type="submit" class="pay-button">Proceed to Pay</button>
                </form>
            </div>
        </div>

        <div class="info-box">
            <strong>Security Note:</strong> Your payment information is securely encrypted by our gateway. We do not store your PIN or sensitive card details.
        </div>

        <div class="button-container">
            <a href="/CustomerDashboard" class="back-link">← Back to Dashboard</a>
        </div>
    </div>
</div>

<!-- Payment Gateway Modals -->
<div class="payment-modal-overlay" id="paymentGatewayModal">
    <!-- Method Selection Step -->
    <div class="payment-modal" id="modalMethodSelection">
        <h4>Choose OTP Method</h4>
        <p>How would you like to receive your secure payment OTP?</p>
        <button type="button" class="btn-gateway-confirm mb-3" style="background: #198754;" onclick="sendOtpOption('email')">
            <i class="bi bi-envelope"></i> Send via Email
        </button>
        <button type="button" class="btn-gateway-confirm" onclick="sendOtpOption('sms')">
            <i class="bi bi-chat-dots"></i> Send via SMS
        </button>
        <button type="button" class="btn-gateway-cancel mt-3" onclick="closeModal()">Cancel Payment</button>
    </div>
    <!-- OTP Verification Step -->
    <div class="payment-modal" id="modalStepOtp">
        <h4>OTP Verification</h4>
        <p>A 4-digit OTP has been sent to <br><strong id="otpTargetText">your account</strong>.<br>Please enter it below to verify.</p>
        <input type="text" id="otpInput" class="gateway-input" maxlength="4" placeholder="••••" autocomplete="off" />
        <button type="button" class="btn-gateway-confirm" onclick="verifyOtp()">Verify OTP</button>
        <button type="button" class="btn-gateway-cancel" onclick="closeModal()">Cancel Payment</button>
    </div>

    <!-- PIN Entry Step -->
    <div class="payment-modal" id="modalStepPin" style="display: none;">
        <h4>Secure Payment</h4>
        <p>Enter your @paymentMethod PIN to confirm the payment of <br><strong style="font-size: 20px;">৳@Model.Items?.Sum(i => i.Quantity * i.PriceWithVat).ToString("N2")</strong></p>
        <input type="password" id="pinInput" class="gateway-input" maxlength="5" placeholder="•••••" autocomplete="off" />
        <button type="button" class="btn-gateway-confirm" onclick="verifyPin()">Confirm Payment</button>
        <button type="button" class="btn-gateway-cancel" onclick="closeModal()">Cancel Payment</button>
    </div>

    <!-- Processing Step -->
    <div class="payment-modal" id="modalStepProcessing" style="display: none;">
        <h4>Processing...</h4>
        <p>Please wait while we securely process your payment. Do not refresh or close this window.</p>
        <div class="gateway-spinner"></div>
    </div>
</div>

@section Scripts {
    <script>
        const form = document.getElementById('paymentForm');
        const paymentGatewayModal = document.getElementById('paymentGatewayModal');
        const modalStepOtp = document.getElementById('modalStepOtp');
        const modalStepPin = document.getElementById('modalStepPin');
        const modalStepProcessing = document.getElementById('modalStepProcessing');
        const generatedTransactionIdInput = document.getElementById('generatedTransactionId');
        const otpTargetText = document.getElementById('otpTargetText');

        let paymentMethodIsCard = @(paymentMethod.Contains("Card", StringComparison.OrdinalIgnoreCase) || paymentMethod.Contains("Credit", StringComparison.OrdinalIgnoreCase) ? "true" : "false");
        let currentPhoneTarget = "";
        let currentEmailTarget = "";
        let selectedOtpMethod = "";

        form.addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Collect targets from form
            if (paymentMethodIsCard) {
                currentPhoneTarget = "01XXXXXXXXX"; // Fallback for card
                currentEmailTarget = "customer@example.com";
            } else {
                const phoneInput = document.querySelector('input[name="phoneNumber"]');
                const emailInput = document.querySelector('input[name="email"]');
                if (phoneInput && phoneInput.value) currentPhoneTarget = phoneInput.value;
                if (emailInput && emailInput.value) currentEmailTarget = emailInput.value;
            }

            // Show Gateway Modal (Method Selection Step)
            paymentGatewayModal.style.display = 'flex';
            document.getElementById('modalMethodSelection').style.display = 'block';
            modalStepOtp.style.display = 'none';
            modalStepPin.style.display = 'none';
            modalStepProcessing.style.display = 'none';
        });

        function sendOtpOption(method) {
            selectedOtpMethod = method;
            let target = "";
            let endpoint = "";
            let bodyData = {};

            if (method === 'sms') {
                if(!currentPhoneTarget || currentPhoneTarget.length < 11) {
                    alert("Please enter a valid phone number to receive the real OTP SMS.");
                    return;
                }
                target = currentPhoneTarget;
                endpoint = '/Order/SendOtpSms';
                bodyData = { PhoneNumber: currentPhoneTarget };
            } else if (method === 'email') {
                if(!currentEmailTarget || !currentEmailTarget.includes("@@")) {
                    alert("Please enter a valid email address to receive the real OTP Email.");
                    return;
                }
                target = currentEmailTarget;
                endpoint = '/Order/SendOtpEmail';
                bodyData = { Email: currentEmailTarget };
            }

            otpTargetText.innerText = target;

            // Show Processing
            document.getElementById('modalMethodSelection').style.display = 'none';
            modalStepProcessing.style.display = 'block';
            
            // Call Backend API
            fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bodyData)
            })
            .then(res => res.json())
            .then(data => {
                modalStepProcessing.style.display = 'none';
                if(data.success) {
                    modalStepOtp.style.display = 'block';
                    document.getElementById('otpInput').value = '';
                    setTimeout(() => document.getElementById('otpInput').focus(), 100);
                    
                    // Notice for missing API Key configuration during testing
                    if (data.testOtp) {
                        let noticeText = method === 'sms' 
                            ? "Real SMS API Key not configured yet!\nTesting OTP is: " + data.testOtp + "\nTo receive real SMS, setup API Key in OrderController." 
                            : "Real Gmail SMTP not configured yet!\nTesting OTP is: " + data.testOtp + "\nTo receive real Email, setup Gmail App Password in OrderController.";
                        alert(`[System Notice]\n\n${noticeText}`);
                    }
                } else {
                    alert(data.message || "Failed to send OTP.");
                    closeModal();
                }
            })
            .catch(err => {
                alert("Server error sending OTP.");
                closeModal();
            });
        }

        function verifyOtp() {
            const otp = document.getElementById('otpInput').value;
            if (otp.length < 4) {
                alert("Please enter a valid 4-digit OTP.");
                return;
            }

            modalStepOtp.style.display = 'none';
            modalStepProcessing.style.display = 'block';

            // Verify with backend
            let verifyBody = { Otp: otp };
            if (selectedOtpMethod === 'sms') verifyBody.PhoneNumber = currentPhoneTarget;
            else verifyBody.Email = currentEmailTarget;

            fetch('/Order/VerifyOtpSms', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(verifyBody)
            })
            .then(res => res.json())
            .then(data => {
                modalStepProcessing.style.display = 'none';
                if(data.success) {
                    // Move to PIN Step
                    modalStepPin.style.display = 'block';
                    setTimeout(() => document.getElementById('pinInput').focus(), 100);
                } else {
                    modalStepOtp.style.display = 'block';
                    alert(data.message || "Incorrect OTP.");
                }
            })
            .catch(err => {
                alert("Error verifying OTP.");
                modalStepProcessing.style.display = 'none';
                modalStepOtp.style.display = 'block';
            });
        }

        function verifyPin() {
            const pin = document.getElementById('pinInput').value;
            if (pin.length < 4) {
                alert("Please enter a valid PIN.");
                return;
            }
            // Move to Processing Step
            modalStepPin.style.display = 'none';
            modalStepProcessing.style.display = 'block';

            // Simulate network processing and generate real Transaction ID
            setTimeout(() => {
                const prefix = paymentMethodIsCard ? "CRD" : "TXN";
                const randomString = Math.random().toString(36).substring(2, 12).toUpperCase();
                generatedTransactionIdInput.value = prefix + randomString;
                
                // Submit form directly to server
                form.submit();
            }, 3000);
        }

        function closeModal() {
            paymentGatewayModal.style.display = 'none';
        }
    </script>
}



