@model E_ShoppingManagement.Models.Order
@{
    ViewData["Title"] = "Order Details";
    Layout = User.IsInRole("Admin") || User.IsInRole("Employee") ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@media print {
        body { background-color: #ffffff !important; font-size: 11pt; }
        .d-print-none, .admin-sidebar, .dm-sidebar, .admin-header, .shoegee-header, .sidebar, .search-box, nav, footer { 
            display: none !important; 
        }
        .admin-main, .dm-main, .container { 
            margin-left: 0 !important; 
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
        }
        .print-container { display: block !important; width: 100%; color: #000; }
        .print-header { text-align: center; border-bottom: 2px solid #000; padding-bottom: 10px; margin-bottom: 20px; }
        .print-table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        .print-table th, .print-table td { border: 1px solid #000; padding: 10px; text-align: left; }
        .print-table th { background-color: #f2efe9 !important; -webkit-print-color-adjust: exact; }
    }
</style>

<!-- Normal View (Hidden when printing) -->
<div class="container mt-4 d-print-none">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Order SL @Model.Id Details</h2>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
            {
                <a href="javascript:history.back()" class="theme-back-btn mb-0">
                    Back
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit / Manage</a>
            }
            <button onclick="window.print()" class="btn btn-outline-primary"><i class="bi bi-printer"></i> Print Receipt</button>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-theme" style="background:#532374 !important;">
                    <h5 class="mb-0 text-white">Order Items</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th>SL</th>
                                <th>Product</th>
                                <th>Details</th>
                                <th>Price Structure</th>
                                <th>Qty</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int sl = 1; }
                            @foreach (var item in Model.OrderDetails!)
                            {
                                <tr>
                                    <td>@(sl++)</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                            {
                                                <img src="@(item.Product.ImageUrl.StartsWith("/") ? item.Product.ImageUrl : "/images/products/" + item.Product.ImageUrl)" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;" />
                                            }
                                            <div class="fw-bold">@item.Product?.Name</div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small">Size: <span class="badge bg-secondary">@(item.Size ?? "N/A")</span></div>
                                        @if(item.OfferPercentage > 0) {
                                            <div class="badge bg-danger mt-1">@item.OfferPercentage% Offer</div>
                                        }
                                    </td>
                                    <td>
                                        <div class="small">Price: ৳@item.Price.ToString("N0")</div>
                                        @if(item.VatPercentage > 0) {
                                            <div class="text-success small">VAT (@item.VatPercentage%): +৳@item.VatAmount.ToString("N0")</div>
                                        }
                                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">Inc. VAT: ৳@item.PriceWithVat.ToString("N0")</div>
                                    </td>
                                    <td>@item.Quantity</td>
                                    <td class="fw-bold">৳@((item.PriceWithVat * item.Quantity).ToString("N0"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="5" class="text-end fw-bold">Grand Total (Inc. All VAT):</td>
                                <td class="fw-bold text-danger" style="font-size: 1.2rem;">৳@Model.TotalAmount.ToString("N0")</td>
                            </tr>
                        </tfoot>
                    </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4 shadow-sm" style="border-color:#532374;">
                <div class="card-header" style="background:#532374;">
                    <h5 class="mb-0 text-white">Order Status</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted small d-block">Status</label>
                        <span class="badge @(Model.OrderStatus == "Delivered" ? "bg-success" : (Model.OrderStatus == "Cancelled" ? "bg-danger" : "bg-warning")) fs-6">
                            @Model.OrderStatus
                        </span>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Payment Status</label>
                        <span class="badge @(Model.PaymentStatus == "Paid" ? "bg-success" : "bg-warning")">@Model.PaymentStatus</span>
                        <small class="ms-1">(@Model.PaymentMethod)</small>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Assigned Employee</label>
                        <span class="fw-bold text-info">@(Model.AssignedEmployee?.Name ?? "Not Assigned")</span>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Delivery Man</label>
                        <span class="fw-bold text-success">@(Model.DeliveryMan?.Name ?? "Not Assigned")</span>
                    </div>
                </div>
            </div>

            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-theme" style="background:#532374 !important;">
                    <h5 class="mb-0 text-white">Shipping Info</h5>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Customer:</strong> @Model.Customer?.Name</p>
                    <p class="mb-1"><strong>Phone:</strong> @Model.PhoneNumber</p>
                    <p class="mb-1"><strong>Address:</strong> @Model.ShippingAddress</p>
                    <p class="mb-0"><strong>City:</strong> @Model.City, @Model.ZipCode</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Print-Only Receipt View -->
<div class="d-none d-print-block print-container">
    <div class="print-header">
        <h1>E-Shop Receipt</h1>
        <p class="mb-0">Order SL @Model.Id | Date: @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</p>
        <p class="mb-0">Status: <strong>@Model.OrderStatus</strong></p>
    </div>

    <div class="row mb-4">
        <div class="col-6">
            <h5 style="border-bottom: 1px solid #ccc; padding-bottom: 5px;">Billed To / Shipping Address</h5>
            <strong>@Model.Customer?.Name</strong><br>
            @Model.ShippingAddress<br>
            @Model.City, @Model.ZipCode<br>
            Phone: @Model.PhoneNumber
        </div>
        <div class="col-6 text-end">
            <h5 style="border-bottom: 1px solid #ccc; padding-bottom: 5px;">Payment Details</h5>
            <p class="mb-0"><strong>Method:</strong> @Model.PaymentMethod</p>
            <p class="mb-0"><strong>Status:</strong> @Model.PaymentStatus</p>
            @if (Model.ProcessedAt.HasValue) {
                <p class="mb-0 small text-muted">Processed: @Model.ProcessedAt.Value.ToLocalTime().ToString("dd MMM, hh:mm tt")</p>
            }
            @if (Model.DeliveredAt.HasValue) {
                <p class="mb-0 small text-muted">Delivered: @Model.DeliveredAt.Value.ToLocalTime().ToString("dd MMM, hh:mm tt")</p>
            }
            <p class="mb-0 mt-1"><strong>Delivery Man:</strong> @(Model.DeliveryMan?.Name ?? "N/A")</p>
        </div>
    </div>

    <table class="print-table mb-4">
        <thead>
            <tr>
                <th>Product</th>
                <th>Size</th>
                <th>Unit Price</th>
                <th>Qty</th>
                <th>VAT (%)</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderDetails!)
            {
                <tr>
                    <td>@item.Product?.Name</td>
                    <td>@(item.Size ?? "-")</td>
                    <td>৳@item.Price.ToString("#,##0")</td>
                    <td>@item.Quantity</td>
                    <td>@(item.VatPercentage)%</td>
                    <td>৳@((item.PriceWithVat * item.Quantity).ToString("#,##0"))</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr style="border-top: 2px solid #000;">
                <td colspan="5" style="text-align: right; font-weight: bold; font-size: 1.1em;">Grand Total (Inc. VAT):</td>
                <td style="font-weight: bold; font-size: 1.1em;">৳@Model.TotalAmount.ToString("#,##0")</td>
            </tr>
        </tfoot>
    </table>


</div>



