@model E_ShoppingManagement.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-3">Edit Product</h2>

<style>
    /* Square checkbox style */
    .size-chk-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 500;
        color: #333;
        user-select: none;
    }
    .size-chk-label input[type="checkbox"] {
        display: none;
    }
    .size-chk-box {
        width: 20px;
        height: 20px;
        border: 2px solid #6c757d;
        border-radius: 3px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f2efe9;
        flex-shrink: 0;
        transition: border-color 0.15s;
    }
    .size-chk-label input[type="checkbox"]:checked + .size-chk-box {
        border-color: #333;
    }
    .size-chk-label input[type="checkbox"]:checked + .size-chk-box::after {
        content: '\2713';
        font-size: 13px;
        font-weight: 700;
        color: #333;
    }
    /* Size quantity input group */
    .size-qty-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 8px;
    }
    .size-qty-item {
        display: flex;
        align-items: stretch;
        border: 1px solid #ced4da;
        border-radius: 4px;
        overflow: hidden;
    }
    .size-qty-item .size-label {
        display: flex;
        align-items: center;
        padding: 4px 10px;
        background: #f2efe9;
        border-right: 1px solid #ced4da;
        font-weight: 700;
        font-size: 0.9rem;
        color: #333;
        min-width: 38px;
        justify-content: center;
    }
    .size-qty-item input[type=number] {
        width: 70px;
        border: none;
        text-align: center;
        padding: 4px 6px;
        font-size: 0.9rem;
        outline: none;
    }
    .size-qty-item input[type=number]:focus {
        background: #f0f4ff;
    }
</style>

<div class="page-card">

    @if (ViewBag.Message != null)
    {
        <div class="alert @(ViewBag.IsSuccess == true ? "alert-success" : "alert-danger")">
            @ViewBag.Message
        </div>
    }

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CategoryId"></label>
            <select asp-for="CategoryId" class="form-control" asp-items="Model.CategoryList">
                <option value="">-- Select Category --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ProductTypeId"></label>
            <select asp-for="ProductTypeId" class="form-control" asp-items="Model.ProductTypeList">
                <option value="">-- Select Product Type --</option>
            </select>
            <span asp-validation-for="ProductTypeId" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label>Regular Price</label>
                    <input asp-for="RegularPrice" id="regPrice" class="form-control" />
                    <span asp-validation-for="RegularPrice" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label>Offer %</label>
                    <input asp-for="OfferPercentage" id="offPercent" class="form-control" />
                    <span asp-validation-for="OfferPercentage" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label>Offer Price (Auto-calculated)</label>
            <input asp-for="Price" id="offPrice" class="form-control" readonly style="background-color: #e9ecef;" />
            <small class="text-muted">Calculated: Regular Price - (Regular Price * Offer % / 100)</small>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    <label asp-for="VatPercentage"></label>
                    <input asp-for="VatPercentage" class="form-control" />
                    <span asp-validation-for="VatPercentage" class="text-danger"></span>
                </div>
            </div>
        </div>



        <div class="form-group">
            <label asp-for="MaxOrderQty">Max Order limit per Customer (Optional)</label>
            <input type="number" name="MaxOrderQty" value="@Model.MaxOrderQty" class="form-control" placeholder="Leave empty for no limit" />
        </div>

        <div class="form-group">
            <label asp-for="DisplayCategory"></label>
            <select asp-for="DisplayCategory" class="form-control" asp-items="Model.DisplayCategoryList">
                <option value="">-- None --</option>
            </select>
            <span asp-validation-for="DisplayCategory" class="text-danger"></span>
        </div>

        <input type="hidden" asp-for="AvailableSizes" id="availableSizesHidden" />

        <div class="form-group">
            <label>Available Sizes</label>
            <div class="d-flex flex-wrap gap-4 mt-2">
                @{
                    var sizesList = new[] { "S", "M", "L", "XL", "XXL", "3XL" };
                    var savedSizes = (Model?.AvailableSizes ?? "").Split(',').Select(s => s.Trim()).ToList();
                }
                @foreach (var sz in sizesList)
                {
                    var isChecked = savedSizes.Contains(sz);
                    <label class="size-chk-label">
                        <input type="checkbox" class="size-checkbox" value="@sz" id="sizeChk_@sz" @(isChecked ? "checked" : "") />
                        <span class="size-chk-box"></span>
                        @sz
                    </label>
                }
            </div>
        </div>

        <div class="form-group">
            <label>Size Wise Quantity</label>
            <div class="size-qty-row">
                @{
                    int idx = 0;
                }
                @foreach (var size in sizesList)
                {
                    var stockVal = Model?.SizeStocks?.FirstOrDefault(s => s.Size == size)?.StockQty ?? 0;
                    <div class="size-qty-item">
                        <span class="size-label">@size</span>
                        <input type="number" id="sizeQty_@size"
                               name="SizeStocks[@idx].StockQty"
                               value="@stockVal"
                               class="size-stock-input"
                               min="0" />
                    </div>
                    <input type="hidden" name="SizeStocks[@idx].Size" value="@size" />
                    idx++;
                }
            </div>
            <small class="text-muted mt-2 d-block">Total stock quantity will be automatically calculated from all sizes.</small>
        </div>

        <div class="form-group">
            <label asp-for="StockQty">Stock Quantity (Auto-calculated)</label>
            <input asp-for="StockQty" id="stockQtyInput" class="form-control" readonly
                   style="background-color: #e9ecef;"
                   data-val="false" />
            <small class="text-muted">Automatically summed from size-wise quantities above.</small>
        </div>
        
        <div class="form-group">
            <label asp-for="AssignedEmployeeId"></label>
            <select asp-for="AssignedEmployeeId" asp-items="Model.EmployeeList" class="form-control">
                <option value="">-- No Assignment --</option>
            </select>
            <span asp-validation-for="AssignedEmployeeId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" rows="3" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Status</label>
            <select asp-for="Status" class="form-control">
                <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
            </select>
        </div>

        <div class="form-group form-check d-flex align-items-center">
            <input asp-for="IsApproved" class="form-check-input me-2" id="chkApproved" />
            <label asp-for="IsApproved" class="form-check-label mr-3"></label>
            <span id="approvedCheck" style="display: none; color: #28a745; font-size: 18px; font-weight: bold; margin-left: 10px;">✔ Approved!</span>
        </div>

        <div class="form-group">
            <label asp-for="ImageFile">Change Image (optional)</label>
            <input asp-for="ImageFile" type="file" class="form-control" id="imageInput" accept="image/*" />
            @if (!string.IsNullOrEmpty(Model?.ExistingImageUrl))
            {
                <div id="imagePreviewWrapper" style="margin-top:10px;">
                    <img id="imagePreview" src="@Model.ExistingImageUrl" alt="Current Product Image" style="height: 120px; width: auto; border-radius: 6px; border: 1px solid #ddd; box-shadow: 0 2px 6px rgba(0,0,0,0.1);" />
                    <p class="text-muted mt-1" style="font-size:0.82rem;" id="imagePreviewLabel">Current image (select a new file to change)</p>
                </div>
            }
            else
            {
                <div id="imagePreviewWrapper" style="display:none; margin-top:10px;">
                    <img id="imagePreview" src="#" alt="Selected Image Preview" style="height: 120px; width: auto; border-radius: 6px; border: 1px solid #ddd; box-shadow: 0 2px 6px rgba(0,0,0,0.1);" />
                    <p class="text-muted mt-1" style="font-size:0.82rem;" id="imagePreviewLabel">Selected image preview</p>
                </div>
            }
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            <button type="submit" class="btn btn-success">Update</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // ── Offer Price Calculation ──────────────────────────────────────
            function calculateOffer() {
                var regPrice = parseFloat(document.getElementById('regPrice').value) || 0;
                var offPct   = parseFloat(document.getElementById('offPercent').value) || 0;
                document.getElementById('offPrice').value = (regPrice - regPrice * offPct / 100).toFixed(2);
            }
            document.getElementById('regPrice').addEventListener('input', calculateOffer);
            document.getElementById('offPercent').addEventListener('input', calculateOffer);
            calculateOffer();

            // ── Approved Checkmark ───────────────────────────────────────────
            var chkApproved    = document.getElementById('chkApproved');
            var approvedCheck  = document.getElementById('approvedCheck');
            function toggleApproved() {
                approvedCheck.style.display = chkApproved.checked ? 'inline' : 'none';
            }
            chkApproved.addEventListener('change', toggleApproved);
            toggleApproved(); // run on load

            // ── Image Preview ────────────────────────────────────────────────
            var imageInput          = document.getElementById('imageInput');
            var imagePreview        = document.getElementById('imagePreview');
            var imagePreviewWrapper = document.getElementById('imagePreviewWrapper');
            var imagePreviewLabel   = document.getElementById('imagePreviewLabel');
            imageInput.addEventListener('change', function () {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        imagePreview.src = e.target.result;
                        imagePreviewWrapper.style.display = 'block';
                        if (imagePreviewLabel) imagePreviewLabel.textContent = 'New image preview';
                    };
                    reader.readAsDataURL(file);
                }
            });

            // ── Stock Calculation ─────────────────────────────────────────────
            function calculateTotalStock() {
                var total      = 0;
                var availSizes = [];
                document.querySelectorAll('.size-checkbox:checked').forEach(function (cb) {
                    availSizes.push(cb.value);
                });
                document.querySelectorAll('.size-stock-input').forEach(function (inp) {
                    total += parseInt(inp.value) || 0;
                });
                document.getElementById('stockQtyInput').value = total;
                document.getElementById('availableSizesHidden').value = availSizes.join(', ');
            }
            document.querySelectorAll('.size-checkbox').forEach(function (cb) {
                cb.addEventListener('change', calculateTotalStock);
            });
            document.querySelectorAll('.size-stock-input').forEach(function (inp) {
                inp.addEventListener('input', calculateTotalStock);
            });
            calculateTotalStock();
        });
    </script>
}



