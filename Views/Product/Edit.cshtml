@model E_ShoppingManagement.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-3">Edit Product</h2>

<div class="page-card">

    @if (ViewBag.Message != null)
    {
        <div class="alert @(ViewBag.IsSuccess == true ? "alert-success" : "alert-danger")">
            @ViewBag.Message
        </div>
    }

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CategoryId"></label>
            <select asp-for="CategoryId" class="form-control" asp-items="Model.CategoryList">
                <option value="">-- Select Category --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ProductTypeId"></label>
            <select asp-for="ProductTypeId" class="form-control" asp-items="Model.ProductTypeList">
                <option value="">-- Select Product Type --</option>
            </select>
            <span asp-validation-for="ProductTypeId" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label>Regular Price</label>
                    <input asp-for="RegularPrice" id="regPrice" class="form-control" />
                    <span asp-validation-for="RegularPrice" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label>Offer %</label>
                    <input asp-for="OfferPercentage" id="offPercent" class="form-control" />
                    <span asp-validation-for="OfferPercentage" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label>Offer Price (Auto-calculated)</label>
            <input asp-for="Price" id="offPrice" class="form-control" readonly style="background-color: #e9ecef;" />
            <small class="text-muted">Calculated: Regular Price - (Regular Price * Offer % / 100)</small>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    <label asp-for="VatPercentage"></label>
                    <input asp-for="VatPercentage" class="form-control" />
                    <span asp-validation-for="VatPercentage" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="StockQty"></label>
            <input asp-for="StockQty" class="form-control" />
            <span asp-validation-for="StockQty" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MaxOrderQty">Max Order limit per Customer (Optional)</label>
            <input type="number" name="MaxOrderQty" value="@Model.MaxOrderQty" class="form-control" placeholder="Leave empty for no limit" />
        </div>

        <div class="form-group">
            <label asp-for="DisplayCategory"></label>
            <select asp-for="DisplayCategory" class="form-control" asp-items="Model.DisplayCategoryList">
                <option value="">-- None --</option>
            </select>
            <span asp-validation-for="DisplayCategory" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="AvailableSizes"></label>
            <div class="input-group mb-2">
                <input asp-for="AvailableSizes" id="availableSizes" class="form-control" placeholder="e.g. L, M, XL" />
                <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('availableSizes').value=''; updateSizeFields();">Clear</button>
            </div>
            <div class="mb-3 d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-sm btn-outline-primary size-preset" data-size="S">S</button>
                <button type="button" class="btn btn-sm btn-outline-primary size-preset" data-size="M">M</button>
                <button type="button" class="btn btn-sm btn-outline-primary size-preset" data-size="L">L</button>
                <button type="button" class="btn btn-sm btn-outline-primary size-preset" data-size="XL">XL</button>
                <button type="button" class="btn btn-sm btn-outline-primary size-preset" data-size="XXL">XXL</button>
                <button type="button" class="btn btn-sm btn-outline-secondary size-preset" data-size="36">36</button>
                <button type="button" class="btn btn-sm btn-outline-secondary size-preset" data-size="38">38</button>
                <button type="button" class="btn btn-sm btn-outline-secondary size-preset" data-size="40">40</button>
                <button type="button" class="btn btn-sm btn-outline-secondary size-preset" data-size="42">42</button>
            </div>
            <span asp-validation-for="AvailableSizes" class="text-danger"></span>
        </div>

        <div id="sizeStockContainer" class="mt-4 mb-4" style="display:none; background: #ffffff; padding: 20px; border-radius: 12px; border: 2px solid #28a745; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
            <div class="d-flex align-items-center mb-3">
                <i class="bi bi-box-seam me-2 fs-4 text-success"></i>
                <h5 class="fw-bold mb-0">Edit Inventory by Size</h5>
            </div>
            
            @if (Model.SizeStocks != null && Model.SizeStocks.Any())
            {
                <div id="initialSizeStocks" style="display:none;">
                    @foreach (var ss in Model.SizeStocks)
                    {
                        <div class="initial-stock" data-size="@ss.Size" data-qty="@ss.StockQty"></div>
                    }
                </div>
            }

            <div class="row g-3" id="sizeStockInputs"></div>
            
            <div class="mt-3 p-2 bg-light rounded border border-dashed text-center">
                <span class="text-muted small">Total stock quantity will be automatically updated based on your changes above.</span>
            </div>
        </div>
        
        <div class="form-group">
            <label asp-for="AssignedEmployeeId"></label>
            <select asp-for="AssignedEmployeeId" asp-items="Model.EmployeeList" class="form-control">
                <option value="">-- No Assignment --</option>
            </select>
            <span asp-validation-for="AssignedEmployeeId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" rows="3" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Status</label>
            <select asp-for="Status" class="form-control">
                <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
            </select>
        </div>

        <div class="form-group form-check d-flex align-items-center">
            <input asp-for="IsApproved" class="form-check-input me-2" id="chkApproved" />
            <label asp-for="IsApproved" class="form-check-label mr-3"></label>
            <span id="approvedCheck" style="display: none; color: #28a745; font-size: 18px; font-weight: bold; margin-left: 10px;">✔ Approved!</span>
        </div>

        <div class="form-group">
            <label asp-for="ImageFile">Change Image (optional)</label>
            <div class="d-flex align-items-center gap-3">
                <input asp-for="ImageFile" type="file" class="form-control" id="imageInput" accept="image/*" style="flex: 1;" />
                <img id="imagePreview" src="#" alt="Preview" style="display:none; height: 50px; width: auto; border-radius: 4px; border: 1px solid #ddd;" />
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            <button type="submit" class="btn btn-success">Update</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            function calculateOffer() {
                var regPrice = parseFloat($('#regPrice').val()) || 0;
                var offPercent = parseFloat($('#offPercent').val()) || 0;
                var offerPrice = regPrice - (regPrice * (offPercent / 100));
                $('#offPrice').val(offerPrice.toFixed(2));
            }

            // Approved Checkbox Feedback
            function toggleApprovedCheck() {
                if ($('#chkApproved').is(':checked')) {
                    $('#approvedCheck').show();
                } else {
                    $('#approvedCheck').hide();
                }
            }
            $('#chkApproved').on('change', toggleApprovedCheck);
            toggleApprovedCheck(); // init on load

            // Image Preview
            $('#imageInput').on('change', function() {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imagePreview').attr('src', e.target.result).show();
                    }
                    reader.readAsDataURL(file);
                } else {
                    $('#imagePreview').hide();
                }
            });

            $('#regPrice, #offPercent').on('input keyup change paste', function() {
                calculateOffer();
            });
            
            // Size-wise stock logic
            $('.size-preset').on('click', function() {
                var size = $(this).data('size');
                var current = $('#availableSizes').val();
                if (current.includes(size)) return;
                
                if (current && !current.endsWith(',')) current += ', ';
                $('#availableSizes').val(current + size);
                updateSizeFields();
            });

            $('#availableSizes').on('input', function() {
                updateSizeFields();
            });

            function updateSizeFields() {
                var sizesStr = $('#availableSizes').val();
                var container = $('#sizeStockContainer');
                var inputsDiv = $('#sizeStockInputs');
                
                if (!sizesStr || sizesStr.trim() === '') {
                    container.hide();
                    inputsDiv.empty();
                    calculateTotalStock();
                    return;
                }

                var sizes = sizesStr.split(',').map(s => s.trim()).filter(s => s !== '');
                if (sizes.length === 0) {
                    container.hide();
                    inputsDiv.empty();
                    calculateTotalStock();
                    return;
                }

                container.show();
                var existingValues = {};
                
                // First check current inputs
                inputsDiv.find('input.size-stock-input').each(function() {
                    existingValues[$(this).attr('data-size')] = $(this).val();
                });

                // Then check initial values from DB (if current inputs are empty)
                $('.initial-stock').each(function() {
                    var s = $(this).attr('data-size');
                    var q = $(this).attr('data-qty');
                    if (existingValues[s] === undefined) {
                        existingValues[s] = q;
                    }
                });

                inputsDiv.empty();
                sizes.forEach((size, index) => {
                    var val = existingValues[size] || 0;
                    var html = `
                        <div class="col-md-4 col-sm-6 mb-3">
                            <div class="card bg-light border-0">
                                <div class="card-body p-2 text-center">
                                    <label class="fw-bold small d-block mb-1 text-success text-uppercase">${size}</label>
                                    <input type="number" name="SizeStocks[${index}].StockQty" 
                                           data-size="${size}" value="${val}" class="form-control form-control-sm size-stock-input text-center" min="0" />
                                    <input type="hidden" name="SizeStocks[${index}].Size" value="${size}" />
                                </div>
                            </div>
                        </div>`;
                    inputsDiv.append(html);
                });

                $('.size-stock-input').off('input').on('input', calculateTotalStock);
                calculateTotalStock();
            }

            function calculateTotalStock() {
                var total = 0;
                var inputs = $('.size-stock-input');
                inputs.each(function() {
                    total += parseInt($(this).val()) || 0;
                });
                
                var stockInput = $('input[name="StockQty"]');
                stockInput.val(total);
                
                if (inputs.length > 0) {
                    stockInput.prop('readonly', true).css('background-color', '#e9ecef');
                } else {
                    stockInput.prop('readonly', false).css('background-color', '#fff');
                }
            }

            // In case of validation reload
            calculateOffer();
            updateSizeFields();
        });
    </script>
}
