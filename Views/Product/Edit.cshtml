@model E_ShoppingManagement.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-3">Edit Product</h2>

<style>
    .size-toggle-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 14px;
        border: 1.5px solid #ced4da;
        border-radius: 20px;
        background: #fff;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        color: #555;
        transition: all 0.18s ease;
    }
    .size-toggle-btn .size-check-icon {
        display: none;
        color: #28a745;
        font-weight: 700;
    }
    .size-toggle-btn.active {
        background: #e6f4ea;
        border-color: #28a745;
        color: #1a7c35;
    }
    .size-toggle-btn.active .size-check-icon {
        display: inline;
    }
    .size-stock-input::-webkit-outer-spin-button,
    .size-stock-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .size-stock-input { -moz-appearance: textfield; }
</style>

<div class="page-card">

    @if (ViewBag.Message != null)
    {
        <div class="alert @(ViewBag.IsSuccess == true ? "alert-success" : "alert-danger")">
            @ViewBag.Message
        </div>
    }

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CategoryId"></label>
            <select asp-for="CategoryId" class="form-control" asp-items="Model.CategoryList">
                <option value="">-- Select Category --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ProductTypeId"></label>
            <select asp-for="ProductTypeId" class="form-control" asp-items="Model.ProductTypeList">
                <option value="">-- Select Product Type --</option>
            </select>
            <span asp-validation-for="ProductTypeId" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label>Regular Price</label>
                    <input asp-for="RegularPrice" id="regPrice" class="form-control" />
                    <span asp-validation-for="RegularPrice" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label>Offer %</label>
                    <input asp-for="OfferPercentage" id="offPercent" class="form-control" />
                    <span asp-validation-for="OfferPercentage" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label>Offer Price (Auto-calculated)</label>
            <input asp-for="Price" id="offPrice" class="form-control" readonly style="background-color: #e9ecef;" />
            <small class="text-muted">Calculated: Regular Price - (Regular Price * Offer % / 100)</small>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    <label asp-for="VatPercentage"></label>
                    <input asp-for="VatPercentage" class="form-control" />
                    <span asp-validation-for="VatPercentage" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="StockQty"></label>
            <input asp-for="StockQty" class="form-control" />
            <span asp-validation-for="StockQty" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MaxOrderQty">Max Order limit per Customer (Optional)</label>
            <input type="number" name="MaxOrderQty" value="@Model.MaxOrderQty" class="form-control" placeholder="Leave empty for no limit" />
        </div>

        <div class="form-group">
            <label asp-for="DisplayCategory"></label>
            <select asp-for="DisplayCategory" class="form-control" asp-items="Model.DisplayCategoryList">
                <option value="">-- None --</option>
            </select>
            <span asp-validation-for="DisplayCategory" class="text-danger"></span>
        </div>

        <input type="hidden" asp-for="AvailableSizes" id="availableSizesHidden" />

        <div class="form-group">
            <label>Available Sizes</label>
            <div class="d-flex flex-wrap gap-2 mt-1">
                @{
                    var sizesList = new[] { "S", "M", "L", "XL", "XXL", "3XL" };
                    var savedSizes = (Model?.AvailableSizes ?? "").Split(',').Select(s => s.Trim()).ToList();
                }
                @foreach (var sz in sizesList)
                {
                    var isActive = savedSizes.Contains(sz);
                    <button type="button" class="size-toggle-btn @(isActive ? "active" : "")" data-size="@sz">
                        <span class="size-check-icon">&#10003;</span> @sz
                    </button>
                }
            </div>
        </div>

        <div class="form-group">
            <label>Size Wise Quantity</label>
            <div class="d-flex flex-wrap gap-3 mt-1">
                @{
                    int idx = 0;
                }
                @foreach (var size in sizesList)
                {
                    var stockVal = Model?.SizeStocks?.FirstOrDefault(s => s.Size == size)?.StockQty ?? 0;
                    var isActive2 = savedSizes.Contains(size);
                    <div class="size-stock-row" data-size="@size" style="display:@(isActive2 ? "flex" : "none");">
                        <div class="d-flex flex-column align-items-center">
                            <small class="text-muted mb-1 fw-semibold">@size</small>
                            <div class="input-group" style="width:110px;">
                                <button type="button" class="btn btn-outline-secondary btn-sm size-dec" data-target="sizeQty_@size">&#8722;</button>
                                <input type="number" id="sizeQty_@size" name="SizeStocks[@idx].StockQty" value="@stockVal" class="form-control form-control-sm size-stock-input text-center" min="0" />
                                <button type="button" class="btn btn-outline-secondary btn-sm size-inc" data-target="sizeQty_@size">&#43;</button>
                            </div>
                            <input type="hidden" name="SizeStocks[@idx].Size" value="@size" />
                        </div>
                    </div>
                    idx++;
                }
            </div>
            <small class="text-muted mt-2 d-block">Total stock quantity will be automatically calculated.</small>
        </div>
        
        <div class="form-group">
            <label asp-for="AssignedEmployeeId"></label>
            <select asp-for="AssignedEmployeeId" asp-items="Model.EmployeeList" class="form-control">
                <option value="">-- No Assignment --</option>
            </select>
            <span asp-validation-for="AssignedEmployeeId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" rows="3" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Status</label>
            <select asp-for="Status" class="form-control">
                <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
            </select>
        </div>

        <div class="form-group form-check d-flex align-items-center">
            <input asp-for="IsApproved" class="form-check-input me-2" id="chkApproved" />
            <label asp-for="IsApproved" class="form-check-label mr-3"></label>
            <span id="approvedCheck" style="display: none; color: #28a745; font-size: 18px; font-weight: bold; margin-left: 10px;">✔ Approved!</span>
        </div>

        <div class="form-group">
            <label asp-for="ImageFile">Change Image (optional)</label>
            <div class="d-flex align-items-center gap-3">
                <input asp-for="ImageFile" type="file" class="form-control" id="imageInput" accept="image/*" style="flex: 1;" />
                <img id="imagePreview" src="#" alt="Preview" style="display:none; height: 50px; width: auto; border-radius: 4px; border: 1px solid #ddd;" />
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            <button type="submit" class="btn btn-success">Update</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            function calculateOffer() {
                var regPrice = parseFloat($('#regPrice').val()) || 0;
                var offPercent = parseFloat($('#offPercent').val()) || 0;
                var offerPrice = regPrice - (regPrice * (offPercent / 100));
                $('#offPrice').val(offerPrice.toFixed(2));
            }

            // Approved Checkbox Feedback
            function toggleApprovedCheck() {
                if ($('#chkApproved').is(':checked')) {
                    $('#approvedCheck').show();
                } else {
                    $('#approvedCheck').hide();
                }
            }
            $('#chkApproved').on('change', toggleApprovedCheck);
            toggleApprovedCheck(); // init on load

            // Image Preview
            $('#imageInput').on('change', function() {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imagePreview').attr('src', e.target.result).show();
                    }
                    reader.readAsDataURL(file);
                } else {
                    $('#imagePreview').hide();
                }
            });

            $('#regPrice, #offPercent').on('input keyup change paste', function() {
                calculateOffer();
            });

            // Size toggle button click
            $(document).on('click', '.size-toggle-btn', function() {
                $(this).toggleClass('active');
                var size = $(this).data('size');
                var row = $('.size-stock-row[data-size="' + size + '"]');
                if ($(this).hasClass('active')) {
                    row.css('display', 'flex');
                } else {
                    row.hide();
                    row.find('.size-stock-input').val(0);
                }
                calculateTotalStock();
            });

            // +/- buttons
            $(document).on('click', '.size-inc', function() {
                var inp = $('#' + $(this).data('target'));
                inp.val((parseInt(inp.val()) || 0) + 1);
                calculateTotalStock();
            });
            $(document).on('click', '.size-dec', function() {
                var inp = $('#' + $(this).data('target'));
                var v = (parseInt(inp.val()) || 0) - 1;
                inp.val(v < 0 ? 0 : v);
                calculateTotalStock();
            });

            function calculateTotalStock() {
                var total = 0;
                var availSizes = [];
                $('.size-toggle-btn.active').each(function() {
                    availSizes.push($(this).data('size'));
                });
                $('.size-stock-row:visible .size-stock-input').each(function() {
                    total += parseInt($(this).val()) || 0;
                });

                var stockInput = $('input[name="StockQty"]');
                stockInput.val(total);
                $('#availableSizesHidden').val(availSizes.join(', '));

                var anyActive = $('.size-toggle-btn.active').length > 0;
                stockInput.prop('readonly', anyActive).css('background-color', anyActive ? '#e9ecef' : '');
            }

            $(document).on('input', '.size-stock-input', calculateTotalStock);

            // Initial calculation
            calculateOffer();
            calculateTotalStock();
        });
    </script>
}
