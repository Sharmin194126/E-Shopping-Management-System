@model E_ShoppingManagement.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Create Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-3">Create Product</h2>

<style>
    /* Square checkbox style */
    .size-chk-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 500;
        color: #333;
        user-select: none;
    }
    .size-chk-label input[type="checkbox"] {
        display: none;
    }
    .size-chk-box {
        width: 20px;
        height: 20px;
        border: 2px solid #6c757d;
        border-radius: 3px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        flex-shrink: 0;
        transition: border-color 0.15s;
    }
    .size-chk-label input[type="checkbox"]:checked + .size-chk-box {
        border-color: #333;
    }
    .size-chk-label input[type="checkbox"]:checked + .size-chk-box::after {
        content: '\2713';
        font-size: 13px;
        font-weight: 700;
        color: #333;
    }
    /* Size quantity input group */
    .size-qty-group {
        display: none;
    }
    .size-qty-group .input-group-text {
        min-width: 42px;
        justify-content: center;
        font-weight: 600;
        background: #fff;
    }
    .size-qty-group input[type=number] {
        width: 70px;
        text-align: center;
    }
</style>

<div class="page-card">
    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CategoryId"></label>
            <select asp-for="CategoryId" class="form-control" asp-items="Model.CategoryList">
                <option value="">Select Category</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ProductTypeId"></label>
            <select asp-for="ProductTypeId" class="form-control" asp-items="Model.ProductTypeList">
                <option value="">Select Product Type</option>
            </select>
            <span asp-validation-for="ProductTypeId" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label>Regular Price</label>
                    <input asp-for="RegularPrice" id="regPrice" class="form-control" />
                    <span asp-validation-for="RegularPrice" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label>Offer %</label>
                    <input asp-for="OfferPercentage" id="offPercent" class="form-control" />
                    <span asp-validation-for="OfferPercentage" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label>Offer Price (Auto-calculated)</label>
            <input asp-for="Price" id="offPrice" class="form-control" readonly style="background-color: #e9ecef;" />
            <small class="text-muted">Calculated: Regular Price - (Regular Price * Offer % / 100)</small>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    <label asp-for="VatPercentage"></label>
                    <input asp-for="VatPercentage" class="form-control" />
                    <span asp-validation-for="VatPercentage" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="StockQty"></label>
            <input asp-for="StockQty" class="form-control" />
            <span asp-validation-for="StockQty" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MaxOrderQty">Max Order limit per Customer (Optional)</label>
            <input asp-for="MaxOrderQty" class="form-control" placeholder="Enter max quantity allowed per order (Leave empty for no limit)" data-val="false" />
            <span asp-validation-for="MaxOrderQty" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DisplayCategory"></label>
            <select asp-for="DisplayCategory" class="form-control" asp-items="Model.DisplayCategoryList">
                <option value="">-- None --</option>
            </select>
            <span asp-validation-for="DisplayCategory" class="text-danger"></span>
        </div>

        <input type="hidden" asp-for="AvailableSizes" id="availableSizesHidden" />

        <div class="form-group">
            <label>Available Sizes</label>
            <div class="d-flex flex-wrap gap-4 mt-2">
                @{
                    var sizesList = new[] { "S", "M", "L", "XL", "XXL", "3XL" };
                }
                @foreach (var sz in sizesList)
                {
                    <label class="size-chk-label">
                        <input type="checkbox" class="size-checkbox" value="@sz" id="sizeChk_@sz" />
                        <span class="size-chk-box"></span>
                        @sz
                    </label>
                }
            </div>
        </div>

        <div class="form-group">
            <label>Size Wise Quantity</label>
            <div class="d-flex flex-wrap gap-3 mt-2">
                @{
                    int idx = 0;
                }
                @foreach (var size in sizesList)
                {
                    <div class="size-qty-group" data-size="@size">
                        <div class="input-group">
                            <span class="input-group-text">@size</span>
                            <input type="number" id="sizeQty_@size"
                                   name="SizeStocks[@idx].StockQty"
                                   value="0"
                                   class="form-control size-stock-input text-center"
                                   min="0" style="width:70px;" />
                        </div>
                        <input type="hidden" name="SizeStocks[@idx].Size" value="@size" />
                    </div>
                    idx++;
                }
            </div>
            <small class="text-muted mt-2 d-block">Total stock quantity will be automatically calculated.</small>
        </div>
        
        <div class="form-group">
            <label asp-for="AssignedEmployeeId"></label>
            <select asp-for="AssignedEmployeeId" asp-items="Model.EmployeeList" class="form-control">
                <option value="">-- No Assignment --</option>
            </select>
            <span asp-validation-for="AssignedEmployeeId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" rows="3" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Status</label>
            <select asp-for="Status" class="form-control">
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>

        <div class="form-group form-check d-flex align-items-center">
            <input asp-for="IsApproved" class="form-check-input me-2" id="chkApproved" />
            <label asp-for="IsApproved" class="form-check-label mr-3"></label>
            <span id="approvedCheck" style="display: none; color: #28a745; font-size: 18px; font-weight: bold; margin-left: 10px;">✔ Approved!</span>
        </div>

        <div class="form-group">
            <label asp-for="ImageFile">Image</label>
            <div class="d-flex align-items-center gap-3">
                <input asp-for="ImageFile" type="file" class="form-control" id="imageInput" accept="image/*" style="flex: 1;" />
                <img id="imagePreview" src="#" alt="Preview" style="display:none; height: 50px; width: auto; border-radius: 4px; border: 1px solid #ddd;" />
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            <button type="submit" class="btn btn-primary">Save</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            function calculateOffer() {
                var regPrice = parseFloat($('#regPrice').val()) || 0;
                var offPercent = parseFloat($('#offPercent').val()) || 0;
                var offerPrice = regPrice - (regPrice * (offPercent / 100));
                $('#offPrice').val(offerPrice.toFixed(2));
            }

            // Approved Checkbox Feedback
            function toggleApprovedCheck() {
                if ($('#chkApproved').is(':checked')) {
                    $('#approvedCheck').show();
                } else {
                    $('#approvedCheck').hide();
                }
            }
            $('#chkApproved').on('change', toggleApprovedCheck);
            toggleApprovedCheck(); // init on load

            // Image Preview
            $('#imageInput').on('change', function() {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imagePreview').attr('src', e.target.result).show();
                    }
                    reader.readAsDataURL(file);
                } else {
                    $('#imagePreview').hide();
                }
            });

            $('#regPrice, #offPercent').on('input keyup change paste', function() {
                calculateOffer();
            });
            
            // Size checkbox → show/hide quantity row
            $(document).on('change', '.size-checkbox', function() {
                var size = $(this).val();
                var row = $('.size-qty-group[data-size="' + size + '"]');
                if ($(this).is(':checked')) {
                    row.show();
                } else {
                    row.hide();
                    row.find('.size-stock-input').val(0);
                }
                calculateTotalStock();
            });

            function calculateTotalStock() {
                var total = 0;
                var availSizes = [];
                $('.size-checkbox:checked').each(function() {
                    availSizes.push($(this).val());
                });
                $('.size-qty-group:visible .size-stock-input').each(function() {
                    total += parseInt($(this).val()) || 0;
                });

                var stockInput = $('input[name="StockQty"]');
                stockInput.val(total);
                $('#availableSizesHidden').val(availSizes.join(', '));

                var anyChecked = $('.size-checkbox:checked').length > 0;
                stockInput.prop('readonly', anyChecked).css('background-color', anyChecked ? '#e9ecef' : '');
            }

            $(document).on('input', '.size-stock-input', calculateTotalStock);

            // Initial calculation
            calculateOffer();
            calculateTotalStock();
        });
    </script>
}
