@model IEnumerable<E_ShoppingManagement.Models.Order>
@{
    ViewData["Title"] = "Delivery Performance";
    Layout = User.IsInRole("Admin") ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Performance Report: @ViewBag.DeliveryMan?.Name</h2>
    <a asp-action="Index" class="theme-back-btn">Back to List</a>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="analytics-metric-card" style="background: linear-gradient(135deg, #2e7d32, #1b5e20);">
            <div class="amc-icon"><i class="bi bi-check-circle-fill"></i></div>
            <div class="amc-label">Successfully Delivered</div>
            <div class="amc-value">@ViewBag.Delivered</div>
            <div class="amc-sub">Total completed deliveries</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="analytics-metric-card" style="background: linear-gradient(135deg, #f57c00, #e65100);">
            <div class="amc-icon"><i class="bi bi-truck"></i></div>
            <div class="amc-label">In Transit / Pending</div>
            <div class="amc-value">@ViewBag.Pending</div>
            <div class="amc-sub">Currently active assignments</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="analytics-metric-card" style="background: linear-gradient(135deg, #d32f2f, #b71c1c);">
            <div class="amc-icon"><i class="bi bi-x-circle-fill"></i></div>
            <div class="amc-label">Returned Parcels</div>
            <div class="amc-value">@ViewBag.Returned</div>
            <div class="amc-sub">Orders failed or returned</div>
        </div>
    </div>
</div>

<style>
    .analytics-metric-card { border-radius:12px; padding:20px; color:#fff; position:relative; overflow:hidden; height:100%; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
    .analytics-metric-card .amc-icon { font-size:2.2rem; opacity:.25; position:absolute; right:15px; bottom:10px; }
    .analytics-metric-card .amc-label { font-size:12px; opacity:.85; text-transform:uppercase; font-weight: 600; letter-spacing:.5px; }
    .analytics-metric-card .amc-value { font-size:2rem; font-weight:700; margin:5px 0; }
    .analytics-metric-card .amc-sub { font-size:11px; opacity:.7; }
</style>

<div class="page-card p-4">
    <h4>Assigned Order History</h4>
    <div class="table-responsive mt-3">
        <table class="table table-hover align-middle">
            <thead style="background: #532374; color: #fff;">
                <tr>
                    <th class="ps-3 py-3">Order #</th>
                    <th class="py-3">Customer</th>
                    <th class="py-3">Status</th>
                    <th class="py-3">Amount</th>
                    <th class="py-3">Payment</th>
                    <th class="py-3 pe-3">Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.Customer?.Name</td>
                        <td>
                            <span class="badge @(order.OrderStatus == "Delivered" ? "bg-success" : (order.OrderStatus == "Returned" ? "bg-danger" : "bg-warning"))">
                                @order.OrderStatus
                            </span>
                        </td>
                        <td>৳@order.TotalAmount</td>
                        <td>
                            @if (order.PaymentStatus == "Paid")
                            {
                                <span class="badge bg-success">Paid (@order.PaymentMethod)</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pending (@order.PaymentMethod)</span>
                                @if (order.PaymentMethod?.Contains("COD") == true || order.PaymentMethod?.Contains("Cash") == true)
                                {
                                    <!-- Button to mark as received -->
                                     <form asp-controller="Order" asp-action="UpdatePaymentStatus" method="post" class="d-inline ms-1">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <input type="hidden" name="status" value="Paid" />
                                        <button type="submit" class="btn btn-xs btn-outline-primary p-0 px-1" style="font-size: 0.7rem;">Mark Paid</button>
                                    </form>
                                }
                            }
                        </td>
                        <td>@order.CreatedAt.ToString("MMM dd, yyyy | hh:mm tt")</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No delivery history found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
