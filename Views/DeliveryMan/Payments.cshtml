@model IEnumerable<E_ShoppingManagement.Models.DeliveryManPayment>
@{
    var dm = ViewBag.DeliveryMan as E_ShoppingManagement.Models.DeliveryMan;
    ViewData["Title"] = "Commission Payments - " + dm?.Name;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>💰 Commissions: @dm?.Name</h2>
        <a asp-action="Index" class="theme-back-btn">Back to List</a>
    </div>

    <div class="row mb-4 g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="background: #ffffff; border-radius: 20px; transition: transform 0.3s ease; box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="icon-box me-3" style="background: rgba(40, 167, 69, 0.1); color: #28a745; width: 60px; height: 60px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                        <i class="bi bi-wallet2"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 1px;">Total Earnings</div>
                        <div class="h3 mb-0 fw-bold" style="color: #2e7d32;">৳@dm?.TotalEarnings</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="background: #ffffff; border-radius: 20px; transition: transform 0.3s ease; box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="icon-box me-3" style="background: rgba(0, 123, 255, 0.1); color: #007bff; width: 60px; height: 60px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 1px;">Total Paid</div>
                        <div class="h3 mb-0 fw-bold" style="color: #0056b3;">৳@dm?.PaidAmount</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="background: #ffffff; border-radius: 20px; transition: transform 0.3s ease; box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="icon-box me-3" style="background: rgba(255, 193, 7, 0.1); color: #ffc107; width: 60px; height: 60px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 1px;">Pending Balance</div>
                        <div class="h3 mb-0 fw-bold" style="color: #856404;">৳@dm?.PendingAmount</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (dm?.PendingAmount > 0)
    {
        <div class="card border-0 mb-4 shadow-sm" style="border-radius: 15px; background: #fff;">
            <div class="card-body p-4">
                <h5 class="card-title fw-bold mb-3" style="color: #532374;">Process New Payout</h5>
                <form asp-action="ProcessPayout" method="post" class="row g-3">
                    <input type="hidden" name="id" value="@dm.Id" />
                    <div class="col-auto">
                        <label class="visually-hidden">Amount</label>
                        <div class="input-group">
                            <div class="input-group-text bg-white border-end-0">৳</div>
                            <input type="number" name="amount" class="form-control border-start-0 ps-0" placeholder="Amount" step="0.01" max="@dm.PendingAmount" required>
                        </div>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn px-4 text-white" style="background: #532374; border-radius: 8px;">Payout Now</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
        <div class="card-header border-0 d-flex justify-content-between align-items-center p-3" style="background: #532374;">
            <h5 class="mb-0 text-white fw-bold">Transaction History</h5>
            <small class="text-white-50">History of commission payouts</small>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead style="background: #532374 !important; color: #fff !important;">
                    <tr>
                        <th class="ps-3">Date & Time</th>
                        <th>Order #</th>
                        <th>Order Total</th>
                        <th>Commission (Earned)</th>
                        <th>Status</th>
                        <th class="pe-3">Paid Date</th>
                    </tr>
                </thead>
                <tbody style="background: #fdfcf9;">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3">@item.CreatedAt.ToString("MMM dd, yyyy | hh:mm tt")</td>
                            <td><a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId" class="text-decoration-none fw-bold" style="color: #532374;">#@item.OrderId</a></td>
                            <td>৳@item.OrderTotal</td>
                            <td class="fw-bold text-success">৳@item.CommissionAmount</td>
                            <td>
                                @if(item.Status == "Paid") {
                                    <span class="badge" style="background: #e8f5e9; color: #2e7d32; border: 1px solid #2e7d32; border-radius: 20px;"><i class="bi bi-check-lg"></i> Paid</span>
                                } else {
                                    <span class="badge" style="background: #fff3e0; color: #ef6c00; border: 1px solid #ef6c00; border-radius: 20px;"><i class="bi bi-hourglass-split"></i> Pending</span>
                                }
                            </td>
                            <td class="pe-3">@(item.PaidAt?.ToString("MMM dd, yyyy | hh:mm tt") ?? "-")</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox display-4 d-block mb-2"></i>
                                No commissions registered yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
