@model IEnumerable<E_ShoppingManagement.Models.Employee>

@{
    ViewData["Title"] = "Employees";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Employees</h2>
    <a asp-controller="AdminDashboard" asp-action="Index" class="theme-back-btn mb-0">Back</a>
</div>

<div class="page-card mb-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">All Employees</h5>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Employee
        </a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert @(TempData["IsSuccess"] as bool? == true ? "alert-success" : "alert-danger")">
            @TempData["Message"]
        </div>
    }

    <table class="table table-hover table-bordered">
        <thead style="background:#532374 !important; color:#fff !important;">
            <tr>
                <th style="width:70px;">SL No</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Designation</th>
                <th>Joining Date</th>
                <th>Status</th>
                <th>Approval</th>
                <th style="width: 190px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                var sl = 1;
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="9" class="text-center text-muted">No employees found.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@(sl++)</td>
                        <td>@item.Name</td>
                        <td>@item.Email</td>
                        <td>@item.PhoneNumber</td>
                        <td>@item.Designation</td>
                        <td>@item.JoiningDate.ToShortDateString()</td>
                        <td>
                            @if (item.Status == "Active")
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else if (item.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Disapproved</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@item.Status</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.Status != "Active")
                            {
                                <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-primary px-3">
                                        <i class="bi bi-check-circle me-1"></i>Approve
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Disapprove" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3" onclick="return confirm('Disapprove this employee? They will not be able to log in.')">
                                        <i class="bi bi-x-circle me-1"></i>Disapprove
                                    </button>
                                </form>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-success">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
