@model IEnumerable<E_ShoppingManagement.Models.PaymentMethod>
@{
    ViewData["Title"] = "Payment Methods";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Manage Payment Methods</h2>
    <a asp-action="Index" class="theme-back-btn mb-0">Back</a>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="page-card mb-4">
            <h5>Add New Method</h5>
            <form asp-action="AddPaymentMethod" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">Method Name (e.g. bKash, Nagad)</label>
                    <input name="Name" class="form-control" required placeholder="Enter method name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Details / Instructions</label>
                    <textarea name="Details" class="form-control" rows="3" placeholder="Account number or usage details"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Logo Icon</label>
                    <input type="file" name="logoFile" class="form-control" accept="image/*" />
                </div>
                @* <input type="hidden" name="IsActive" value="true" /> *@
                <button type="submit" class="btn btn-primary w-100">Add Method</button>
            </form>
        </div>
    </div>
    <div class="col-md-8">
        <div class="page-card">
            <h5>Existing Methods</h5>
            <table class="table table-hover">
                <thead style="background:#532374; color:#fff;">
                    <tr>
                        <th style="width: 70px;">SL No</th>
                        <th>Name</th>
                        <th>Account Details</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var sl = 1; }
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>@(sl++)</td>
                            <td>
                                @if(!string.IsNullOrEmpty(m.LogoUrl)){
                                    <img src="@m.LogoUrl" style="height: 20px; margin-right: 10px;" />
                                }
                                <strong>@m.Name</strong>
                            </td>
                            <td>@m.Details</td>
                            <td><span class="badge @(m.Status == "Active" ? "bg-success" : "bg-danger")">@m.Status</span></td>
                            <td>@m.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="EditPaymentMethod" asp-route-id="@m.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <form asp-action="DeletePaymentMethod" asp-route-id="@m.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this payment method?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
