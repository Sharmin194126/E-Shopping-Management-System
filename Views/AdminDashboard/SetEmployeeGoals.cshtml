@model List<E_ShoppingManagement.ViewModels.EmployeeGoalViewModel>
@{
    ViewData["Title"] = "Set Employee Goals";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1" style="color:#532374;">🎯 Employee Sales Goals</h3>
        <p class="text-muted mb-0">Set and management yearly targets for your sales team.</p>
    </div>
    <a asp-action="Index" class="theme-back-btn mb-0">Back to Dashboard</a>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" style="border-radius: 12px; background: #d1e7dd; color: #0f5132;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm" style="border-radius: 16px; background: #fff; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: #f8f6f0; color: #532374;">
                <tr>
                    <th class="ps-4 py-3" style="font-weight: 600;">Employee Name</th>
                    <th class="py-3" style="font-weight: 600;">Designation</th>
                    <th class="py-3" style="font-weight: 600;">Current Goal (@DateTime.Now.Year)</th>
                    <th class="pe-4 py-3 text-end" style="font-weight: 600;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="avatar-circle me-3" style="background: #e9ecef; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #532374; font-weight: bold;">
                                    @emp.EmployeeName.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">@emp.EmployeeName</div>
                                    <small class="text-muted">ID: #EMP-@emp.EmployeeId</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border px-3 rounded-pill">@emp.Designation</span>
                        </td>
                        <td>
                            <div class="fw-bold" style="color: #532374; font-size: 1.1rem;">৳@emp.CurrentGoal.ToString("#,##0")</div>
                        </td>
                        <td class="pe-4 text-end">
                            <button type="button" class="btn btn-sm btn-primary px-4 rounded-pill fw-bold" 
                                    style="background: #532374; border: none; transition: all 0.3s;"
                                    data-bs-toggle="modal" data-bs-target="#editGoalModal-@emp.EmployeeId">
                                <i class="bi bi-pencil-square me-1"></i> Edit Goal
                            </button>

                            <!-- Modal for each employee -->
                            <div class="modal fade" id="editGoalModal-@emp.EmployeeId" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 shadow" style="border-radius: 20px; text-align: left;">
                                        <div class="modal-header border-0 pb-0" style="padding: 25px 30px;">
                                            <h5 class="modal-title fw-bold" style="color: #532374;">Update Goal: @emp.EmployeeName</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <form asp-action="UpdateEmployeeGoal" method="post">
                                            <div class="modal-body" style="padding: 20px 30px 30px;">
                                                <input type="hidden" name="employeeId" value="@emp.EmployeeId" />
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold text-muted small mb-2">TARGET REVENUE (৳)</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text border-end-0" style="background: #f8f6f0; border-radius: 12px 0 0 12px; color: #532374; font-weight: bold;">৳</span>
                                                        <input type="number" name="goalAmount" class="form-control border-start-0" 
                                                               style="border-radius: 0 12px 12px 0; background: #f8f6f0; font-weight: 600;"
                                                               value="@emp.CurrentGoal" step="0.01" required min="0" />
                                                    </div>
                                                    <div class="form-text mt-2 small">This goal is for the fiscal year @DateTime.Now.Year.</div>
                                                </div>
                                            </div>
                                            <div class="modal-footer border-0 pt-0" style="padding: 0 30px 25px;">
                                                <button type="button" class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal" style="border-radius: 12px;">Cancel</button>
                                                <button type="submit" class="btn btn-primary px-4 fw-bold" style="background: #532374; border: none; border-radius: 12px;">Save Changes</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <style>
        .table > :not(caption) > * > * {
            padding: 1.25rem 0.5rem;
        }
        .table tr:hover {
            background-color: #fcfbf8 !important;
        }
        .btn-primary:hover {
            background: #3d1a55 !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(83, 35, 116, 0.2);
        }
    </style>
}
