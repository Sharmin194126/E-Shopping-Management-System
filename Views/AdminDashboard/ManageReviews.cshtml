@model IEnumerable<E_ShoppingManagement.ViewModels.ReviewViewModel>
@{
    ViewData["Title"] = "Manage Customer Reviews";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Manage Customer Reviews</h2>
    <a asp-action="Index" class="theme-back-btn mb-0">Back</a>
</div>

<div class="card border-0 shadow-sm" style="background:#f2efe9;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#532374 !important; color:#fff !important;">
                    <tr>
                        <th style="width: 70px;">SL No</th>
                        <th>Date</th>
                        <th>Product</th>
                        <th>Customer</th>
                        <th>Rating</th>
                        <th>Comment</th>
                        <th>Images</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var sl = 1; }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(sl++)</td>
                            <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td><span class="fw-bold">@item.ProductName</span></td>
                            <td>@item.CustomerName</td>
                            <td>
                                <span class="text-warning">
                                    @for(int i=0; i<item.Rating; i++) { <text>★</text> }
                                    @for(int i=item.Rating; i<5; i++) { <text>☆</text> }
                                </span>
                            </td>
                            <td><small>@item.Comment</small></td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrls))
                                {
                                    <div class="d-flex gap-1 flex-wrap">
                                        @foreach (var img in item.ImageUrls.Split(','))
                                        {
                                            <a href="@img" target="_blank">
                                                <img src="@img" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" />
                                            </a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small">No images</span>
                                }
                            </td>
                            <td>
                                <form asp-action="UpdateReviewStatus" method="post" class="d-flex align-items-center">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <select name="status" class="form-select form-select-sm me-2" onchange="this.form.submit()">
                                        <option value="Pending" selected="@(item.Status == "Pending")">Pending</option>
                                        <option value="Active" selected="@(item.Status == "Active")">Approved</option>
                                        <option value="Rejected" selected="@(item.Status == "Rejected")">Rejected</option>
                                    </select>
                                </form>
                            </td>
                            <td class="text-end">
                                <a asp-action="DeleteReview" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-4 text-muted">No reviews found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

