@model IEnumerable<E_ShoppingManagement.Models.Order>
@{
    ViewData["Title"] = "Employee Analytics";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Performance: @ViewBag.EmployeeName</h2>
    <a asp-action="Index" class="theme-back-btn mb-0">Back</a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="page-card text-center p-3" style="background: rgba(83,35,116,0.08);">
            <h3 class="text-primary">@ViewBag.TotalProducts</h3>
            <p class="mb-0 text-muted">Managed Products</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="page-card text-center p-3" style="background: rgba(40,167,69,0.08);">
            <h3 class="text-success">৳@ViewBag.TotalProductValue</h3>
            <p class="mb-0 text-muted">Stock Value</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="page-card text-center p-3" style="background: rgba(255,193,7,0.12);">
            <h3 class="text-warning">@ViewBag.TotalSalesCount</h3>
            <p class="mb-0 text-muted">Orders Delivered</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="page-card text-center p-3" style="background: rgba(220,53,69,0.08);">
            <h3 class="text-danger">@ViewBag.ReturnsCount</h3>
            <p class="mb-0 text-muted">Returns/Issues</p>
        </div>
    </div>
</div>

<div class="page-card p-4">
    <h4>Recent Successful Sales</h4>
    <div class="table-responsive mt-3">
        <table class="table table-hover align-middle">
            <thead style="background:#532374; color:#fff;">
                <tr>
                    <th style="width: 70px;">SL No</th>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Revenue</th>
                </tr>
            </thead>
            <tbody>
                @{ var sl = 1; }
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@(sl++)</td>
                        <td>@order.Id</td>
                        <td>@order.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>@order.OrderDetails?.Count items</td>
                        <td class="fw-bold">৳@order.TotalAmount</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted">No delivered orders yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
