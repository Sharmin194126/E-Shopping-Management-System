@model IEnumerable<E_ShoppingManagement.Models.Order>
@{
    ViewData["Title"] = "Employee Analytics";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Performance: @ViewBag.EmployeeName</h2>
    <a asp-action="Index" class="theme-back-btn mb-0">Back</a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="page-card text-center p-4 border-0 shadow-sm transition-hover" style="background: linear-gradient(135deg, #532374, #7a3a9d); color: white; border-radius: 15px;">
            <i class="bi bi-box-seam mb-2" style="font-size: 2rem; opacity: 0.8;"></i>
            <h3 class="fw-bold mb-1">@ViewBag.TotalProducts</h3>
            <p class="mb-0 small" style="opacity: 0.9;">Managed Products</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="page-card text-center p-4 border-0 shadow-sm transition-hover" style="background: linear-gradient(135deg, #28a745, #4cd137); color: white; border-radius: 15px;">
            <i class="bi bi-currency-dollar mb-2" style="font-size: 2rem; opacity: 0.8;"></i>
            <h3 class="fw-bold mb-1">৳@ViewBag.TotalProductValue.ToString("#,##0")</h3>
            <p class="mb-0 small" style="opacity: 0.9;">Stock Value</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="page-card text-center p-4 border-0 shadow-sm transition-hover" style="background: linear-gradient(135deg, #f59e0b, #fbbf24); color: white; border-radius: 15px;">
            <i class="bi bi-cart-check mb-2" style="font-size: 2rem; opacity: 0.8;"></i>
            <h3 class="fw-bold mb-1">@ViewBag.TotalSalesCount</h3>
            <p class="mb-0 small" style="opacity: 0.9;">Orders Delivered</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="page-card text-center p-4 border-0 shadow-sm transition-hover" style="background: linear-gradient(135deg, #ef4444, #f87171); color: white; border-radius: 15px;">
            <i class="bi bi-exclamation-triangle mb-2" style="font-size: 2rem; opacity: 0.8;"></i>
            <h3 class="fw-bold mb-1">@ViewBag.ReturnsCount</h3>
            <p class="mb-0 small" style="opacity: 0.9;">Returns/Issues</p>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }
</style>

<div class="page-card p-4">
    <h4>Recent Successful Sales</h4>
    <div class="table-responsive mt-3">
        <table class="table table-hover align-middle">
            <thead style="background:#532374; color:#fff;">
                <tr>
                    <th style="width: 70px;">SL No</th>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Revenue</th>
                </tr>
            </thead>
            <tbody>
                @{ var sl = 1; }
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@(sl++)</td>
                        <td>@order.Id</td>
                        <td>@order.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>@order.OrderDetails?.Count items</td>
                        <td class="fw-bold">৳@order.TotalAmount</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted">No delivered orders yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
