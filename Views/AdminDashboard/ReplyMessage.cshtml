@model E_ShoppingManagement.Models.ContactMessage
@{
    ViewData["Title"] = "Reply to Message";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Reply to Customer Inquiry</h2>
    <a asp-action="Messages" class="btn btn-secondary">Back to Messages</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="page-card mb-4">
            <h5 class="border-bottom pb-2 mb-3">Customer's Original Message</h5>
            <p><strong>From:</strong> @Model.Name (@Model.Email)</p>
            <p><strong>Subject:</strong> @Model.Subject</p>
            <p><strong>Date:</strong> @Model.CreatedAt.ToLocalTime()</p>
            <hr />
            <div class="p-3 bg-light rounded">
                @Model.Message
            </div>
            @if (!string.IsNullOrEmpty(Model.AttachmentUrl))
            {
                <div class="mt-3">
                    <strong>Attachment:</strong> 
                    <a href="@Model.AttachmentUrl" target="_blank" class="btn btn-sm btn-outline-info ms-2">View File</a>
                </div>
            }
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="page-card">
            <h5 class="border-bottom pb-2 mb-3">Your Response</h5>
            <form asp-action="ReplyMessage" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Reply Content</label>
                    <textarea name="reply" class="form-control" rows="10" placeholder="Type your response here..." required></textarea>
                </div>
                <button type="submit" class="btn btn-primary px-5 py-2 fw-bold">Send Reply</button>
            </form>
            <div class="alert alert-info mt-4 small">
                <i class="bi bi-info-circle me-1"></i>
                Note: This will mark the message as "Replied". Ensure you have configured an email service if you want to send an actual email to the customer.
            </div>
        </div>
    </div>
</div>
