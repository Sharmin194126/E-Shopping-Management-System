@using E_ShoppingManagement.Models
@{
    ViewData["Title"] = "System Notifications";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var orders = ViewBag.RecentOrders as List<Order>;
    var customers = ViewBag.RecentCustomers as List<Customer>;
    var employees = ViewBag.RecentEmployees as List<Employee>;
    var messages = ViewBag.RecentMessages as List<ContactMessage>;
    var lastCheck = ViewBag.LastNotificationCheck as DateTime? ?? DateTime.UtcNow.AddHours(-24);
}

<style>
    .notification-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 15px;
        height: 100%;
    }
    .notification-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .new-notification {
        background-color: #fff9f0 !important;
        border-right: 4px solid #532374 !important;
    }
    .badge-new {
        background: linear-gradient(135deg, #FF6B35, #FFB200);
        color: white;
        padding: 4px 10px;
        border-radius: 50rem;
        font-size: 10px;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.5px;
    }
    .text-theme { color: #532374 !important; }
    .bg-theme { background-color: #532374 !important; }
    .livechat-badge {
        background-color: #fce4ec !important;
        color: #d81b60 !important;
        font-weight: 700 !important;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-theme"><i class="bi bi-bell-fill me-2"></i> All Notifications & Activities</h3>
    <a href="javascript:history.back()" class="theme-back-btn mb-0" style="text-decoration: none;">Back</a>
</div>

<div class="row g-4">
    <!-- Orders Activity -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius: 15px;">
            <div class="card-header py-3 border-0" style="background:#532374; border-radius: 15px 15px 0 0;">
                <h5 class="mb-0 fw-bold text-white"><i class="bi bi-cart-check me-2"></i>Recent Orders</h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (orders != null && orders.Any())
                    {
                        foreach (var order in orders)
                        {
                            var isNew = order.CreatedAt >= lastCheck;
                            <div class="list-group-item py-4 px-4 overflow-hidden position-relative @(isNew ? "new-notification" : "")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="icon-circle bg-light text-primary" style="width: 45px; height: 45px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%;">
                                            <i class="bi bi-bag-plus-fill" style="font-size: 1.2rem;"></i>
                                        </div>
                                        <div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="fw-bold">New Order #@order.Id</span>
                                                @if(isNew) { <span class="badge-new">NEW</span> }
                                            </div>
                                            <div class="small text-muted">Customer: @(order.Customer?.Name ?? "Admin")</div>
                                            <div class="small mt-1">
                                                Status: <span class="badge @(order.OrderStatus == "Delivered" ? "bg-success" : (order.OrderStatus == "Pending" ? "bg-warning text-dark" : "bg-info"))">@order.OrderStatus</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="small text-muted mb-2">@order.CreatedAt.ToString("MMM dd, hh:mm tt")</div>
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">View</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">No recent orders found.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Customer Inquiries -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius: 15px;">
            <div class="card-header py-3 border-0" style="background:#17a2b8; border-radius: 15px 15px 0 0;">
                <h5 class="mb-0 fw-bold text-white"><i class="bi bi-chat-left-dots-fill me-2"></i>Customer Inquiries</h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (messages != null && messages.Any())
                    {
                        foreach (var msg in messages)
                        {
                            var isNew = msg.CreatedAt >= lastCheck;
                            <div class="list-group-item py-4 px-4 overflow-hidden position-relative @(isNew ? "new-notification" : "")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="icon-circle bg-light" style="width: 45px; height: 45px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; color: #17a2b8;">
                                            <i class="bi @(msg.MessageType == "LiveChat" ? "bi-chat-heart-fill" : "bi-chat-dots-fill")" style="font-size: 1.2rem;"></i>
                                        </div>
                                        <div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="fw-bold">@msg.Name</span>
                                                @if(isNew) { <span class="badge-new">NEW</span> }
                                                <span class="badge @(msg.MessageType == "LiveChat" ? "livechat-badge" : "bg-warning text-dark")" style="font-size: 9px;">@msg.MessageType</span>
                                            </div>
                                            <div class="small text-muted text-truncate" style="max-width: 200px;">@msg.Subject</div>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="small text-muted mb-2">@msg.CreatedAt.ToString("MMM dd, hh:mm tt")</div>
                                        <a asp-action="ReplyMessage" asp-route-id="@msg.Id" class="btn btn-sm btn-outline-info rounded-pill px-3">Reply</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">No recent messages found.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Registration Activities -->
    <div class="col-md-12">
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
            <div class="card-header py-3 border-0" style="background:#28a745; border-radius: 15px 15px 0 0;">
                <h5 class="mb-0 fw-bold text-white"><i class="bi bi-person-plus me-2"></i>New Registrations</h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (employees != null && employees.Any())
                    {
                        foreach (var emp in employees)
                        {
                            var isNew = emp.CreatedAt >= lastCheck;
                            <div class="list-group-item py-4 px-4 @(isNew ? "new-notification" : "")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="icon-circle bg-light text-success" style="width: 45px; height: 45px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%;">
                                            <i class="bi bi-person-badge-fill" style="font-size: 1.2rem;"></i>
                                        </div>
                                        <div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="fw-bold">Employee: @emp.Name</span>
                                                @if(isNew) { <span class="badge-new">NEW</span> }
                                            </div>
                                            <div class="small text-muted">@emp.Email | @emp.Designation</div>
                                            @if(emp.Status != "Active") {
                                                <span class="badge bg-danger mt-1">Pending Approval</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="small text-muted mb-2">@emp.CreatedAt.ToString("MMM dd, yyyy")</div>
                                        <a asp-controller="Employee" asp-action="Details" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-success rounded-pill px-3">Approve/Details</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    @if (customers != null && customers.Any())
                    {
                        foreach (var cust in customers)
                        {
                            var isNew = cust.CreatedAt >= lastCheck;
                            <div class="list-group-item py-4 px-4 @(isNew ? "new-notification" : "")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="icon-circle bg-light text-info" style="width: 45px; height: 45px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%;">
                                            <i class="bi bi-person-heart" style="font-size: 1.2rem;"></i>
                                        </div>
                                        <div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="fw-bold">Customer: @cust.Name</span>
                                                @if(isNew) { <span class="badge-new">NEW</span> }
                                            </div>
                                            <div class="small text-muted">Joined: @cust.CreatedAt.ToString("MMM dd, yyyy | hh:mm tt")</div>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                         <span class="badge bg-info p-2 rounded-pill"><i class="bi bi-person"></i> Customer</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

