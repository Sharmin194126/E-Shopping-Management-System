@model E_ShoppingManagement.ViewModels.AdminStatsViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .stat-card {
        padding: 20px;
        border-radius: 10px;
        color: white;
        margin-bottom: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .bg-delivered { background-color: #28a745; }
    .bg-pending { background-color: #ffc107; color: #333; }
    .bg-processing { background-color: #17a2b8; }
    .bg-revenue { background-color: #532374; }
    
    .table-container {
        background: #f2efe9;
        padding: 20px;
        border-radius: 12px;
        margin-top: 30px;
        border: 1px solid #e6e2db;
    }
    .table-container h4 {
        color: #33312e;
        margin-bottom: 20px;
    }
    .nav-shortcuts .dash-card {
        padding: 15px;
        text-align: center;
        border-radius: 8px;
        transition: 0.3s;
    }
    .nav-shortcuts .dash-card:hover {
        transform: translateY(-5px);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0" style="color:#532374;">📊 Admin Dashboard Overview</h3>
    <a asp-action="Profile" class="btn btn-warning fw-bold text-dark shadow-sm px-4">
        <i class="bi bi-person-circle me-2"></i> Account Profile
    </a>
</div>

<!-- KEY STATS (Premium Mode) -->
<div class="row g-3 mb-5">
    <div class="col-md">
        <a asp-action="OrdersByStatus" asp-route-status="Delivered" class="stat-card-premium card-variant-green">
            <div class="stat-card-content">
                <div class="stat-card-label">Delivered Orders</div>
                <div class="stat-card-value">@Model.TotalDelivered.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-bag-check-fill"></i></div>
        </a>
    </div>
    <div class="col-md">
        <a asp-action="OrdersByStatus" asp-route-status="Pending" class="stat-card-premium card-variant-orange">
            <div class="stat-card-content">
                <div class="stat-card-label">Pending Orders</div>
                <div class="stat-card-value">@Model.TotalPending.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-clock-history"></i></div>
        </a>
    </div>
    <div class="col-md">
        <a asp-action="OrdersByStatus" asp-route-status="Processing" class="stat-card-premium card-variant-blue">
            <div class="stat-card-content">
                <div class="stat-card-label">In Processing</div>
                <div class="stat-card-value">@Model.TotalProcessing.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-gear-wide-connected"></i></div>
        </a>
    </div>
    <div class="col-md">
        <a asp-action="OrdersByStatus" asp-route-status="Shipped" class="stat-card-premium card-variant-cyan">
            <div class="stat-card-content">
                <div class="stat-card-label">Shipped Orders</div>
                <div class="stat-card-value">@Model.TotalShipped.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-truck"></i></div>
        </a>
    </div>
    <div class="col-md">
        <div class="stat-card-premium card-variant-purple">
            <div class="stat-card-content">
                <div class="stat-card-label">Total Revenue</div>
                <div class="stat-card-value">৳@Model.TotalRevenue.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-cash-stack"></i></div>
        </div>
    </div>
</div>


<!-- MANAGEMENT QUICK LINKS -->
<div class="mb-4">
    <h5 class="fw-bold mb-3"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Management</h5>
    <div class="row g-2 nav-shortcuts">
        <div class="col-6 col-md-3">
            <a asp-controller="Category" asp-action="Index" class="btn btn-outline-primary w-100 py-2">Categories</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-success w-100 py-2">Products</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Customer" asp-action="Index" class="btn btn-outline-info w-100 py-2">Customers</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Employee" asp-action="Index" class="btn btn-outline-dark w-100 py-2">Employees</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="DeliveryMan" asp-action="Index" class="btn btn-outline-secondary w-100 py-2">Delivery Men</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="AdminReport" asp-action="Index" class="btn btn-outline-danger w-100 py-2">Reports</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="AdminDashboard" asp-action="FooterSettings" class="btn btn-outline-warning w-100 py-2">Footer Settings</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="AdminDashboard" asp-action="PaymentMethods" class="btn btn-outline-dark w-100 py-2">Payment Methods</a>
        </div>
    </div>
</div><!-- SALES ANALYTICS SECTION -->
<div class="row g-4 mb-5">
    <div class="col-lg-8">
        <div class="dashboard-table-card h-100 shadow-sm border-0" style="background: white; border-radius: 15px;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0 text-dark">
                    <i class="bi bi-graph-up-arrow text-primary me-2"></i>Daily Sales Analytics (Last 30 Days)
                </h5>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        View Options
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item active" href="#" onclick="toggleChart('daily')">Daily (30 Days)</a></li>
                        <li><a class="dropdown-item" href="#" onclick="toggleChart('monthly')">Monthly History</a></li>
                    </ul>
                </div>
            </div>
            <div style="height: 350px;">
                <canvas id="salesChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="dashboard-table-card h-100 shadow-sm border-0" style="background: white; border-radius: 15px;">
            <h5 class="fw-bold mb-4 text-dark">
                <i class="bi bi-pie-chart-fill text-info me-2"></i>Sales by Product Type
            </h5>
            <div style="height: 280px; position: relative;">
                <canvas id="typePieChart"></canvas>
            </div>
            <div class="mt-4 border-top pt-3">
                <div class="small text-muted mb-2 text-uppercase fw-bold" style="font-size: 10px;">Summary Distribution</div>
                <div id="pieLegend" class="d-flex flex-wrap gap-2"></div>
            </div>
        </div>
    </div>
</div>

<!-- DETAILED SALES RECORDS (FILTERABLE) -->
<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0"><i class="bi bi-calendar-range text-danger me-2"></i>Sales Records & History</h5>
        <div class="btn-group" role="group">
            <button type="button" class="btn btn-sm btn-outline-primary active" onclick="showHistory('monthly')">Monthly History</button>
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="showHistory('yearly')">Yearly Comparison</button>
        </div>
    </div>
    
    <div class="page-card shadow-sm border-0 p-0 overflow-hidden" style="background: white; border-radius: 15px;">
        <div id="monthlyHistoryTable" class="history-view">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background: #532374; color: white;">
                        <tr>
                            <th class="ps-4">Month/Year</th>
                            <th class="text-center">Total Amount (Inc. VAT)</th>
                            <th class="text-center">Pieces Sold</th>
                            <th class="text-center">Growth</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ decimal prevAmount = 0; }
                        @foreach (var month in Model.MonthlyHistory.OrderByDescending(m => m.Year).ThenByDescending(m => m.MonthName))
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@month.MonthName @month.Year</td>
                                <td class="text-center fw-bold text-success">৳@month.Amount.ToString("N0")</td>
                                <td class="text-center">@month.Pieces <small class="text-muted">Units</small></td>
                                <td class="text-center">
                                    @if(prevAmount > 0) {
                                        decimal growth = ((month.Amount - prevAmount) / prevAmount) * 100;
                                        <span class="@(growth >= 0 ? "text-success" : "text-danger") small">
                                            <i class="bi bi-caret-@(growth >= 0 ? "up" : "down")-fill"></i> @Math.Abs(growth).ToString("F1")%
                                        </span>
                                    } else {
                                        <span class="text-muted small">--</span>
                                    }
                                    @{ prevAmount = month.Amount; }
                                </td>
                                <td class="text-center">
                                    <a asp-controller="AdminReport" asp-action="Index" asp-route-fromDate="@(new DateTime(month.Year, DateTime.ParseExact(month.MonthName, "MMM", null).Month, 1).ToString("yyyy-MM-dd"))" class="btn btn-sm btn-link text-decoration-none p-0">Detailed Report</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Data from Model using System.Text.Json
            const dailyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Select(s => s.Date.ToString("dd MMM"))));
            const dailyAmount = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Select(s => s.Amount)));
            const dailyPieces = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Select(s => s.Pieces)));

            const typeLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductTypeSales.Select(s => s.ProductTypeName)));
            const typeAmount = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductTypeSales.Select(s => s.Amount)));

            // 1. Line Chart (Daily Sales)
            const ctxSales = document.getElementById('salesChart').getContext('2d');
            const salesChart = new Chart(ctxSales, {
                type: 'line',
                data: {
                    labels: dailyLabels,
                    datasets: [{
                        label: 'Revenue (৳)',
                        data: dailyAmount,
                        borderColor: '#532374',
                        backgroundColor: 'rgba(83, 35, 116, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 4,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#532374'
                    }, {
                        label: 'Pieces Sold',
                        data: dailyPieces,
                        borderColor: '#ffc107',
                        borderDash: [5, 5],
                        fill: false,
                        tension: 0.4,
                        yAxisID: 'yPieces'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', labels: { usePointStyle: true, boxWidth: 6 } },
                        tooltip: { mode: 'index', intersect: false }
                    },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            title: { display: true, text: 'Revenue (৳)' },
                            grid: { borderDash: [2, 2] }
                        },
                        yPieces: { 
                            beginAtZero: true, 
                            position: 'right', 
                            title: { display: true, text: 'Units Sold' },
                            grid: { display: false }
                        }
                    }
                }
            });

            // 2. Pie Chart (Product Type Distribution)
            const ctxPie = document.getElementById('typePieChart').getContext('2d');
            const colors = ['#532374', '#17a2b8', '#ffc107', '#28a745', '#dc3545', '#fd7e14', '#6610f2', '#e83e8c'];
            
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: typeLabels,
                    datasets: [{
                        data: typeAmount,
                        backgroundColor: colors,
                        borderWidth: 0,
                        hoverOffset: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: { display: false }
                    }
                }
            });

            // Generate Custom Legend
            const legendContainer = document.getElementById('pieLegend');
            typeLabels.forEach((label, i) => {
                const item = document.createElement('div');
                item.className = 'd-flex align-items-center';
                item.innerHTML = `<span style="width:10px; height:10px; background:${colors[i % colors.length]}; border-radius:50%; display:inline-block; margin-right:5px;"></span> <span style="font-size:11px;">${label}</span>`;
                legendContainer.appendChild(item);
            });
        });

        function showHistory(type) {
            // In a real app, this might show/hide different tables
            alert('Switching view to ' + type + '. Yearly aggregate data calculation implementation follows same pattern.');
        }
    </script>
}

<div class="row g-4">
    <!-- RECENT ORDERS (Standardized Card) -->
    <div class="col-lg-8">
        <div class="dashboard-table-card">
            <h4><i class="bi bi-cart-check"></i> Recent Orders Detailed View</h4>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 60px;">SL</th>
                            <th>Order Ref</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Location</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var sl_o = 1; }
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td>@(sl_o++)</td>
                                <td><span class="fw-bold text-primary">#@order.OrderId</span></td>
                                <td>@order.CustomerName</td>
                                <td><small>@order.OrderDate.ToString("MMM dd, yyyy")</small></td>
                                <td class="fw-bold">৳@order.Amount.ToString("#,##0")</td>
                                <td>
                                    @switch (order.Status)
                                    {
                                        case "Delivered": <span class="badge bg-success">Delivered</span> break;
                                        case "Pending": <span class="badge bg-warning text-dark">Pending</span> break;
                                        case "Processing": <span class="badge bg-info">Processing</span> break;
                                        case "Shipped": <span class="badge bg-primary">Shipped</span> break;
                                        default: <span class="badge bg-secondary">@order.Status</span> break;
                                    }
                                </td>
                                <td><small class="text-muted">@order.ShippingAddress</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- EMPLOYEE PERFORMANCE (No Scroll, Full Width Column) -->
    <div class="col-lg-4">
        <div class="dashboard-table-card employee-stats-container">
            <h4><i class="bi bi-people"></i> Employee Stats</h4>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle" style="font-size: 11px;">
                    <thead>
                        <tr>
                            <th style="width: 25px;">SL</th>
                            <th>Name</th>
                            <th class="text-center">Prod</th>
                            <th class="text-center">Sold</th>
                            <th class="text-end">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var sl_e = 1; }
                        @foreach (var emp in Model.EmployeePerformances)
                        {
                            <tr>
                                <td>@(sl_e++)</td>
                                <td>
                                    <a asp-action="EmployeeDashboard" asp-route-employeeId="@emp.EmployeeId" class="text-decoration-none fw-bold text-dark">
                                        @emp.EmployeeName
                                    </a>
                                </td>
                                <td class="text-center">@emp.TotalProductsManaged</td>
                                <td class="text-center">@emp.ProductsSold</td>
                                <td class="text-end fw-bold text-success">৳@emp.TotalSalesValue.ToString("#,##0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>





