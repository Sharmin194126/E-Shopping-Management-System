@model E_ShoppingManagement.ViewModels.AdminStatsViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .stat-card {
        padding: 20px;
        border-radius: 10px;
        color: white;
        margin-bottom: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .bg-delivered { background-color: #28a745; }
    .bg-pending { background-color: #ffc107; color: #333; }
    .bg-processing { background-color: #17a2b8; }
    .bg-revenue { background-color: #532374; }
    
    .table-container {
        background: #f2efe9;
        padding: 20px;
        border-radius: 12px;
        margin-top: 30px;
        border: 1px solid #e6e2db;
    }
    .table-container h4 {
        color: #33312e;
        margin-bottom: 20px;
    }
    .nav-shortcuts .dash-card {
        padding: 15px;
        text-align: center;
        border-radius: 8px;
        transition: 0.3s;
    }
    .nav-shortcuts .dash-card:hover {
        transform: translateY(-5px);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0" style="color:#532374;">📊 Admin Dashboard Overview</h3>
    <a asp-action="Profile" class="btn btn-warning fw-bold text-dark shadow-sm px-4">
        <i class="bi bi-person-circle me-2"></i> Account Profile
    </a>
</div>

<!-- KEY STATS (Premium Mode) -->
<div class="row g-3 mb-5">
    <div class="col-md">
        <a asp-action="OrdersByStatus" asp-route-status="Delivered" class="stat-card-premium card-variant-green">
            <div class="stat-card-content">
                <div class="stat-card-label">Delivered Orders</div>
                <div class="stat-card-value">@Model.TotalDelivered.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-bag-check-fill"></i></div>
        </a>
    </div>
    <div class="col-md">
        <a asp-action="OrdersByStatus" asp-route-status="Pending" class="stat-card-premium card-variant-orange">
            <div class="stat-card-content">
                <div class="stat-card-label">Pending Orders</div>
                <div class="stat-card-value">@Model.TotalPending.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-clock-history"></i></div>
        </a>
    </div>
    <div class="col-md">
        <a asp-action="OrdersByStatus" asp-route-status="Processing" class="stat-card-premium card-variant-blue">
            <div class="stat-card-content">
                <div class="stat-card-label">In Processing</div>
                <div class="stat-card-value">@Model.TotalProcessing.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-gear-wide-connected"></i></div>
        </a>
    </div>
    <div class="col-md">
        <a asp-action="OrdersByStatus" asp-route-status="Shipped" class="stat-card-premium card-variant-cyan">
            <div class="stat-card-content">
                <div class="stat-card-label">Shipped Orders</div>
                <div class="stat-card-value">@Model.TotalShipped.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-truck"></i></div>
        </a>
    </div>
    <div class="col-md">
        <div class="stat-card-premium card-variant-purple">
            <div class="stat-card-content">
                <div class="stat-card-label">Total Revenue</div>
                <div class="stat-card-value">৳@Model.TotalRevenue.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-cash-stack"></i></div>
        </div>
    </div>
</div>


<!-- MANAGEMENT QUICK LINKS -->
<div class="mb-4">
    <h5 class="fw-bold mb-3"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Management</h5>
    <div class="row g-2 nav-shortcuts">
        <div class="col-6 col-md-3">
            <a asp-controller="Category" asp-action="Index" class="btn btn-outline-primary w-100 py-2">Categories</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-success w-100 py-2">Products</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Customer" asp-action="Index" class="btn btn-outline-info w-100 py-2">Customers</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Employee" asp-action="Index" class="btn btn-outline-dark w-100 py-2">Employees</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="DeliveryMan" asp-action="Index" class="btn btn-outline-secondary w-100 py-2">Delivery Men</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="AdminReport" asp-action="Index" class="btn btn-outline-danger w-100 py-2">Reports</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="AdminDashboard" asp-action="FooterSettings" class="btn btn-outline-warning w-100 py-2">Footer Settings</a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="AdminDashboard" asp-action="PaymentMethods" class="btn btn-outline-dark w-100 py-2">Payment Methods</a>
        </div>
    </div>
</div><!-- SALES ANALYTICS SECTION (DESCO STYLE) -->
<div class="row g-4 mb-5">
    <div class="col-lg-8">
        <div class="dashboard-table-card h-100 shadow-sm border-0 overflow-hidden" style="background: white; border-radius: 15px;">
            <div class="p-4 border-bottom bg-light d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0 text-dark">
                    <i class="bi bi-activity text-primary me-2"></i>Sales Performance Analytics
                </h5>
                <div class="btn-group desco-range-picker" role="group">
                    <button type="button" class="btn btn-outline-primary btn-sm px-3 active" onclick="updateChartRange('weekly')">Weekly</button>
                    <button type="button" class="btn btn-outline-primary btn-sm px-3" onclick="updateChartRange('monthly')">Monthly</button>
                    <button type="button" class="btn btn-outline-primary btn-sm px-3" onclick="updateChartRange('yearly')">Yearly</button>
                </div>
            </div>
            
            <div class="p-4">
                <div class="row mb-4">
                    <div class="col-4">
                        <div class="small text-muted">Total Amount</div>
                        <h4 class="fw-bold mb-0" id="rangeTotalAmount">৳0</h4>
                    </div>
                    <div class="col-4 border-start">
                        <div class="small text-muted">Total Pieces</div>
                        <h4 class="fw-bold mb-0" id="rangeTotalPieces">0</h4>
                    </div>
                    <div class="col-4 border-start">
                        <div class="small text-muted">Avg/Order</div>
                        <h4 class="fw-bold mb-0 text-success" id="rangeAvgOrder">৳0</h4>
                    </div>
                </div>
                
                <div style="height: 300px;">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="dashboard-table-card h-100 shadow-sm border-0 overflow-hidden" style="background: white; border-radius: 15px;">
            <div class="p-4 border-bottom bg-light">
                <h5 class="fw-bold mb-0 text-dark">
                    <i class="bi bi-box-seam-fill text-info me-2"></i>Top Moving Products
                </h5>
            </div>
            <div class="p-3">
                <div class="list-group list-group-flush">
                    @foreach (var prod in Model.TopProducts.Take(6))
                    {
                        <div class="list-group-item px-0 py-3 border-bottom d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded p-2 me-3" style="width: 40px; text-align: center;">
                                    <i class="bi bi-package text-muted"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-dark" style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@prod.ProductName</div>
                                    <small class="text-muted">@prod.Category</small>
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="fw-bold text-primary">@prod.TotalQuantity Pcs</div>
                                <small class="text-success">৳@prod.TotalRevenue.ToString("N0")</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Pie Chart for Product Types -->
    <div class="col-lg-5">
        <div class="dashboard-table-card h-100 shadow-sm border-0" style="background: white; border-radius: 15px;">
            <h5 class="fw-bold mb-4 text-dark p-4 pb-0">
                <i class="bi bi-pie-chart-fill text-info me-2"></i>Sales by Product Type
            </h5>
            <div style="height: 280px; position: relative;">
                <canvas id="typePieChart"></canvas>
            </div>
            <div class="mt-4 border-top pt-3 p-4">
                <div id="pieLegend" class="d-flex flex-wrap gap-2"></div>
            </div>
        </div>
    </div>
    
<!-- DETAILED SALES RECORDS (FILTERABLE) -->
<div class="mb-5 px-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-calendar-range text-danger me-2"></i>Full Sales Archives & History</h5>
        <div class="btn-group" role="group">
            <button type="button" class="btn btn-sm btn-outline-primary active" id="btnMonthly" onclick="toggleHistoryView('monthly')">Monthly View</button>
            <button type="button" class="btn btn-sm btn-outline-primary" id="btnYearly" onclick="toggleHistoryView('yearly')">Yearly Summary</button>
        </div>
    </div>
    
    <div class="page-card shadow-sm border-0 p-0 overflow-hidden bg-white" style="border-radius: 15px; border: 1px solid #e6e2db !important;">
        <!-- Monthly History Table -->
        <div id="historyTableMonthly" class="history-view">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background: #f8f9fa;">
                        <tr>
                            <th class="ps-4">Reporting Period</th>
                            <th class="text-center">Gross Revenue</th>
                            <th class="text-center">Items Sold (Pieces)</th>
                            <th class="text-center">Net Impact</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var month in Model.MonthlyHistory.OrderByDescending(m => m.Year).ThenByDescending(m => m.MonthName))
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@month.MonthName @month.Year</div>
                                    <small class="text-muted">Completed Sales Cycle</small>
                                </td>
                                <td class="text-center fw-bold text-success" style="font-size: 1.1rem;">৳@month.Amount.ToString("N0")</td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border px-3">@month.Pieces Pieces</span>
                                </td>
                                <td class="text-center">
                                    <span class="text-success"><i class="bi bi-graph-up me-1"></i>Verified</span>
                                </td>
                                <td class="text-center">
                                    <a asp-controller="AdminReport" asp-action="Index" class="btn btn-sm btn-outline-secondary px-3">View Report</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Yearly History Table (Hidden by default) -->
        <div id="historyTableYearly" class="history-view" style="display:none;">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background: #532374; color: white;">
                        <tr>
                            <th class="ps-4 text-white">Fiscal Year</th>
                            <th class="text-center text-white">Annual Revenue</th>
                            <th class="text-center text-white">Annual Output (Pieces)</th>
                            <th class="text-center text-white">Avg Monthly Sales</th>
                            <th class="text-center text-white">Performance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var yearGroup in Model.MonthlyHistory.GroupBy(m => m.Year).OrderByDescending(g => g.Key))
                        {
                            var yearTotal = yearGroup.Sum(y => y.Amount);
                            var yearPieces = yearGroup.Sum(y => y.Pieces);
                            <tr>
                                <td class="ps-4 fw-bold text-dark" style="font-size: 1.2rem;">@yearGroup.Key</td>
                                <td class="text-center fw-bold text-primary">৳@yearTotal.ToString("N0")</td>
                                <td class="text-center fw-bold">@yearPieces <small class="text-muted">Items</small></td>
                                <td class="text-center text-muted">৳@((yearTotal/12).ToString("N0")) /mo</td>
                                <td class="text-center">
                                    <span class="badge bg-success rounded-pill px-3">Year Closed</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .desco-range-picker .btn { border-radius: 20px !important; margin: 0 2px; }
    .desco-range-picker .btn.active { background-color: #532374 !important; border-color: #532374 !important; color: white !important; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let salesChart;
        
        const chartData = {
            weekly: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklySales.Select(s => s.Date.ToString("ddd")))),
                amount: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklySales.Select(s => s.Amount))),
                pieces: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklySales.Select(s => s.Pieces))),
                totalAmount: '৳@Model.WeeklySales.Sum(s => s.Amount).ToString("N0")',
                totalPieces: '@Model.WeeklySales.Sum(s => s.Pieces)',
                avgOrder: '৳@((Model.WeeklySales.Sum(s => s.Amount) / Math.Max(1, Model.WeeklySales.Count(s => s.Amount > 0))).ToString("N0"))'
            },
            monthly: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Select(s => s.Date.ToString("dd MMM")))),
                amount: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Select(s => s.Amount))),
                pieces: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Select(s => s.Pieces))),
                totalAmount: '৳@Model.DailySales.Sum(s => s.Amount).ToString("N0")',
                totalPieces: '@Model.DailySales.Sum(s => s.Pieces)',
                avgOrder: '৳@((Model.DailySales.Sum(s => s.Amount) / Math.Max(1, Model.DailySales.Count(s => s.Amount > 0))).ToString("N0"))'
            },
            yearly: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyHistory.Select(s => s.MonthName))),
                amount: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyHistory.Select(s => s.Amount))),
                pieces: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyHistory.Select(s => s.Pieces))),
                totalAmount: '৳@Model.MonthlyHistory.Sum(s => s.Amount).ToString("N0")',
                totalPieces: '@Model.MonthlyHistory.Sum(s => s.Pieces)',
                avgOrder: '৳@((Model.MonthlyHistory.Sum(s => s.Amount) / Math.Max(1, Model.MonthlyHistory.Count())).ToString("N0"))'
            }
        };

        const typeLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductTypeSales.Select(s => s.ProductTypeName)));
        const typeAmount = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductTypeSales.Select(s => s.Amount)));

        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('salesChart').getContext('2d');
            
            salesChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartData.weekly.labels,
                    datasets: [{
                        label: 'Sales Revenue',
                        data: chartData.weekly.amount,
                        borderColor: '#532374',
                        backgroundColor: 'rgba(83, 35, 116, 0.05)',
                        fill: true,
                        tension: 0, // Sharp lines like "digital graph"
                        borderWidth: 4,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#532374',
                        pointRadius: 5,
                        pointHoverRadius: 8
                    }, {
                        label: 'Pieces',
                        data: chartData.weekly.pieces,
                        borderColor: '#17a2b8',
                        borderDash: [5, 5],
                        fill: false,
                        yAxisID: 'yPieces'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { backgroundColor: '#333', titleFont: { size: 14 } }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { borderDash: [2, 2], color: '#eee' } },
                        yPieces: { position: 'right', beginAtZero: true, grid: { display: false } }
                    }
                }
            });

            // 2. Pie Chart (Product Type Distribution)
            const ctxPie = document.getElementById('typePieChart').getContext('2d');
            const colors = ['#532374', '#17a2b8', '#ffc107', '#28a745', '#dc3545', '#fd7e14', '#6610f2', '#e83e8c'];
            
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: typeLabels,
                    datasets: [{
                        data: typeAmount,
                        backgroundColor: colors,
                        borderWidth: 0,
                        hoverOffset: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: { display: false }
                    }
                }
            });

            // Generate Custom Legend
            const legendContainer = document.getElementById('pieLegend');
            typeLabels.forEach((label, i) => {
                const item = document.createElement('div');
                item.className = 'd-flex align-items-center';
                item.innerHTML = `<span style="width:10px; height:10px; background:${colors[i % colors.length]}; border-radius:50%; display:inline-block; margin-right:5px;"></span> <span style="font-size:11px;">${label}</span>`;
                legendContainer.appendChild(item);
            });
            
            updateDisplayStats('weekly');
        });

        function updateChartRange(range) {
            // Update buttons
            document.querySelectorAll('.desco-range-picker .btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            // Update Chart
            salesChart.data.labels = chartData[range].labels;
            salesChart.data.datasets[0].data = chartData[range].amount;
            salesChart.data.datasets[1].data = chartData[range].pieces;
            salesChart.update();
            
            updateDisplayStats(range);
        }

        function updateDisplayStats(range) {
            document.getElementById('rangeTotalAmount').innerText = chartData[range].totalAmount;
            document.getElementById('rangeTotalPieces').innerText = chartData[range].totalPieces;
            document.getElementById('rangeAvgOrder').innerText = chartData[range].avgOrder;
        }

        function toggleHistoryView(view) {
            if(view === 'monthly') {
                document.getElementById('historyTableMonthly').style.display = 'block';
                document.getElementById('historyTableYearly').style.display = 'none';
                document.getElementById('btnMonthly').classList.add('active');
                document.getElementById('btnYearly').classList.remove('active');
            } else {
                document.getElementById('historyTableMonthly').style.display = 'none';
                document.getElementById('historyTableYearly').style.display = 'block';
                document.getElementById('btnMonthly').classList.remove('active');
                document.getElementById('btnYearly').classList.add('active');
            }
        }

        function showHistory(type) {
             // Redundant now that range picker is here, but keeping for compatibility
             updateChartRange(type === 'monthly' ? 'monthly' : 'yearly');
        }
    </script>
}

<div class="row g-4">
    <!-- RECENT ORDERS (Standardized Card) -->
    <div class="col-lg-8">
        <div class="dashboard-table-card">
            <h4><i class="bi bi-cart-check"></i> Recent Orders Detailed View</h4>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 60px;">SL</th>
                            <th>Order Ref</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Location</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var sl_o = 1; }
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td>@(sl_o++)</td>
                                <td><span class="fw-bold text-primary">#@order.OrderId</span></td>
                                <td>@order.CustomerName</td>
                                <td><small>@order.OrderDate.ToString("MMM dd, yyyy")</small></td>
                                <td class="fw-bold">৳@order.Amount.ToString("#,##0")</td>
                                <td>
                                    @switch (order.Status)
                                    {
                                        case "Delivered": <span class="badge bg-success">Delivered</span> break;
                                        case "Pending": <span class="badge bg-warning text-dark">Pending</span> break;
                                        case "Processing": <span class="badge bg-info">Processing</span> break;
                                        case "Shipped": <span class="badge bg-primary">Shipped</span> break;
                                        default: <span class="badge bg-secondary">@order.Status</span> break;
                                    }
                                </td>
                                <td><small class="text-muted">@order.ShippingAddress</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- EMPLOYEE PERFORMANCE (No Scroll, Full Width Column) -->
    <div class="col-lg-4">
        <div class="dashboard-table-card employee-stats-container">
            <h4><i class="bi bi-people"></i> Employee Stats</h4>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle" style="font-size: 11px;">
                    <thead>
                        <tr>
                            <th style="width: 25px;">SL</th>
                            <th>Name</th>
                            <th class="text-center">Prod</th>
                            <th class="text-center">Sold</th>
                            <th class="text-end">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var sl_e = 1; }
                        @foreach (var emp in Model.EmployeePerformances)
                        {
                            <tr>
                                <td>@(sl_e++)</td>
                                <td>
                                    <a asp-action="EmployeeDashboard" asp-route-employeeId="@emp.EmployeeId" class="text-decoration-none fw-bold text-dark">
                                        @emp.EmployeeName
                                    </a>
                                </td>
                                <td class="text-center">@emp.TotalProductsManaged</td>
                                <td class="text-center">@emp.ProductsSold</td>
                                <td class="text-end fw-bold text-success">৳@emp.TotalSalesValue.ToString("#,##0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>





