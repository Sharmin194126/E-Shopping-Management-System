@model IEnumerable<E_ShoppingManagement.Models.ContactMessage>
@{
    ViewData["Title"] = "Customer Emails";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0" style="color:#532374;"><i class="bi bi-envelope-paper-fill me-2"></i> Customer Emails</h3>
    <a href="/EmployeeDashboard" class="theme-back-btn mb-0">Back to Dashboard</a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:15px; background: #fff;">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead style="background:#f8f6f0;">
                    <tr>
                        <th style="width: 50px;">SL</th>
                        <th>From</th>
                        <th>Subject</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var sl = 1; }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(sl++)</td>
                            <td>
                                <div class="fw-bold">@item.Name</div>
                                <div class="small text-muted">@item.Email</div>
                            </td>
                            <td>
                                <div class="text-truncate" style="max-width: 250px;">@item.Subject</div>
                            </td>
                            <td>@item.CreatedAt.ToString("MMM dd, yyyy | hh:mm tt")</td>
                            <td>
                                <span class="badge @(item.Status == "Replied" ? "bg-success" : "bg-warning text-dark")">@item.Status</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="MessageDetails" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill">View Details</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">No emails found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
