@model E_ShoppingManagement.ViewModels.EmployeeStatsViewModel
@{
    ViewData["Title"] = "Employee Dashboard";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<style>
    .stat-card {
        padding: 20px;
        border-radius: 10px;
        color: white;
        margin-bottom: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .bg-inventory { background-color: #6c757d; }
    .bg-pending { background-color: #ffc107; color: #333; }
    .bg-processing { background-color: #17a2b8; }
    .bg-delivered { background-color: #28a745; }
    .bg-dm { background-color: #532374; }
    .bg-active { background-color: #ef4444; }
    
    .table-container {
        background: #f2efe9;
        padding: 20px;
        border-radius: 12px;
        margin-top: 30px;
        border: 1px solid #e6e2db;
    }
    .table-container h4 {
        color: #33312e;
        margin-bottom: 20px;
    }
    .quick-links .btn {
        margin-bottom: 10px;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0" style="color:#532374;">💼 Employee Dashboard Overview</h3>
    <div class="d-flex gap-2">
        <a asp-controller="EmployeeProduct" asp-action="Create" class="btn btn-primary px-4">
            <i class="bi bi-plus-circle me-2"></i> New Product
        </a>
        <a href="javascript:history.back()" class="theme-back-btn mb-0">Back</a>
    </div>
</div>

<!-- KEY STATS (Premium Mode) -->
<div class="row g-3 mb-5">
    <div class="col">
        <div class="stat-card-premium card-variant-blue">
            <div class="stat-card-content">
                <div class="stat-card-label">My Products</div>
                <div class="stat-card-value">@Model.TotalProductsManaged</div>
                <div class="small mt-1 opacity-75">Qty: @Model.TotalInventoryQty</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-box-seam"></i></div>
        </div>
    </div>
    <div class="col">
        <div class="stat-card-premium card-variant-orange">
            <div class="stat-card-content">
                <div class="stat-card-label">Pending Orders</div>
                <div class="stat-card-value">@Model.PendingOrders</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-hourglass-split"></i></div>
        </div>
    </div>
    <div class="col">
        <div class="stat-card-premium card-variant-cyan">
            <div class="stat-card-content">
                <div class="stat-card-label">In Processing</div>
                <div class="stat-card-value">@Model.ProcessingOrders</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-gear-fill"></i></div>
        </div>
    </div>
    <div class="col">
        <div class="stat-card-premium card-variant-green">
            <div class="stat-card-content">
                <div class="stat-card-label">Total Sales</div>
                <div class="stat-card-value">@Model.DeliveredOrders</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-cart-check-fill"></i></div>
        </div>
    </div>
    <div class="col">
        <div class="stat-card-premium card-variant-purple">
            <div class="stat-card-content">
                <div class="stat-card-label">Delivery Personnel</div>
                <div class="stat-card-value">@Model.TotalDeliveryMen</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-truck"></i></div>
        </div>
    </div>
    <div class="col">
        <div class="stat-card-premium card-variant-red">
            <div class="stat-card-content">
                <div class="stat-card-label">Shipping Now</div>
                <div class="stat-card-value">@Model.ActiveDeliveries</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-geo-alt-fill"></i></div>
        </div>
    </div>
</div>

<div class="mb-4">
    <h5 class="fw-bold mb-3"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</h5>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="EmployeeProduct" asp-action="Index" class="btn btn-outline-primary px-4 py-2">My Managed Products</a>
        <a asp-controller="EmployeeOrder" asp-action="MySales" class="btn btn-outline-success px-4 py-2">View My Sales History</a>
        <a asp-controller="EmployeeProduct" asp-action="Create" class="btn btn-outline-info px-4 py-2">Add New Product</a>
    </div>
</div>


<!-- ASSIGNED ORDERS -->
<div class="dashboard-table-card">
    <h4><i class="bi bi-list-task"></i> Recent Orders Assigned to Me</h4>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 70px;">SL No</th>
                    <th>Order Ref</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Location</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @{ var sl = 1; }
                @foreach (var order in Model.AssignedOrders)
                {
                    <tr>
                        <td>@(sl++)</td>
                        <td><span class="fw-bold text-primary">#@order.OrderId</span></td>
                        <td>@order.CustomerName</td>
                        <td><small>@order.OrderDate.ToString("MMM dd, yyyy")</small></td>
                        <td class="fw-bold">৳@order.Amount</td>
                        <td>
                            @switch (order.Status)
                            {
                                case "Delivered": <span class="badge bg-success">Delivered</span> break;
                                case "Pending": <span class="badge bg-warning text-dark">Pending</span> break;
                                case "Processing": <span class="badge bg-info">Processing</span> break;
                                case "Shipped": <span class="badge bg-primary">Shipped</span> break;
                                default: <span class="badge bg-secondary">@order.Status</span> break;
                            }
                        </td>
                        <td><small class="text-muted">@order.ShippingAddress</small></td>
                        <td>
                            <a asp-controller="EmployeeOrder" asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-primary px-3">View</a>
                        </td>
                    </tr>
                }
                @if (!Model.AssignedOrders.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">No orders assigned to you yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>




