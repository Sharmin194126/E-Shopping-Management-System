@model E_ShoppingManagement.ViewModels.EmployeeStatsViewModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment _env
@{
    ViewData["Title"] = "Employee Dashboard";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<style>
    /* Analytics Metric Card Hover Animation */
    .analytics-metric-card {
        border-radius:12px; 
        padding:16px; 
        color:#fff; 
        position:relative; 
        overflow:hidden; 
        height:100%;
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
        cursor: pointer;
    }
    .analytics-metric-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }
    .analytics-metric-card .amc-icon { font-size:2rem; opacity:.25; position:absolute; right:12px; bottom:8px; }
    .analytics-metric-card .amc-label { font-size:11px; opacity:.85; text-transform:uppercase; letter-spacing:.5px; }
    .analytics-metric-card .amc-value { font-size:1.35rem; font-weight:700; margin:4px 0; }
    .analytics-metric-card .amc-sub { font-size:10px; opacity:.7; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0" style="color:#532374;">💼 Employee Dashboard Overview</h3>
    <div class="d-flex gap-2">
        <a asp-controller="EmployeeProduct" asp-action="Create" class="btn btn-primary px-4">
            <i class="bi bi-plus-circle me-2"></i> New Product
        </a>
        <a href="javascript:history.back()" class="theme-back-btn mb-0">Back</a>
    </div>
</div>

<!-- KEY STATS -->
<div class="row g-3 mb-5">
    <div class="col">
        <div class="stat-card-premium card-variant-blue">
            <div class="stat-card-content">
                <div class="stat-card-label">My Products</div>
                <div class="stat-card-value">@Model.TotalProductsManaged</div>
                <div class="small mt-1 opacity-75">Qty: @Model.TotalInventoryQty</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-box-seam"></i></div>
        </div>
    </div>
    <div class="col">
        <div class="stat-card-premium card-variant-orange">
            <div class="stat-card-content">
                <div class="stat-card-label">Pending Orders</div>
                <div class="stat-card-value">@Model.PendingOrders</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-hourglass-split"></i></div>
        </div>
    </div>
    <div class="col">
        <div class="stat-card-premium card-variant-cyan">
            <div class="stat-card-content">
                <div class="stat-card-label">In Processing</div>
                <div class="stat-card-value">@Model.ProcessingOrders</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-gear-fill"></i></div>
        </div>
    </div>
    <div class="col">
        <div class="stat-card-premium card-variant-green">
            <div class="stat-card-content">
                <div class="stat-card-label">Delivered</div>
                <div class="stat-card-value">@Model.DeliveredOrders</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-cart-check-fill"></i></div>
        </div>
    </div>
    <div class="col">
        <div class="stat-card-premium card-variant-purple">
            <div class="stat-card-content">
                <div class="stat-card-label">Total Revenue</div>
                <div class="stat-card-value">৳@Model.TotalRevenue.ToString("#,##0")</div>
            </div>
            <div class="stat-card-icon"><i class="bi bi-cash-stack"></i></div>
        </div>
    </div>
</div>

@{
    var currentYearSales = Model.MonthlyHistory.Where(m => m.Year == DateTime.Now.Year).Sum(m => m.Amount);
    var goalPercent = Model.SalesGoal > 0 ? (int)Math.Min(100, (currentYearSales / Model.SalesGoal) * 100) : 0;
    var goalRemaining = Model.SalesGoal - currentYearSales;
}

<!-- ANALYTICS BAR (Same as Admin) -->
<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="row g-3 h-100">
             <div class="col-6">
                <div class="analytics-metric-card" style="background: linear-gradient(135deg,#6f2da8,#532374);">
                    <div class="amc-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <div class="amc-label">My Sales Revenue</div>
                    <div class="amc-value">৳@Model.TotalRevenue.ToString("#,##0")</div>
                    <div class="amc-sub">Total since joining</div>
                </div>
            </div>
            <div class="col-6">
                <div class="analytics-metric-card" style="background: linear-gradient(135deg,#1a7a6e,#138d75);">
                    <div class="amc-icon"><i class="bi bi-currency-exchange"></i></div>
                    <div class="amc-label">Weekly Sales</div>
                    <div class="amc-value">৳@Model.WeeklyRevenue.ToString("#,##0")</div>
                    <div class="amc-sub">Last 7 days performance</div>
                </div>
            </div>
            <div class="col-6">
                <div class="analytics-metric-card" style="background: linear-gradient(135deg,#8b4513,#a0522d);">
                    <div class="amc-icon"><i class="bi bi-check-circle"></i></div>
                    <div class="amc-label">Delivered Orders</div>
                    <div class="amc-value">@Model.DeliveredOrders</div>
                    <div class="amc-sub">Successfully fulfilled</div>
                </div>
            </div>
            <div class="col-6">
                <div class="analytics-metric-card" style="background: linear-gradient(135deg,#1565c0,#1976d2);">
                    <div class="amc-icon"><i class="bi bi-truck"></i></div>
                    <div class="amc-label">Assigned Delivery</div>
                    <div class="amc-value">@Model.ActiveDeliveries</div>
                    <div class="amc-sub">Active personnel: @Model.TotalDeliveryMen</div>
                </div>
            </div>
        </div>
    </div>
    <!-- Sales Goals Card -->
    <div class="col-lg-5">
        <div class="h-100 p-4 rounded-3 shadow-sm" style="background:#fff; border:1px solid #e6e2db;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-2">
                    <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-trophy-fill text-warning me-2"></i>My Sales Goal</h6>
                    <div class="d-flex align-items-center border rounded-pill px-2" style="background:#f8f6f0; height:28px;">
                        <button class="btn btn-sm p-0 border-0" onclick="updateEmployeeGoalYear(-1)" style="font-size:10px;">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <span id="goalDisplayYear" class="px-2 fw-bold" style="font-size:12px; color:#532374;">@DateTime.Now.Year</span>
                        <button class="btn btn-sm p-0 border-0" onclick="updateEmployeeGoalYear(1)" style="font-size:10px;">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#historyGoalModal" title="View Goal History">
                        <i class="bi bi-clock-history"></i> History
                    </button>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-6">
                    <div class="small text-muted">Target</div>
                    <div class="fw-bold fs-5" id="valTarget" style="color:#532374;">৳@Model.SalesGoal.ToString("#,##0")</div>
                    <div class="small text-muted">Full Year Goal</div>
                </div>
                <div class="col-6 border-start">
                    <div class="small text-muted">Remaining</div>
                    <div class="fw-bold fs-5 text-danger" id="valRemaining">৳@(goalRemaining > 0 ? goalRemaining.ToString("#,##0") : "0")</div>
                    <div class="small text-muted">To reach target</div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div style="position:relative; width:90px; height:90px; flex-shrink:0;">
                    <canvas id="goalRingChart"></canvas>
                    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:14px;font-weight:700;color:#532374;" id="valPercent">@goalPercent%</div>
                </div>
                <div>
                    <div class="fw-bold text-dark" id="valAchieved">৳@currentYearSales.ToString("#,##0") achieved</div>
                    <div class="small text-muted" id="goalNote">Note: Goal for <span id="noteYear">@DateTime.Now.Year</span></div>
                    <div class="progress mt-2" style="height:6px;">
                        <div class="progress-bar" id="valProgressBar" style="width:@goalPercent%; background:#532374;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CHARTS ROW -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="shadow-sm rounded-3 p-4" style="background:#fff; border:1px solid #e6e2db;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h6 class="fw-bold mb-0">Sales Analytics</h6>
                    <small class="text-muted">Track your performance over time</small>
                </div>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <span id="rangeDropdownLabel">Weekly</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item chart-range-item" href="#" data-range="weekly">Weekly</a></li>
                        <li><a class="dropdown-item chart-range-item" href="#" data-range="monthly">Monthly (30 Days)</a></li>
                        <li><a class="dropdown-item chart-range-item" href="#" data-range="yearly">Yearly (@DateTime.Now.Year)</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li class="dropdown-item px-3 py-1">
                            <div class="d-flex align-items-center justify-content-between border rounded-pill px-2" style="background:#f8f6f0;">
                                <button class="btn btn-sm p-0 border-0" onclick="updateYear(-1); event.stopPropagation();">
                                    <i class="bi bi-chevron-left" style="color:#532374;"></i>
                                </button>
                                <div class="chart-range-item text-center flex-grow-1 fw-bold" data-range="prevyear" style="cursor:pointer; color:#532374; font-size:12px;">
                                    Year <span id="displayYear">@(DateTime.Now.Year - 1)</span>
                                </div>
                                <button class="btn btn-sm p-0 border-0" onclick="updateYear(1); event.stopPropagation();">
                                    <i class="bi bi-chevron-right" style="color:#532374;"></i>
                                </button>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
            <div style="height:300px;">
                <canvas id="salesChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="shadow-sm rounded-3 p-4 h-100" style="background:#fff; border:1px solid #e6e2db;">
            <h6 class="fw-bold mb-3">Sales by Category</h6>
            <div style="height:220px; position:relative;">
                <canvas id="typePieChart"></canvas>
            </div>
            <div id="pieLegend" class="d-flex flex-wrap gap-2 mt-3"></div>
        </div>
    </div>
</div>

<!-- RECENT ASSIGNED ORDERS -->
<div class="dashboard-table-card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden; background: #fff !important;">
    <div class="p-4 border-bottom-0" style="background: #f8f6f0 !important; color: #532374 !important; border-bottom: 1px solid rgba(83, 35, 116, 0.1) !important;">
        <h5 class="mb-0 fw-bold"><i class="bi bi-list-task me-2" style="color: #532374 !important;"></i>Recent Orders Assigned to Me</h5>
    </div>
    <div class="table-responsive p-0">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: #f8f6f0 !important; color: #532374 !important; border-bottom: 2px solid #532374 !important;">
                <tr>
                    <th class="ps-4" style="width: 70px;">SL</th>
                    <th>Product</th>
                    <th>Order Ref</th>
                    <th>Customer</th>
                    <th>Date & Time</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th class="text-center pe-4">Action</th>
                </tr>
            </thead>
            <tbody>
                @{ var sl = 1; }
                @foreach (var order in Model.AssignedOrders)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-muted">@(sl++)</td>
                        <td>
                             <img src="@(string.IsNullOrEmpty(order.ImageUrl) ? "/images/no-image.png" : order.ImageUrl)" 
                                 class="rounded shadow-sm" style="width: 45px; height: 45px; object-fit: cover;" onerror="this.src='/images/no-image.png'"/>
                        </td>
                        <td><span class="fw-bold text-primary">@order.OrderId</span></td>
                        <td>@order.CustomerName</td>
                        <td><small>@order.OrderDate.ToString("MMM dd, yyyy | hh:mm tt")</small></td>
                        <td class="fw-bold text-success">৳@order.Amount.ToString("#,##0")</td>
                        <td>
                            @switch (order.Status)
                            {
                                case "Delivered": <span class="badge rounded-pill bg-success px-3">Delivered</span> break;
                                case "Pending": <span class="badge rounded-pill text-dark px-3" style="background:#ffc107;">Pending</span> break;
                                case "Processing": <span class="badge rounded-pill bg-info px-3">Processing</span> break;
                                case "Shipped": <span class="badge rounded-pill bg-primary px-3">Shipped</span> break;
                                default: <span class="badge rounded-pill bg-secondary px-3">@order.Status</span> break;
                            }
                        </td>
                        <td class="text-center pe-4">
                            <a asp-controller="EmployeeOrder" asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- History Goal Modal -->
<div class="modal fade" id="historyGoalModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:#f2efe9; border:none;">
            <div class="modal-header" style="border-bottom:1px solid #e6e2db;">
                <h5 class="modal-title fw-bold" style="color:#532374;"><i class="bi bi-clock-history me-2"></i>Yearly Goal Rates</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-center" style="font-size:14px; background:#fff;">
                        <thead style="background:#532374; color:#fff;">
                            <tr>
                                <th>Year</th>
                                <th>Sales</th>
                                <th>Target</th>
                                <th>Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var yrData = Model.MonthlyHistory.GroupBy(m => m.Year).OrderByDescending(g => g.Key).ToList();
                                foreach (var yrGroup in yrData)
                                {
                                    var yrSales = yrGroup.Sum(m => m.Amount);
                                    decimal yrGoal = 0;
                                    string gPath = System.IO.Path.Combine(_env.WebRootPath, "settings", "goals", $"employee_goal_{Model.EmployeeId}_{yrGroup.Key}.txt");
                                    
                                    if (System.IO.File.Exists(gPath) && decimal.TryParse(System.IO.File.ReadAllText(gPath), out decimal saved)) {
                                        yrGoal = saved;
                                    }
                                    else if (yrGroup.Key == DateTime.Now.Year) {
                                        yrGoal = Model.SalesGoal;
                                    }
                                    else {
                                        yrGoal = yrSales * 1.1m; 
                                    }
 
                                    var achv = yrGoal > 0 ? (yrSales / yrGoal) * 100 : 0;
                                    <tr>
                                        <td>@yrGroup.Key</td>
                                        <td class="text-success fw-bold">৳@yrSales.ToString("#,##0")</td>
                                        <td class="text-muted">৳@yrGoal.ToString("#,##0")</td>
                                        <td class="fw-bold" style="color:#532374;">@achv.ToString("0.0")%</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Goal Modal -->
<div class="modal fade" id="editGoalModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header" style="background:#532374; color:#fff;">
                <h5 class="modal-title">Set Annual Sales Goal</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateSalesGoal" method="post">
                <div class="modal-body p-4">
                    <label class="form-label fw-bold">Target Revenue for @DateTime.Now.Year (৳)</label>
                    <input type="number" name="goalAmount" class="form-control" value="@Model.SalesGoal" step="0.01" required />
                    <p class="text-muted small mt-2">Setting a realistic goal helps track your performance effectively.</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4" style="background:#532374; border:none;">Save Goal</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let salesChart;
        const fmtBDT = n => '৳' + Number(n).toLocaleString('en-IN');

        const chartData = {
            weekly: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklySales.Select(s => s.Date.ToString("ddd")))),
                amount: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklySales.Select(s => s.Amount)))
            },
            monthly: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Select(s => s.Date.ToString("dd MMM")))),
                amount: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Select(s => s.Amount)))
            },
            yearly: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyHistory.OrderBy(s=>s.Year).ThenBy(s=>s.Month).Select(s => s.MonthName + " " + s.Year))),
                amount: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyHistory.OrderBy(s=>s.Year).ThenBy(s=>s.Month).Select(s => s.Amount)))
            },
            prevyear: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PreviousYearSales.Select(s => s.MonthName + " " + s.Year))),
                amount: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PreviousYearSales.Select(s => s.Amount)))
            }
        };

        const pieLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductTypeSales.Select(s => s.ProductTypeName)));
        const pieAmounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductTypeSales.Select(s => s.Amount)));

        let goalRing;
        function initGoalRing() {
            const goalCtx = document.getElementById('goalRingChart').getContext('2d');
            const goalPct = @goalPercent;
            goalRing = new Chart(goalCtx, {
                type: 'doughnut',
                data: {
                    datasets: [{
                        data: [goalPct, 100 - goalPct],
                        backgroundColor: ['#532374', '#f0ece6'],
                        borderWidth: 0
                    }]
                },
                options: { cutout: '72%', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { enabled: false } }, animation: { duration: 1000 } }
            });
        }
        
        async function updateEmployeeGoalYear(delta) {
            const yearEl = document.getElementById('goalDisplayYear');
            let year = parseInt(yearEl.innerText) + delta;
            if (year < 2020) return;
            yearEl.innerText = year;
            
            try {
                const response = await fetch(`/EmployeeDashboard/GetYearlyGoalStats?year=${year}`);
                const data = await response.json();
                
                document.getElementById('valTarget').innerText = fmtBDT(data.goal);
                document.getElementById('valAchieved').innerText = fmtBDT(data.revenue) + ' achieved';
                document.getElementById('valRemaining').innerText = fmtBDT(Math.max(0, data.remaining));
                document.getElementById('valPercent').innerText = data.percent + '%';
                document.getElementById('valProgressBar').style.width = data.percent + '%';
                document.getElementById('noteYear').innerText = year;
                
                goalRing.data.datasets[0].data = [data.percent, 100 - data.percent];
                goalRing.update();
            } catch (e) { console.error('Error fetching goal stats:', e); }
        }

        document.addEventListener('DOMContentLoaded', () => {
            initGoalRing();
             // Line Chart
            const ctx = document.getElementById('salesChart').getContext('2d');
            salesChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartData.weekly.labels,
                    datasets: [{
                        label: 'My Revenue',
                        data: chartData.weekly.amount,
                        borderColor: '#532374',
                        backgroundColor: 'rgba(83, 35, 116, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true } }
                }
            });

            // Pie Chart
            const ctxPie = document.getElementById('typePieChart').getContext('2d');
            const colors = ['#532374','#17a2b8','#f59e0b','#28a745','#dc3545'];
            const totalSum = pieAmounts.reduce((a, b) => a + b, 0);

            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: pieLabels,
                    datasets: [{ data: pieAmounts, backgroundColor: colors }]
                },
                options: { 
                    cutout: '70%', 
                    responsive: true, 
                    maintainAspectRatio: false, 
                    plugins: { 
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const value = context.raw;
                                    const percentage = totalSum > 0 ? ((value / totalSum) * 100).toFixed(1) + '%' : '0%';
                                    return ` ${context.label}: ৳${value.toLocaleString()} (${percentage})`;
                                }
                            }
                        }
                    } 
                }
            });

            // Pie Legend
            const legend = document.getElementById('pieLegend');
            pieLabels.forEach((lbl, i) => {
                const el = document.createElement('div');
                el.innerHTML = `<span style="width:10px;height:10px;background:${colors[i%colors.length]};display:inline-block;border-radius:50%;"></span> <small>${lbl}</small>`;
                legend.appendChild(el);
            });
        });

        document.querySelectorAll('.chart-range-item').forEach(item => {
            item.addEventListener('click', function(e) {
                e.preventDefault();
                const range = this.dataset.range;
                document.getElementById('rangeDropdownLabel').innerText = this.innerText.trim();
                
                if (range === 'prevyear') {
                    fetchYearData(parseInt(document.getElementById('displayYear').innerText));
                } else {
                    salesChart.data.labels = chartData[range].labels;
                    salesChart.data.datasets[0].data = chartData[range].amount;
                    salesChart.update();
                }
            });
        });

        async function updateYear(delta) {
            const yearSpan = document.getElementById('displayYear');
            let currentYear = parseInt(yearSpan.innerText);
            currentYear += delta;
            yearSpan.innerText = currentYear;
            await fetchYearData(currentYear);
            document.getElementById('rangeDropdownLabel').innerText = 'Year ' + currentYear;
        }

        async function fetchYearData(year) {
            try {
                const response = await fetch(`/EmployeeDashboard/GetYearlySales?year=${year}`);
                const data = await response.json();
                chartData.prevyear = {
                    labels: data.map(s => s.monthName + ' ' + s.year),
                    amount: data.map(s => s.amount)
                };
                salesChart.data.labels = chartData.prevyear.labels;
                salesChart.data.datasets[0].data = chartData.prevyear.amount;
                salesChart.update();
            } catch (e) { console.error(e); }
        }
    </script>
}
